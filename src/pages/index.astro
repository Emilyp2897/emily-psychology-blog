---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// Get latest blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3); // Get 3 latest posts
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">

      <section class="hero">
        <h1>About Me</h1>
      </section>

      <section class="intro about-grid">
        <div class="about-text">
          <p>My name is Emily Phelan, I am a 32-year-old female athlete living in London, and I play Ladies Gaelic Football. I have experienced anxiety and depression during my sporting journey, and for a long time I didn’t have access to resources that helped me understand what was happening in my mind, why pressure felt overwhelming at times, why confidence shifted, and why certain moments in sport affected me the way they did.</p>
          <p>Mind the Gael was created from that gap, with the aim of bringing clear, accessible sports psychology and mental performance education directly to athletes, so they can begin to understand themselves and their performance without having to rely on occasional workshops or limited access to support.</p>
        </div>
        <div class="arrow-image-row arrow-image-row-reverse">
          <img class="about-image-img" src="/EmilyPhelan-Depressed.jpg" alt="Emily Phelan" />
          <span class="arrow-to-image" aria-hidden="true">
            <svg width="60" height="24" viewBox="0 0 60 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M60 12H10m0 0l8-8m-8 8l8 8" stroke="var(--green-lime)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="guess-arrow-text">This was me on league final day. My head was all over the place and although I was happy for my team, I couldnt be happy myself because of my performance. I was not in a good place mentally and that showed on the pitch.</span>
        </div>
        <div class="arrow-image-row">
          <span class="guess-arrow-text">And here's me, a year later on the same league final day. Happy and thriving because I have worked hard on my mental health. The road to this was a very long one. if you want to hear my story please click the link here.</span>
          <span class="arrow-to-image" aria-hidden="true">
            <svg width="60" height="24" viewBox="0 0 60 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0 12h50m0 0l-8-8m8 8l-8 8" stroke="var(--green-lime)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <img class="about-image-img" src="/assets/saoirse.png" alt="Emily Phelan" />
        </div>
      </section>

      <h2 class="section-heading">Subscriptions</h2>
      <div class="two-col-grid">
        <section class="subscription-box individual-subscription">
          <h3>Individual subscription</h3>
          <p>Access all articles and mental wellbeing resources.</p>
          <form class="subscription-form">
            <input type="email" placeholder="Enter your email" required>
            <button type="submit" name="plan" value="individual">Subscribe</button>
          </form>
        </section>
        <section class="subscription-box team-subscription">
          <h3>Team subscription</h3>
          <p>Get access for your whole team. Contact us for a quote.</p>
          <form class="team-contact-form" action="/contact-us" method="get" onsubmit="return true;">
            <input type="email" name="email" placeholder="Your email (for team quote)" required>
            <button type="submit" class="team-contact-link">Request team quote</button>
          </form>
        </section>
      </div>

      <h2 class="section-heading">Workshops</h2>
      <div class="two-col-grid">
        <section class="subscription-box public-workshops coming-soon-box">
          <h3>Online Workshops</h3>
          <p>We offer public workshops every quarter</p>
          <div class="coming-soon">
            <img src="/assets/saoirse.png" alt="Shamrock" class="coming-soon-img" />
            <span class="coming-soon-text">Coming Soon</span>
            <a href="/online-workshops" class="view-all-link">Find out more →</a>
          </div>
        </section>
        <section class="subscription-box team-workshops coming-soon-box">
          <h3>In person Workshops</h3>
          <p>We offer 1 and 2 day workshops for teams looking for mental wellbeing and performance coaching</p>
          <div class="coming-soon">
            <img src="/assets/saoirse.png" alt="Shamrock" class="coming-soon-img" />
            <span class="coming-soon-text">Coming Soon</span>
            <a href="/in-person-workshops" class="view-all-link">Find out more →</a>
          </div>
        </section>
      </div>

      <h2 class="section-heading">Personal Training</h2>
      <section class="subscription-box personal-training-box coming-soon-box">
        <h3>One-to-One Personal Training</h3>
        <p>Focused on mental wellbeing, performance coaching and women's health.</p>
        <div class="coming-soon">
          <img src="/assets/saoirse.png" alt="Shamrock" class="coming-soon-img" />
          <span class="coming-soon-text">Coming Soon</span>
          <a href="/personal-training" class="view-all-link">Find out more →</a>
        </div>
      </section>

      <section class="latest-blog-box">
        <h2>Latest Articles</h2>
        <ul class="latest-posts">
          {latestPosts.map(post => (
            <li>
              <a href={`/blog/${post.slug}/`}>
                <h3>{post.data.title}</h3>
                <p class="post-date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                {post.data.description && <p class="post-description">{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog" class="view-all-link">View All Articles →</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  h2 {
    color: var(--green-lime);
    font-size: 1.5rem;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  h3 {
    color: var(--green-lime);
    font-size: 1.2rem;
    margin: 0 0 0.5rem 0;
  }

  .tagline {
    color: var(--green-light);
    font-size: 1.2rem;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .intro p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .about-grid {
    display: flex;
    flex-direction: column;
    max-width: 1200px;
    margin-bottom: 3rem;
    gap: 0;
  }

  .about-text {
    margin-bottom: 0.5rem;
  }

  .arrow-image-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .guess-arrow-text {
    font-weight: 500;
  }

  .arrow-to-image {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.5rem;
  }

  .arrow-image-row-reverse {
    flex-direction: row;
    justify-content: flex-start;
    
  }

  @media (max-width: 900px) {
    .arrow-image-row-reverse {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
  }

 .about-image-img {
    width: 500px;
    object-fit: cover;
    max-width: 100%;
    border-radius: 12px;
    border: 2px solid var(--green-lime);
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    display: block;
  }

  @media (max-width: 900px) {
    .about-grid {
      max-width: 100%;
    }
    .arrow-image-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .about-image-img {
      max-width: 160px;
    }
  }

  .section-heading {
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: var(--green-lime);
    font-size: 1.7rem;
  }

  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    align-items: stretch;
  }

  .two-col-grid > section {
    display: flex;
    flex-direction: column;
    justify-content: stretch;
    height: 100%;
  }

  .individual-subscription,
  .team-subscription,
  .public-workshops,
  .team-workshops {
    margin: 0;
    padding: 1.5rem 2rem;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    transition: transform 0.2s ease, border-color 0.2s ease;
    height: 100%;
    box-sizing: border-box;
  }

  .individual-subscription:hover,
  .team-subscription:hover,
  .public-workshops:hover,
  .team-workshops:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .team-contact-form,
  .subscription-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: auto;
  }

  .team-contact-form input,
  .subscription-form input {
    padding: 0.75rem;
    border: 2px solid var(--green-lime);
    border-radius: 4px;
    background-color: var(--green-dark);
    color: var(--green-light);
    font-family: inherit;
    font-size: 1rem;
  }

  .team-contact-form input::placeholder,
  .subscription-form input::placeholder {
    color: rgba(244, 255, 232, 0.6);
  }

  .team-contact-form button,
  .subscription-form button {
    padding: 0.75rem 1.5rem;
    background-color: var(--green-lime);
    color: var(--green-dark);
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
    font-size: 1rem;
  }

  .team-contact-form button:hover,
  .subscription-form button:hover {
    background-color: var(--purple-light);
  }

  .personal-training-box {
    margin: 0 0 2rem 0;
    padding: 1.5rem 2rem;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    transition: transform 0.2s ease, border-color 0.2s ease;
    text-align: center;
  }

  .personal-training-box:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .latest-blog-box {
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    margin-bottom: 2rem;
  }

  .latest-blog-box:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .latest-posts {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
  }

  .latest-posts li {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(192, 254, 113, 0.2);
  }

  .latest-posts li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .latest-posts li a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .latest-posts li a:hover h3 {
    color: var(--purple-light);
  }

  .post-date {
    color: var(--green-light);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .post-description {
    color: var(--green-light);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .view-all-link {
    display: inline-block;
    color: var(--green-lime);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s ease;
    margin-top: 0.75rem;
    align-self: center;
  }
  .view-all-link:hover {
    border-bottom-color: var(--green-lime);
  }

  @media (max-width: 768px) {
    .intro p {
      font-size: 1rem;
    }
  }
  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-top: 0.75rem;
    gap: 0.75rem;
    align-self: center;
  }

  .coming-soon-img {
    width: 60px;
    height: 60px;
    opacity: 0.8;
  }

  .coming-soon-text {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--green-lime);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>