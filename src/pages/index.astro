---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// Get latest blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter(post => !post.data.seriesIndex) // Exclude series index pages
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3); // Get 3 latest posts
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">

      <section class="hero">
        <h1>About Me</h1>
      </section>

      <section class="intro about-grid">
        <div class="about-text">
          <p>My name is Emily Phelan, I am a 32-year-old female athlete living in London, and I play Ladies Gaelic Football. I have experienced anxiety and depression during my sporting journey, and for a long time I didn’t have access to resources that helped me understand what was happening in my mind, why pressure felt overwhelming at times, why confidence shifted, and why certain moments in sport affected me the way they did.</p>
          <p>Mind the Gael was created from that gap, with the aim of bringing clear, accessible sports psychology and mental performance education directly to athletes, so they can begin to understand themselves and their performance without having to rely on occasional workshops or limited access to support.</p>
          <p>
            <span class="guess-arrow-text">Can you guess which one is me on league final day?</span>
            <span class="arrow-to-image" aria-hidden="true">
              <svg width="60" height="24" viewBox="0 0 60 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 12h50m0 0l-8-8m8 8l-8 8" stroke="var(--green-lime)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </p>
        </div>
        <div class="about-image">
          <img src="/EmilyPhelan-Depressed.jpg" alt="Emily Phelan" />
        </div>
      </section>

      <h2 class="section-heading">Subscriptions</h2>
      <div class="two-col-grid">
        <section class="subscription-box individual-subscription">
          <h3>Individual subscription</h3>
          <p>Access all articles and mental wellbeing resources.</p>
          <form class="subscription-form">
            <input type="email" placeholder="Enter your email" required>
            <button type="submit" name="plan" value="individual">Subscribe</button>
          </form>
        </section>
        <section class="subscription-box team-subscription">
          <h3>Team subscription</h3>
          <p>Get access for your whole team. Contact us for a quote.</p>
          <form class="team-contact-form" action="/contact-us" method="get" onsubmit="return true;">
            <input type="email" name="email" placeholder="Your email (for team quote)" required>
            <button type="submit" class="team-contact-link">Request team quote</button>
          </form>
        </section>
      </div>

      <h2 class="section-heading">Workshops</h2>
      <div class="two-col-grid">
        <section class="subscription-box public-workshops">
          <h3>Looking for what workshops are coming up?</h3>
          <p>We offer public workshops every quarter</p>
          <form class="team-contact-form" action="/contact-us" method="get" onsubmit="return true;">
            <input type="email" name="email" placeholder="Your email (for team quote)" required>
            <button type="submit" class="team-contact-link">Click Below Here to See Upcoming Dates</button>
          </form>
        </section>
        <section class="subscription-box team-workshops">
          <h3>Looking for personalised team workshops?</h3>
          <p>We offer 1 and 2 day workshops for teams looking for mental wellbeing and performance coaching</p>
          <form class="team-contact-form" action="/contact-us" method="get" onsubmit="return true;">
            <input type="email" name="email" placeholder="Your email (for team quote)" required>
            <button type="submit" class="team-contact-link">Click Here for a Quote</button>
          </form>
        </section>
      </div>

      <section class="latest-blog-box">
        <h2>Latest Articles</h2>
        <ul class="latest-posts">
          {latestPosts.map(post => (
            <li>
              <a href={`/blog/${post.slug}/`}>
                <h3>{post.data.title}</h3>
                <p class="post-date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                {post.data.description && <p class="post-description">{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog" class="view-all-link">View All Articles →</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  h2 {
    color: var(--green-lime);
    font-size: 1.5rem;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  h3 {
    color: var(--green-lime);
    font-size: 1.2rem;
    margin: 0 0 0.5rem 0;
  }

  .tagline {
    color: var(--green-light);
    font-size: 1.2rem;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .intro p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    align-items: center;
    max-width: 1200px;
    margin-bottom: 3rem;
  }

  .about-image img {
    width: 450px;
    max-width: 100%;
    border-radius: 12px;
    border: 3px solid var(--green-lime);
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    display: block;
    margin: 0 auto;
  }

  @media (max-width: 700px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .about-image img {
      max-width: 160px;
    }
  }

  .arrow-to-image {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.5rem;
  }

  @media (max-width: 700px) {
    .arrow-to-image {
      display: none;
    }
  }

  .section-heading {
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: var(--green-lime);
    font-size: 1.7rem;
  }

  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    align-items: stretch;
  }

  .two-col-grid > section {
    display: flex;
    flex-direction: column;
    justify-content: stretch;
    height: 100%;
  }

  .individual-subscription,
  .team-subscription,
  .public-workshops,
  .team-workshops {
    margin: 0;
    padding: 1.5rem 2rem;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    transition: transform 0.2s ease, border-color 0.2s ease;
    height: 100%;
    box-sizing: border-box;
  }

  .individual-subscription:hover,
  .team-subscription:hover,
  .public-workshops:hover,
  .team-workshops:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .team-contact-form,
  .subscription-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .team-contact-form input,
  .subscription-form input {
    padding: 0.75rem;
    border: 2px solid var(--green-lime);
    border-radius: 4px;
    background-color: var(--green-dark);
    color: var(--green-light);
    font-family: inherit;
    font-size: 1rem;
  }

  .team-contact-form input::placeholder,
  .subscription-form input::placeholder {
    color: rgba(244, 255, 232, 0.6);
  }

  .team-contact-form button,
  .subscription-form button {
    padding: 0.75rem 1.5rem;
    background-color: var(--green-lime);
    color: var(--green-dark);
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
    font-size: 1rem;
  }

  .team-contact-form button:hover,
  .subscription-form button:hover {
    background-color: var(--purple-light);
  }

  .latest-blog-box {
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    margin-bottom: 2rem;
  }

  .latest-blog-box:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .latest-posts {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
  }

  .latest-posts li {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(192, 254, 113, 0.2);
  }

  .latest-posts li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .latest-posts li a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .latest-posts li a:hover h3 {
    color: var(--purple-light);
  }

  .post-date {
    color: var(--green-light);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .post-description {
    color: var(--green-light);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .view-all-link {
    display: inline-block;
    color: var(--green-lime);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s ease;
  }
  .view-all-link:hover {
    border-bottom-color: var(--green-lime);
  }

  @media (max-width: 768px) {
    .intro p {
      font-size: 1rem;
    }
  }
</style>