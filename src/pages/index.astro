---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// Get latest blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter(post => !post.data.seriesIndex) // Exclude series index pages
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3); // Get 3 latest posts
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">

      <section class="hero">
        <h1>Mind the Gael</h1>
        <p class="tagline">Evidence-based mental health resources for women in sport</p>
      </section>

      <section class="intro">
        <p>
          Mind the Gael is a mental health awareness platform launching in April 2026, built specifically for female athletes in Ladies Gaelic Football. Through Instagram and a dedicated website, it delivers evidence-based education on mental health, sports psychology, and performance wellbeing — framed around the lived experience of women in sport.
        </p>
      </section>

      <div class="content-grid">
        <div class="subscription-stack">
          <section class="subscription-box individual-subscription">
            <h2>Individual subscription: £2.99 per month</h2>
            <p>Access all articles and mental wellbeing resources.</p>
            <form class="subscription-form">
              <input type="email" placeholder="Enter your email" required>
              <button type="submit" name="plan" value="individual">Subscribe</button>
            </form>
          </section>
          <section class="subscription-box team-subscription">
            <h2>Team subscription</h2>
            <p>Get access for your whole team. Contact us for a quote.</p>
            <form class="team-contact-form" action="/contact-us" method="get" onsubmit="return true;">
              <input type="email" name="email" placeholder="Your email (for team quote)" required>
              <button type="submit" class="team-contact-link">Request team quote</button>
            </form>
          </section>
        </div>
        <section class="latest-blog-box">
          <h2>Latest Articles</h2>
          <ul class="latest-posts">
            {latestPosts.map(post => (
              <li>
                <a href={`/blog/${post.slug}/`}>
                  <h3>{post.data.title}</h3>
                  <p class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                  {post.data.description && <p class="post-description">{post.data.description}</p>}
                </a>
              </li>
            ))}
          </ul>
          <a href="/blog" class="view-all-link">View All Articles →</a>
        </section>
      </div>

    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  h2 {
    color: var(--green-lime);
    font-size: 1.5rem;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  h3 {
    color: var(--green-lime);
    font-size: 1.2rem;
    margin: 0 0 0.5rem 0;
  }

  .tagline {
    color: var(--green-light);
    font-size: 1.2rem;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .intro {
    margin-bottom: 3rem;
    max-width: 800px;
  }

  .intro p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    align-items: stretch;
  }
  .subscription-stack {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    height: 100%;
    grid-column: 1;
  }
  .latest-blog-box {
    grid-column: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: stretch;
  }

  .subscription-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .individual-subscription,
  .team-subscription {
    margin: 0;
    padding: 1.5rem 2rem;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .individual-subscription:hover,
  .team-subscription:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .team-contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .team-contact-form input {
    padding: 0.75rem;
    border: 2px solid var(--green-lime);
    border-radius: 4px;
    background-color: var(--green-dark);
    color: var(--green-light);
    font-family: inherit;
    font-size: 1rem;
  }
  .team-contact-form input::placeholder {
    color: rgba(244, 255, 232, 0.6);
  }
  .team-contact-form button {
    padding: 0.75rem 1.5rem;
    background-color: var(--green-lime);
    color: var(--green-dark);
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
    font-size: 1rem;
  }
  .team-contact-form button:hover {
    background-color: var(--purple-light);
  }
  .team-subscription {
    margin-top: 2rem;
  }

  .subscription-box,
  .latest-blog-box {
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .subscription-box:hover,
  .latest-blog-box:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .subscription-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .subscription-form input {
    padding: 0.75rem;
    border: 2px solid var(--green-lime);
    border-radius: 4px;
    background-color: var(--green-dark);
    color: var(--green-light);
    font-family: inherit;
    font-size: 1rem;
  }

  .subscription-form input::placeholder {
    color: rgba(244, 255, 232, 0.6);
  }

  .subscription-form button {
    padding: 0.75rem 1.5rem;
    background-color: var(--green-lime);
    color: var(--green-dark);
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
    font-size: 1rem;
  }

  .subscription-form button:hover {
    background-color: var(--purple-light);
  }

  .latest-posts {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
  }

  .latest-posts li {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(192, 254, 113, 0.2);
  }

  .latest-posts li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .latest-posts li a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .latest-posts li a:hover h3 {
    color: var(--purple-light);
  }

  .post-date {
    color: var(--green-light);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .post-description {
    color: var(--green-light);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .view-all-link {
    display: inline-block;
    color: var(--green-lime);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s ease;
  }

  .view-all-link:hover {
    border-bottom-color: var(--green-lime);
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .intro p {
      font-size: 1rem;
    }
  }
</style>
