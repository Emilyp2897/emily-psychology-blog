---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('blog');

// Show the first post from each core series in the home page article section.
const featuredSlugs = [
  'training-the-mind/attention-control-theory',
  'gael-performance-toolkit/reset-your-focus-toolkit',
  'strong-minds-stronger-players/strong-minds-stronger-players',
];

const latestPosts = featuredSlugs
  .map((slug) => allPosts.find((post) => post.slug === slug))
  .filter((post): post is (typeof allPosts)[number] => post !== undefined);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="home-page">
    <Header />
    <main class="container">
      <section class="hero">
      </section>

      <section class="about">
        <h2>Why this platform exists</h2>
        <p>Mind the Gael exists because many female athletes, including me, do not get consistent access to sports psychology support.</p>
        <p>And that creates a gap. A gap in understanding confidence, pressure, focus, anxiety, and mental wellbeing in sport, right when athletes need that understanding the most.</p>
        <p>Mind the Gael exists to help bridge that gap.</p>
        <p>Just to be really clear, I am not a sports psychologist. This platform is not clinical advice or therapy. What I share here is based on my own lived experience as an athlete, alongside research I'm actively learning from, exploring, and translating into language that makes sense in real sport.</p>
        <p>My aim is education and awareness,helping athletes better understand their minds, not diagnosing or treating anything.</p>
        
        <h2>The Problem I'm Focused On</h2>
        <p>This platform comes from my own experience as an athlete: struggling with anxiety, overthinking, confidence dips, and pressure, then realizing I needed practical understanding, not generic motivation; Mind the Gael focuses on what these moments actually feel like in training and matches and turns lived experience plus psychological learning into clear, usable guidance for real-time performance.</p>

        <h2>What will you find here?</h2>
        <p>You will find three core areas: the Content Hub, Personal Training, and Online Workshops.</p>
        <p>The <strong>Content Hub</strong> is where all educational content lives, and it is broken into three parts:</p>
        <ul>
          <li><strong>Training the Mind Blog:</strong> sports psychology explained in simple, practical language.</li>
          <li><strong>Gael Performance Toolkit:</strong> practical tools for focus, confidence, pressure moments, and match-day decision making.</li>
          <li><strong>Stronger Minds, Stronger Players:</strong> always free content focused on spotting when someone may be struggling with mental health and signposting pathways to professional resources.</li>
        </ul>
        <p><strong>Personal Training</strong> is exercise-based coaching with a special focus on women's health. While there is overlap with performance and wellbeing, the primary focus is physical training support for female athletes.</p>
        <p><strong>Online Workshops</strong> provide structured, topic-based coaching in an accessible format for athletes and teams.</p>

        <h2>Who This Platform is For</h2>
        <p> This is for female athletes, coaches, and support staff who want to better understand the mental side of performance.</p>
          <p>It's for those who want to:</p>
          <ul>
            <li>perform more consistently under pressure</li>
            <li>build confidence in key moments</li>
            <li>Understand how mindset affects focus and decision-making</li>
            <li>Make sense of what you're experiencing mentally in sport.</li>
            <li>Support your own wellbeing, and know when to seek further help if needed</li>
            <li>Or if you're involved in player development or coaching and want a clearer understanding of sports psychology in action.</li>
          </ul>

        <h2>Start here</h2>

        <section class="founding-offer" aria-label="Founding offer">
          <h3>Founding Offer</h3>
          <p><strong>£5/month for the first 50 members</strong> (then £8/month).</p>
          <p><strong>Includes a 14-day free trial</strong>, then full monthly access.</p>
          <p>Each month includes: 4 Training the Mind articles, 4 Gael Performance Toolkits, and 1 mindfulness newsletter.</p>
          <p><strong>Stronger Minds, Stronger Players is always free</strong> because it helps people spot when someone may be struggling with their mental health and points them toward professional support pathways.</p>
          <a class="founding-offer-cta" href="/api/create-checkout-session?plan=individual">Start Free Trial</a>
        </section>

      </section>

      <section class="latest-blog-box">
        <h2>Latest Articles and Toolkits</h2>
        <ul class="latest-posts">
          {latestPosts.map((post) => (
            <li>
              <a href={`/content-hub/${post.slug}/`}>
                <h3>{post.data.title}</h3>
                <p class="post-date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                {post.data.description && <p class="post-description">{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
        <a href="/content-hub" class="view-all-link">View All Articles →</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero h1 {
    margin: 0 0 0.5rem 0;
  }

  .hero:not(.why-hero) h1 {
    margin-top: 1.5rem;
  }

  .tagline {
    color: var(--green-light);
    font-size: 1.2rem;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .intro p {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .about ul {
    margin: 0 0 1.5rem 1.5rem;
    padding-left: 1rem;
  }

  .about li {
    margin-bottom: 0.5rem;
  }

  .founding-offer {
    margin: 1rem 0 2rem;
    padding: 1rem 1.1rem;
    border: 2px solid var(--green-lime);
    border-radius: 10px;
    background: rgba(240, 205, 255, 0.12);
  }

  .founding-offer h3 {
    margin: 0 0 0.6rem;
    color: var(--green-lime);
  }

  .founding-offer p {
    margin-bottom: 0.6rem;
  }

  .founding-offer-cta {
    display: inline-block;
    margin-top: 0.35rem;
    padding: 0.65rem 1rem;
    border-radius: 8px;
    border: 2px solid var(--green-lime);
    background: var(--green-lime);
    color: var(--green-dark);
    font-weight: 700;
    text-decoration: none;
  }

  .founding-offer-cta:hover {
    border-color: var(--purple-light);
    background: var(--purple-light);
  }

  .about-grid {
    display: flex;
    flex-direction: column;
    max-width: 1200px;
    margin-bottom: 3rem;
    gap: 0;
  }

  .why-grid {
    margin-bottom: 1.25rem;
  }

  .about-text {
    margin-bottom: 2rem;
  }

  .about-text p:last-child {
    margin-bottom: 0;
  }

  .arrow-image-row {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  .guess-arrow-text {
    font-size: 1rem;
    font-weight: 500;
  }

  .guess-arrow-text p:last-child {
    margin-bottom: 0;
  }

  .arrow-to-image {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.5rem;
  }

  .arrow-image-row-reverse {
    flex-direction: row;
    justify-content: flex-start;
  }

  .why-hero {
    margin-top: -1rem;
  }

  .about-image-img {
    width: 500px;
    object-fit: cover;
    max-width: 100%;
    border-radius: 12px;
    border: 2px solid var(--green-lime);
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    display: block;
  }

  .section-heading {
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: var(--green-lime);
    font-size: 1.7rem;
  }

  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    align-items: stretch;
  }

  .two-col-grid > section {
    display: flex;
    flex-direction: column;
    justify-content: stretch;
    height: 100%;
  }

  .individual-subscription,
  .team-subscription {
    margin: 0;
    padding: 1.5rem 2rem;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    transition: transform 0.2s ease, border-color 0.2s ease;
    height: 100%;
    box-sizing: border-box;
  }

  .individual-subscription:hover,
  .team-subscription:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .team-contact-form,
  .subscription-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: auto;
  }

  .team-contact-form input,
  .subscription-form input {
    padding: 0.75rem;
    border: 2px solid var(--green-lime);
    border-radius: 4px;
    background-color: var(--green-dark);
    color: var(--green-light);
    font-family: inherit;
    font-size: 1rem;
  }

  .team-contact-form input::placeholder,
  .subscription-form input::placeholder {
    color: rgba(244, 255, 232, 0.6);
  }

  .team-contact-form button,
  .subscription-form button {
    padding: 0.75rem 1.5rem;
    background-color: var(--green-lime);
    color: var(--green-dark);
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
    font-size: 1rem;
  }

  .team-contact-form button:hover,
  .subscription-form button:hover {
    background-color: var(--purple-light);
  }

  .personal-training-box {
    margin: 0 0 2rem 0;
    padding: 1.5rem 2rem;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    transition: transform 0.2s ease, border-color 0.2s ease;
    text-align: center;
  }

  .personal-training-box:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .latest-blog-box {
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    margin-bottom: 2rem;
  }

  .latest-blog-box:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .latest-posts {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
  }

  .latest-posts li {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(192, 254, 113, 0.2);
  }

  .latest-posts li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .latest-posts li a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .latest-posts li a:hover h3 {
    color: var(--purple-light);
  }

  .post-date {
    color: var(--green-light);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .post-description {
    color: var(--green-light);
    font-size: 1rem;
    line-height: 1.5;
  }

  .view-all-link {
    display: inline-block;
    color: var(--green-lime);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s ease;
    margin-top: 0.75rem;
    align-self: center;
  }

  .view-all-link:hover {
    border-bottom-color: var(--green-lime);
  }

  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-top: 0.75rem;
    gap: 0.75rem;
    align-self: center;
  }

  .coming-soon-img {
    width: 60px;
    height: 60px;
    opacity: 0.8;
  }

  .coming-soon-text {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--green-lime);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .two-col-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .individual-subscription,
    .team-subscription,
    .personal-training-box,
    .latest-blog-box {
      padding: 1.25rem 1rem;
    }

    .section-heading {
      font-size: 1.45rem;
      margin-top: 2.2rem;
    }

    .about-grid {
      max-width: 100%;
    }

    .arrow-image-row,
    .arrow-image-row-reverse {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .about-image-img {
      width: min(100%, 360px);
    }
  }

  @media (max-width: 768px) {
    .intro p,
    .guess-arrow-text {
      font-size: 0.95rem;
    }
  }
</style>
