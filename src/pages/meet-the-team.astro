---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<html lang="en">
  <head>
    <BaseHead title={`Meet the Team | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">
      <h1>Meet the Team</h1>
      <section class="team-bio">
        <div class="bio-image">
          <img src="/assets/emilyprofile.png" alt="Emily Phelan" />
        </div>
        <div class="bio-text">
          <h2>Emily Phelan</h2>
          <h3>Mental Wellbeing & Performance Coach</h3>
          <p>Add your bio paragraph here. Tell visitors about your background, qualifications, experience and what drives your passion for psychology and wellbeing.</p>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin-bottom: 2rem;
  }

  .team-bio {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 700px;
    margin: 0 auto 3rem auto;
    padding: 2rem;
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    background-color: rgba(240, 205, 255, 0.1);
  }

  .bio-image img {
    width: 200px;
    height: 200px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid var(--green-lime);
    background: #fff;
  }

  .bio-text {
    text-align: center;
    margin-top: 1.5rem;
  }

  .bio-text h2 {
    color: var(--green-lime);
    font-size: 1.5rem;
    margin: 0 0 0.25rem 0;
  }

  .bio-text h3 {
    color: var(--green-lime);
    margin-bottom: 1rem;
  }

  .bio-role {
    color: var(--purple-light);
    font-size: 1.1rem;
    font-style: italic;
    display: block;
    margin-bottom: 1rem;
  }

  .bio-text p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #f0cdff;
  }

  @media (max-width: 768px) {
    .bio-image img {
      width: 150px;
      height: 150px;
    }
  }
</style>