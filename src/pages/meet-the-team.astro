---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container" style="padding-top:0;margin-top:0;">
      <section class="resources-bubbles" style="margin-top: 0;">
        <!-- Example team member bubble -->
        <div class="resource-bubble">
          <button type="button" aria-label="Emily O'Connor">
            <span class="bubble-icon" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
              <img src="/assets/happy.png" alt="Emily Phelan Photo" style="width: 120px; height: 120px; object-fit: contain; margin-bottom: 0.3em; border-radius: 50%; background: #fff;" />
            </span>
            <span class="bubble-label">Emily Phelan<br/>Founder</span>
          </button>
        </div>
        <div class="resource-bubble">
          <button type="button" aria-label="Nicci Mernagh">
            <span class="bubble-icon" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
              <img src="/assets/happy.png" alt="Nicci Mernagh Photo" style="width: 120px; height: 120px; object-fit: contain; margin-bottom: 0.3em; border-radius: 50%; background: #fff;" />
            </span>
            <span class="bubble-label">Nicci Mernagh<br/>Design Director</span>
          </button>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
<style>
  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  h2 {
    color: var(--green-lime);
    font-size: 1.5rem;
    margin-top: 2rem;
  }

  .tagline {
    color: #f0cdff;
    font-size: 1.2rem;
    font-style: italic;
    margin-bottom: 2rem;
  }


  .resources-bubbles {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 5rem;
    margin: 3rem 0 0 0 !important;
    padding-top: 0 !important;
    position: relative;
  }
  @media (max-width: 720px) {
    .resources-bubbles {
      flex-direction: column;
      gap: 2.5rem;
      margin: 1.5rem 0 0 0 !important;
    }
    .resource-bubble {
      min-width: 140px;
      max-width: 90vw;
    }
    .resource-bubble button {
      width: 140px;
      height: 140px;
      font-size: 1.2rem;
    }
    .bubble-label {
      font-size: 1rem;
      padding: 0.4em 1em;
      bottom: -2.2rem;
    }
  }
  .resource-bubble {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1 1 320px;
    min-width: 260px;
    max-width: 340px;
    margin-bottom: 1.5rem;
    margin-top: 0 !important;
  }

  .resource-bubble button {
    background: var(--green-dark);
    border: 3px solid var(--green-lime);
    border-radius: 50%;
    width: var(--bubble-size, 260px);
    height: var(--bubble-size, 260px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    box-shadow: 0 4px 24px rgba(0,0,0,0.15);
    position: relative;
    outline: none;
    font-size: 3rem;
  }
  .resource-bubble button:hover,
  .resource-bubble button:focus {
    border-color: var(--purple-light);
    box-shadow: 0 8px 32px rgba(105,0,90,0.18);
    transform: scale(1.07) rotate(-2deg);
    z-index: 2;
  }
  .resource-bubble button:hover,
  .resource-bubble button:focus {
    border-color: var(--purple-light);
    box-shadow: 0 4px 16px rgba(105,0,90,0.12);
  }
  .bubble-icon {
    font-size: 3.5rem;
    color: var(--green-lime);
    pointer-events: none;
    user-select: none;
  }
  .bubble-label {
    position: absolute;
    left: 50%;
    bottom: -2.7rem;
    transform: translateX(-50%) scale(1);
    background: var(--purple);
    color: #fff;
    padding: 0.6em 1.6em;
    border-radius: 1.5em;
    font-size: 1.25rem;
    font-weight: 700;
    opacity: 1;
    pointer-events: auto;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0,0,0,0.13);
    z-index: 2;
  }

  .closing {
    color: #f0cdff;
    font-style: italic;
    font-size: 1.05rem;
  }
</style>
