---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<html lang="en">
  <head>
    <BaseHead title={`Meet the Team | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="meet-team-page">
    <Header />
    <main class="container team-main">
      <section class="team-hero"><h1>Meet the Team</h1></section>
      <section class="team-bio">
        <div class="bio-image">
          <img src="/assets/emilyprofile.png" alt="Emily Phelan" />
        </div>
        <div class="bio-text">
          <h2>Emily Phelan</h2>
          <h3>Mental Wellbeing & Performance Coach</h3>
          <p>I am a current Ladies Gaelic Footballer for the Holloway Gaels Intermediate Panel and have played at underage level for Cork as well as representing London at senior level.</p>
          <p>Alongside football, I hold a Level 2 Fitness Instructor qualification and a Level 3 Personal Training qualification, with a specialisation in women’s health. My focus is on supporting women in sport across all stages of their journey, whether that’s returning from injury, returning from maternity leave, nutrition, strength and conditioning, or building sustainable training habits.</p>
          <p>Most importantly, I’m passionate about the mental side of sport, and helping athletes build the stability, awareness, and understanding needed to perform and feel their best under pressure.</p>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .team-main {
    padding: 0 0 2rem;
  }

  .team-hero {
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
    margin: 0 calc(50% - 50vw);
    padding: 2rem max(1rem, calc(50vw - 600px));
  }

  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin: 0;
  }

  .team-bio {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 700px;
    margin: 1.3rem auto 2rem auto;
    padding: 2rem;
    border: 2px solid rgba(105, 0, 90, 0.35);
    border-radius: 12px;
    background: linear-gradient(180deg, rgba(240, 205, 255, 0.92) 0%, rgba(244, 255, 232, 0.9) 100%);
  }

  .bio-image img {
    width: 200px;
    height: 200px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid var(--green-lime);
    background: #fff;
  }

  .bio-text {
    text-align: center;
    margin-top: 1.5rem;
  }

  .bio-text h2 {
    color: var(--purple);
    font-size: 1.5rem;
    margin: 0 0 0.25rem 0;
  }

  .bio-text h3 {
    color: var(--purple);
    margin-bottom: 1rem;
  }

  .bio-role {
    color: var(--purple-light);
    font-size: 1.1rem;
    font-style: italic;
    display: block;
    margin-bottom: 1rem;
  }

  .bio-text p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--green-dark);
  }

  @media (max-width: 768px) {
    .bio-image img {
      width: 150px;
      height: 150px;
    }
  }
</style>