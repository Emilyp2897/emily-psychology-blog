---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Performance Plans | ${SITE_TITLE}`} description="Performance plans for female athletes. Physical training plans + mental performance plans, all delivered online with a special focus on women's health." />
  </head>
  <body class="personal-training-page">
    <Header />
    <main class="container">
      <section class="intro">
        <div class="pt-band pt-band-intro">
          <div class="pt-band-inner">
            <h1>Performance Plans</h1>
            <p>Two performance plans, both delivered fully online and built around women's health for female athletes. The physical training plan is exercise-based: strength, conditioning, recovery, sport-specific work. The mental performance plan focuses on confidence, focus, routines, and staying composed under pressure. Each plan runs as a 6-week or 12-week programme. You receive a full plan to follow at your own pace, with no scheduled check-ins. If you want to talk through your plan once you have it, you can book an optional chat.</p>
          </div>
        </div>

        <div class="pt-band pt-band-pricing pt-band-mental">
          <div class="pt-band-inner">
            <h2 id="mental-performance-plans" class="pricing-heading">Mental Performance Plans</h2>
            <p class="pricing-intro">Built around your sport, your routines, and the performance moments you want to work on. Confidence, focus, pre-game nerves, recovery from mistakes, staying composed under pressure.</p>
            <div class="plan-option-list">
              <article class="plan-option-item">
                <h3>6-Week Mental Performance Plan</h3>
                <p class="plan-option-price">£10</p>
                <p>A 6-week online mental performance plan built around your sport, your routines, and the moments you want to work on: pre-game nerves, focus during play, recovery from mistakes.</p>
                <h4>What you get</h4>
                <ul class="plan-option-list-bullets">
                  <li>6 weekly themes drawn from the 12 Gael Performance Toolkit areas, picked to match what you shared in the intake</li>
                  <li>A weekly concept explainer in plain English, with named frameworks and academic sources where they apply</li>
                  <li>A daily practice table (5-10 minutes a day, 7 days a week) you can do at home, in the car, or before training</li>
                  <li>A "performance moment to apply it" each week, anchored to a real session or match moment in your week</li>
                  <li>A weekly reflection prompt so you can track what is shifting</li>
                  <li>A Routines to Build section: pre-performance routine, refocus routine, post-mistake reset cue, all built around your sport</li>
                  <li>Coach notes for each week (why this week comes here, what to watch for, when to adjust)</li>
                  <li>A Things to Track checklist (confidence, refocus speed, sleep before competition)</li>
                  <li>Optional follow-up chat if you want to talk it through once you have read it</li>
                </ul>
                <p class="plan-option-best-for"><strong>Best for:</strong> one focused mental skill arc — a championship run, a confidence reset, returning from a tough patch.</p>
              </article>
              <article class="plan-option-item">
                <h3>12-Week Mental Performance Plan</h3>
                <p class="plan-option-price">£20</p>
                <p>A 12-week online mental performance plan for longer arcs: pre-season mental prep, post-injury return, or sustained mental skill development.</p>
                <h4>What you get</h4>
                <ul class="plan-option-list-bullets">
                  <li>12 weekly themes spanning the full Gael Performance Toolkit (confidence, focus, routines, self-talk, visualisation, motivation, recovery from mistakes, team pressure, return from injury, long-term mental development)</li>
                  <li>A weekly concept explainer in plain English, with named frameworks and academic sources</li>
                  <li>A daily practice table for every week, scaling complexity as the plan progresses</li>
                  <li>A "performance moment to apply it" each week, mapped to your training and match calendar</li>
                  <li>A weekly reflection prompt</li>
                  <li>A Routines to Build section that layers across the 12 weeks (week 1's breathing becomes week 6's full pre-game routine, becomes week 12's championship-ready protocol)</li>
                  <li>Coach notes for each of the 12 weeks</li>
                  <li>A Things to Track checklist</li>
                  <li>Optional follow-up chat if you want to talk it through</li>
                </ul>
                <p class="plan-option-best-for"><strong>Best for:</strong> a full block of mental skill development — a season build, a return from injury, or laying foundations that hold for the long term.</p>
              </article>
            </div>
            <h3 class="start-plan-heading">Start your plan</h3>
            <p class="consultation-note">Start your mental performance plan by filling in the intake form below. Your plan is built around what you share, then emailed straight to you. Please include as much detail as possible so your programme matches your sport, routines, and goals.</p>
            <button type="button" class="consultation-btn" id="open-mental-modal">Start a Mental Performance Plan</button>
          </div>
        </div>

        <div class="pt-band pt-band-focus">
          <div class="pt-band-inner">
            <div class="training-highlight">
              <div class="training-highlight-copy">
                <h2>Physical training to complement your mental performance plan</h2>
                <p>
                  Once your mental plan is in place, your physical training can reinforce it. Clear progression across strength, recovery, and sport-specific demands helps you apply confidence, focus, and routines under real training and match pressure.
                </p>
              </div>
              <div class="training-highlight-media">
                <img src="/assets/CiaraFlan-London-1.jpg" alt="Ciara Flanagan training in London" loading="lazy" />
              </div>
            </div>
          </div>
        </div>

        <div class="pt-band pt-band-focus-areas">
          <div class="pt-band-inner">
            <div class="focus-areas">
              <div class="focus-card">
                <h3>Strength & Conditioning</h3>
                <p>Structured S&C that builds capacity, movement quality, and the resilience your sport actually demands.</p>
              </div>
              <div class="focus-card">
                <h3>Women's Health Focus</h3>
                <p>Training designed around women's health. Cycle-aware planning, programming for the load demands female athletes actually carry, and a long-term view on your wellbeing.</p>
              </div>
              <div class="focus-card">
                <h3>Performance Integration</h3>
                <p>Your gym work shouldn't sit separate from your sport. Every session is built so the work translates to training and match-day. Not just numbers on the bar.</p>
              </div>
              <div class="focus-card">
                <h3>Recovery & Load Management</h3>
                <p>Train consistently without burning out. Your plan accounts for load, recovery, and progression so the work is sustainable across a season. Not a quick win that breaks down.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="pt-band pt-band-pricing pt-band-physical">
          <div class="pt-band-inner">
            <h2 class="pricing-heading">Physical Performance Plans</h2>
            <p class="pricing-intro">Exercise-based training plans built around your sport, your equipment, and women's health. Strength, conditioning, recovery, and sport-specific work, delivered as a full plan to follow at your own pace.</p>
            <div class="plan-option-list">
              <article class="plan-option-item">
                <h3>6-Week Physical Training Plan</h3>
                <p class="plan-option-price">£10</p>
                <p>A 6-week online training plan built around your sport, your equipment, and your goals. Strength, conditioning, recovery, and sport-specific work. Delivered as a full plan to follow at your own pace, with no scheduled check-ins.</p>
                <h4>What you get</h4>
                <ul class="plan-option-list-bullets">
                  <li>6 weeks of structured training built around your sport, equipment, and the frequency your schedule allows</li>
                  <li>Every session laid out in a clear table (exercise, sets, reps, RPE, rest) with a plain-English description of every movement</li>
                  <li>At least one planned deload week for recovery</li>
                  <li>A cycle-aware programming note each week (where heavier work fits, where mobility and aerobic work fit)</li>
                  <li>Specialised tracks where they apply: pregnancy, postpartum, endometriosis, return-to-play (each backed by recognised guidance like POGP and Aspetar)</li>
                  <li>Coach notes for each week (progression rationale, what to watch for, when to adjust)</li>
                  <li>A list of any exercises excluded for your safety, with the substitutes used in their place</li>
                  <li>A Things to Track section so you can report back on how it landed</li>
                  <li>Optional follow-up chat if you want to talk it through</li>
                </ul>
                <p class="plan-option-best-for"><strong>Best for:</strong> a focused training block — pre-season ramp, getting back into structure, or a short specific goal.</p>
              </article>
              <article class="plan-option-item">
                <h3>12-Week Physical Training Plan</h3>
                <p class="plan-option-price">£20</p>
                <p>A 12-week online training plan for longer arcs: pre-season builds, return-to-play phases, or extended training blocks. Same self-paced delivery, with optional follow-up chat if you want to talk it through.</p>
                <h4>What you get</h4>
                <ul class="plan-option-list-bullets">
                  <li>12 weeks of structured progression with clear phases (accumulation, intensification, peak/taper, deloads)</li>
                  <li>Every session laid out in a table, every exercise described in plain English</li>
                  <li>Built-in deload weeks at the right points (not just bolted on at the end)</li>
                  <li>Cycle-aware notes that shift across the longer arc</li>
                  <li>Specialised tracks where they apply, with the longer block giving room for true progression</li>
                  <li>Coach notes for each of the 12 weeks</li>
                  <li>A list of exercises excluded for your safety, with substitutes</li>
                  <li>A Things to Track section</li>
                  <li>Optional follow-up chat</li>
                </ul>
                <p class="plan-option-best-for"><strong>Best for:</strong> a full block — pre-season build, return-to-play phase, postpartum rebuild, or any time you want progression that lasts longer than a six-week burst.</p>
              </article>
            </div>
          </div>
        </div>

        <div class="pt-band pt-band-booking">
          <div class="pt-band-inner">
            <section class="consultation-cta" aria-labelledby="consultation-heading">
              <h2 id="consultation-heading" class="calendar-heading">Start your plan</h2>
              <p class="calendar-copy">
                Start your physical training plan by filling in the intake form below. Your plan is built around what you share, then emailed straight to you. Please include as much detail as possible so your programme matches your sport, schedule, and goals. If you'd rather email me directly, you can reach me at emilyphelan@mindthegael.co.uk.
              </p>
              <div class="consultation-btn-row">
                <button type="button" class="consultation-btn" id="open-consultation-modal">Start a Physical Training Plan</button>
              </div>
              <p class="consultation-note">The intake form opens in a pop-up when you click the button above.</p>
            </section>
          </div>
        </div>

      </section>

      <div class="consultation-modal-backdrop" id="consultation-modal-backdrop" aria-hidden="true">
        <div class="consultation-modal" role="dialog" aria-modal="true" aria-labelledby="consultation-modal-title">
          <button type="button" class="consultation-close" id="close-consultation-modal" aria-label="Close consultation form">✕</button>
          <h2 id="consultation-modal-title">Programme Intake Form</h2>
          <p class="consultation-intro">Fill this out and hit submit. Your details come straight to me and I'll be in touch within 48 hours with your plan.</p>

          <form id="consultation-form" class="consultation-form">
            <div class="consultation-grid">
              <label>
                Full Name
                <input type="text" name="name" required />
              </label>

              <label>
                Email
                <input type="email" name="email" required />
              </label>

              <label>
                Phone (optional)
                <input type="tel" name="phone" />
              </label>

              <label>
                Sport / Team
                <input type="text" name="sport" required />
              </label>
            </div>

            <div class="progression-plan-fields">
              <h3>Custom Progression Plan</h3>
              <p class="plan-fields-intro">Optional. Fill in your training details so I can build your programme around them. The more I know, the better the plan.</p>

              <label>
                Does any of the following apply to you? (optional)
                <select name="programTrack">
                  <option value="">Select if applicable</option>
                  <option value="pregnancy">Currently pregnant</option>
                  <option value="postpartum">Postpartum (less than 12 months)</option>
                  <option value="endometriosis">Endometriosis</option>
                  <option value="return_to_play">Returning to play from injury</option>
                </select>
              </label>

              <div class="plan-basic-fields">
                <label>
                  Age
                  <input type="number" name="planAge" min="16" max="100" />
                </label>
                <label>
                  Height (e.g. 5'8 or 173cm)
                  <input type="text" name="planHeight" placeholder="e.g. 5'8 or 173cm" />
                </label>
                <label>
                  Weight (e.g. 65kg, 143lbs)
                  <input type="text" name="planWeight" placeholder="e.g. 65kg, 143lbs" />
                </label>
                <label>
                  Exercise Experience
                  <select name="planExerciseLevel">
                    <option value="">Select level</option>
                    <option value="Beginner (less than 1 year)">Beginner (less than 1 year)</option>
                    <option value="Intermediate (1-3 years)">Intermediate (1-3 years)</option>
                    <option value="Advanced (3+ years)">Advanced (3+ years)</option>
                  </select>
                </label>
                <label>
                  Sports Background
                  <select name="planSportsOrNot">
                    <option value="">Select option</option>
                    <option value="Currently competing">Currently competing in a sport</option>
                    <option value="Previously competed">Previously competed, now fitness</option>
                    <option value="No competitive background">No competitive sports background</option>
                  </select>
                </label>
                <label>
                  Current activity level
                  <select name="planActivityLevel">
                    <option value="">Select option</option>
                    <option value="Mostly inactive (less than 1 session per week)">Mostly inactive (less than 1 session per week)</option>
                    <option value="Light (1-2 sessions per week)">Light (1-2 sessions per week)</option>
                    <option value="Moderate (3-4 sessions per week)">Moderate (3-4 sessions per week)</option>
                    <option value="Active (5-6 sessions per week)">Active (5-6 sessions per week)</option>
                    <option value="Highly active (6+ sessions per week)">Highly active (6+ sessions per week)</option>
                  </select>
                </label>
                <label>
                  How many sessions per week can your schedule allow?
                  <input type="number" name="planFrequency" min="1" max="7" placeholder="e.g. 3" />
                </label>
                <label>
                  Plan Duration
                  <select name="planDuration">
                    <option value="">Select duration</option>
                    <option value="6 weeks">6-Week Plan</option>
                    <option value="12 weeks">12-Week Plan</option>
                  </select>
                </label>
              </div>

              <label class="plan-equipment-label">
                Where will you train?
                <div class="plan-checkbox-group">
                  <label class="checkbox">
                    <input type="checkbox" name="planEquipment" value="Home - bodyweight only" />
                    <span>Home (bodyweight only)</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planEquipment" value="Home - with some equipment" />
                    <span>Home with basic equipment (dumbbells, bands, etc.)</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planEquipment" value="Gym access" />
                    <span>Gym access</span>
                  </label>
                </div>
              </label>

              <label>
                Lifestyle
                <select name="planLifestyle">
                  <option value="">Select option</option>
                  <option value="Office-based, sedentary">Office-based job, mostly sedentary</option>
                  <option value="Active job">Active job (standing, moving)</option>
                  <option value="Outdoor-focused">Outdoor-focused lifestyle</option>
                  <option value="Mix">Mix of sedentary and active</option>
                </select>
              </label>

              <label>
                What does a typical current week look like? (optional)
                <textarea name="currentWeek" rows="2" placeholder="e.g. work Mon-Fri 9-5, training Tue/Thu/Sat, kids on weekends"></textarea>
              </label>

              <label>
                Menstrual cycle status (optional)
                <select name="cycleStatus">
                  <option value="">Select if comfortable</option>
                  <option value="cycling_regularly">Cycling regularly</option>
                  <option value="hormonal_contraception">On hormonal contraception</option>
                  <option value="irregular_or_not_tracking">Irregular or not tracking</option>
                  <option value="pregnant_or_postpartum">Currently pregnant or postpartum</option>
                  <option value="perimenopausal">Perimenopausal or postmenopausal</option>
                  <option value="prefer_not_to_say">Prefer not to say</option>
                </select>
              </label>

              <label>
                Medical Conditions (if any)
                <textarea name="planMedical" rows="2" placeholder="e.g. asthma, diabetes, pcos, none"></textarea>
              </label>

              <label>
                Injuries or Limitations (if any)
                <textarea name="planInjuries" rows="2" placeholder="e.g. lower back, shoulder, none"></textarea>
              </label>

              <label class="plan-goals-label">
                What are your main goals? (select all that apply)
                <div class="plan-checkbox-group">
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Strength" />
                    <span>Build strength</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Muscle" />
                    <span>Build muscle</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Endurance" />
                    <span>Improve endurance</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Performance" />
                    <span>Sport/athletic performance</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Recovery" />
                    <span>Injury prevention & recovery</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="General fitness" />
                    <span>General fitness & health</span>
                  </label>
                </div>
              </label>

              <label class="consultation-full-width">
                Please provide specific details on what you are hoping to achieve
                <textarea name="goals" rows="4" required placeholder="Be as specific as possible about your goals and what success looks like for you"></textarea>
              </label>

              <label>
                Issues, Worries, or Specific Concerns
                <textarea name="planIssues" rows="2" placeholder="e.g. knee pain, recovery, cycle-aware, etc."></textarea>
              </label>

              <label>
                Are you also doing a Mind the Gael Mental Performance Plan? (optional)
                <textarea name="companionPlanSummary" rows="3" placeholder="If yes, paste the highlights or give a short summary (e.g. weekly themes, routines you are building, performance moments you are working on). Your physical plan will be built to reinforce it."></textarea>
              </label>

              <label>
                Anything else we should know? (optional)
                <textarea name="anythingElse" rows="2" placeholder="A catchall. Anything that didn't fit above, or anything you'd want Emily to know before building your plan"></textarea>
              </label>
            </div>

            <label class="consultation-consent">
              <input type="checkbox" name="consent" required />
              <span>I consent to being contacted about my consultation request.</span>
            </label>

            <button type="submit" class="consultation-submit">Submit Consultation Request</button>
          </form>
        </div>
      </div>

      <div class="consultation-modal-backdrop" id="mental-modal-backdrop" aria-hidden="true">
        <div class="consultation-modal" role="dialog" aria-modal="true" aria-labelledby="mental-modal-title">
          <button type="button" class="consultation-close" id="close-mental-modal" aria-label="Close mental performance form">✕</button>
          <h2 id="mental-modal-title">Mental Performance Plan Intake</h2>
          <p class="consultation-intro">Tell me about your sport, your competitive history, and the performance moments you want to work on. Your plan is built around what you share here.</p>

          <form id="mental-form" class="consultation-form">
            <div class="consultation-grid">
              <label>
                Full Name
                <input type="text" name="name" required />
              </label>
              <label>
                Email
                <input type="email" name="email" required />
              </label>
              <label>
                Phone (optional)
                <input type="tel" name="phone" />
              </label>
              <label>
                Sport / Team
                <input type="text" name="sport" required />
              </label>
            </div>

            <div class="progression-plan-fields">
              <h3>Your Competitive Background</h3>
              <p class="plan-fields-intro">A bit of context on where you are competing and how long you have been at it. This shapes the level your plan is pitched at.</p>

              <div class="plan-basic-fields">
                <label>
                  Competition Level
                  <select name="competitionLevel" required>
                    <option value="">Select level</option>
                    <option value="Recreational / Local club">Recreational / Local club</option>
                    <option value="Club">Club</option>
                    <option value="County / Regional">County / Regional</option>
                    <option value="Inter-county / National">Inter-county / National</option>
                    <option value="International">International</option>
                    <option value="Other">Other</option>
                  </select>
                </label>
                <label>
                  Years competing in your main sport
                  <select name="yearsCompeting">
                    <option value="">Select</option>
                    <option value="Less than 1 year">Less than 1 year</option>
                    <option value="1-3 years">1-3 years</option>
                    <option value="3-5 years">3-5 years</option>
                    <option value="5-10 years">5-10 years</option>
                    <option value="10+ years">10+ years</option>
                  </select>
                </label>
                <label>
                  Plan Duration
                  <select name="planDuration" required>
                    <option value="">Select duration</option>
                    <option value="6 weeks">6-Week Plan</option>
                    <option value="12 weeks">12-Week Plan</option>
                  </select>
                </label>
                <label>
                  Current confidence level (1-10)
                  <select name="confidenceLevel">
                    <option value="">Select</option>
                    <option value="1">1 - very low</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5 - middle</option>
                    <option value="6">6</option>
                    <option value="7">7</option>
                    <option value="8">8</option>
                    <option value="9">9</option>
                    <option value="10">10 - very high</option>
                  </select>
                </label>
              </div>

              <label class="plan-goals-label">
                Which performance moments do you want to work on? (select all that apply)
                <div class="plan-checkbox-group">
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Pre-game nerves" />
                    <span>Pre-game nerves and pressure</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Confidence" />
                    <span>Building and holding confidence</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Focus during play" />
                    <span>Focus and concentration during play</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Recovery from mistakes" />
                    <span>Recovering from mistakes mid-game</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Pre-performance routines" />
                    <span>Pre-performance routines</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Self-talk" />
                    <span>Self-talk under fatigue</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Visualisation" />
                    <span>Visualisation and imagery</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Motivation" />
                    <span>Motivation and goal setting</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Team and social pressure" />
                    <span>Team and social pressure</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="performanceMoments" value="Return from injury" />
                    <span>Mental return from injury</span>
                  </label>
                </div>
              </label>

              <label>
                Any current mental performance routines you already use? (optional)
                <textarea name="currentRoutines" rows="2" placeholder="e.g. breathing before warm-up, visualisation the night before, a phrase you say to yourself, journaling. Or none."></textarea>
              </label>

              <label>
                A peak moment you've had in your sport (optional)
                <textarea name="peakMoment" rows="3" placeholder="A moment you felt fully on top of things. What was happening, what did it feel like, what were you doing differently?"></textarea>
              </label>

              <label>
                A struggle moment you've had in your sport (optional)
                <textarea name="struggleMoment" rows="3" placeholder="A moment things felt off. What happened, what was running through your head, what would you want to change about that response?"></textarea>
              </label>

              <label class="consultation-full-width">
                What do you most want this plan to help you with?
                <textarea name="goals" rows="4" required placeholder="Be specific. What does success look like for you by the end of this plan?"></textarea>
              </label>

              <label>
                Are you also doing a Mind the Gael Physical Training Plan? (optional)
                <textarea name="companionPlanSummary" rows="3" placeholder="If yes, paste the highlights or give a short summary (e.g. session split, focus areas, weeks completed). Your mental plan will be built to apply directly to those training and match moments."></textarea>
              </label>

              <label>
                Anything else I should know? (optional)
                <textarea name="anythingElse" rows="2" placeholder="A catchall. Anything that didn't fit above."></textarea>
              </label>
            </div>

            <label class="consultation-consent">
              <input type="checkbox" name="consent" required />
              <span>I consent to being contacted about my mental performance plan.</span>
            </label>

            <button type="submit" class="consultation-submit">Submit Mental Performance Intake</button>
          </form>
        </div>
      </div>

      <div class="intake-loading-overlay" id="intake-loading-overlay" aria-hidden="true" role="status">
        <div class="intake-loading-card">
          <div class="intake-loading-spinner" aria-hidden="true"></div>
          <p class="intake-loading-title">Building your preview</p>
          <p class="intake-loading-status" id="intake-loading-status">Reading your details...</p>
          <p class="intake-loading-footnote">This usually takes a few seconds.</p>
        </div>
      </div>
    </main>
    <Footer />

    <script is:inline>
      // ── Shared intake-submit loading overlay ──
      // Both the mental and physical intake forms route through Anthropic
      // for a teaser. The wait is short (~2-3s on Haiku) but feels long if
      // the page looks frozen. The overlay rotates short status messages
      // so the wait feels intentional.
      const intakeLoadingOverlay = document.getElementById('intake-loading-overlay');
      const intakeLoadingStatus = document.getElementById('intake-loading-status');
      const INTAKE_LOADING_STEPS = [
        'Reading your details...',
        'Picking your weekly themes...',
        'Building your preview...',
        'Almost there...',
      ];
      let intakeLoadingTimer = null;

      const startIntakeLoading = () => {
        if (!intakeLoadingOverlay) return;
        intakeLoadingOverlay.classList.add('active');
        intakeLoadingOverlay.setAttribute('aria-hidden', 'false');
        let step = 0;
        if (intakeLoadingStatus) intakeLoadingStatus.textContent = INTAKE_LOADING_STEPS[0];
        intakeLoadingTimer = window.setInterval(() => {
          step = Math.min(step + 1, INTAKE_LOADING_STEPS.length - 1);
          if (intakeLoadingStatus) intakeLoadingStatus.textContent = INTAKE_LOADING_STEPS[step];
        }, 1800);
      };

      const stopIntakeLoading = () => {
        if (!intakeLoadingOverlay) return;
        intakeLoadingOverlay.classList.remove('active');
        intakeLoadingOverlay.setAttribute('aria-hidden', 'true');
        if (intakeLoadingTimer) {
          window.clearInterval(intakeLoadingTimer);
          intakeLoadingTimer = null;
        }
      };

      const openModalBtn = document.getElementById('open-consultation-modal');
      const closeModalBtn = document.getElementById('close-consultation-modal');
      const modalBackdrop = document.getElementById('consultation-modal-backdrop');
      const consultationForm = document.getElementById('consultation-form');

      const openModal = () => {
        if (!modalBackdrop) return;
        modalBackdrop.classList.add('active');
        modalBackdrop.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };

      const closeModal = () => {
        if (!modalBackdrop) return;
        modalBackdrop.classList.remove('active');
        modalBackdrop.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      if (openModalBtn) {
        openModalBtn.addEventListener('click', openModal);
      }

      if (closeModalBtn) {
        closeModalBtn.addEventListener('click', closeModal);
      }

      if (modalBackdrop) {
        modalBackdrop.addEventListener('click', (event) => {
          if (event.target === modalBackdrop) {
            closeModal();
          }
        });
      }

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeModal();
        }
      });

      if (consultationForm instanceof HTMLFormElement) {
        consultationForm.addEventListener('submit', async (event) => {
          event.preventDefault();

          const submitBtn = consultationForm.querySelector('.consultation-submit');
          const originalSubmitLabel = submitBtn ? submitBtn.textContent : '';
          if (submitBtn instanceof HTMLButtonElement) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Submitting...';
          }
          startIntakeLoading();

          const formData = new FormData(consultationForm);
          const name = String(formData.get('name') || '').trim();
          const email = String(formData.get('email') || '').trim();
          const phone = String(formData.get('phone') || '').trim();
          const sport = String(formData.get('sport') || '').trim();
          const goals = String(formData.get('goals') || '').trim();

          // Build request payload
          const requestData = {
            name,
            email,
            phone: phone || undefined,
            sport,
            goals,
            includeProgressionPlan: true,
          };

          // Add progression plan fields
          const planAge = String(formData.get('planAge') || '').trim();
          const planFrequency = String(formData.get('planFrequency') || '').trim();
          const planGoalsArray = [];
          
          // Get all planGoals checkboxes
          formData.getAll('planGoals').forEach(goal => {
            planGoalsArray.push(String(goal));
          });

          const equipmentArray = [];
          
          // Get all planEquipment checkboxes
          formData.getAll('planEquipment').forEach(equip => {
            equipmentArray.push(String(equip));
          });

          Object.assign(requestData, {
            age: planAge ? parseInt(planAge) : undefined,
            height: String(formData.get('planHeight') || '').trim() || undefined,
            weight: String(formData.get('planWeight') || '').trim() || undefined,
            exerciseLevel: String(formData.get('planExerciseLevel') || '').trim() || undefined,
            sportsOrNot: String(formData.get('planSportsOrNot') || '').trim() || undefined,
            equipment: equipmentArray,
            frequencyPerWeek: planFrequency ? parseInt(planFrequency) : undefined,
            planDuration: String(formData.get('planDuration') || '').trim() || undefined,
            planGoals: planGoalsArray,
            issuesWorries: String(formData.get('planIssues') || '').trim() || undefined,
            lifestyle: String(formData.get('planLifestyle') || '').trim() || undefined,
            medicalConditions: String(formData.get('planMedical') || '').trim() || undefined,
            injuries: String(formData.get('planInjuries') || '').trim() || undefined,
            programTrack: String(formData.get('programTrack') || '').trim() || undefined,
            cycleStatus: String(formData.get('cycleStatus') || '').trim() || undefined,
            currentWeek: String(formData.get('currentWeek') || '').trim() || undefined,
            anythingElse: String(formData.get('anythingElse') || '').trim() || undefined,
            currentActivityLevel: String(formData.get('planActivityLevel') || '').trim() || undefined,
            companionPlanSummary: String(formData.get('companionPlanSummary') || '').trim() || undefined,
          });

          // Submit to the new preview-then-buy endpoint. On success we redirect
          // the user to /programme-preview where they see a teaser and can buy.
          try {
            const response = await fetch('/api/programme-intake', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(requestData),
            });

            const result = await response.json().catch(() => ({}));
            if (!response.ok && result.reason !== 'red_flag') {
              throw new Error(result.message || 'Submission failed.');
            }

            if (result.success && result.previewToken) {
              closeModal();
              consultationForm.reset();
              window.location.href = '/programme-preview?token=' + encodeURIComponent(result.previewToken);
              return;
            }

            if (result.reason === 'red_flag' && result.message) {
              // Red-flag case: no preview, no purchase. Show Emily's support message.
              closeModal();
              consultationForm.reset();
              alert(result.message);
              return;
            }

            alert('Error: ' + (result.message || 'Something went wrong'));
          } catch (error) {
            console.error('Error:', error);
            const message = error instanceof Error
              ? error.message
              : 'Failed to submit your request. Please try again or contact me directly at emilyphelan@mindthegael.co.uk';
            alert(message);
          } finally {
            if (submitBtn instanceof HTMLButtonElement) {
              submitBtn.disabled = false;
              submitBtn.textContent = originalSubmitLabel || 'Submit Consultation Request';
            }
            stopIntakeLoading();
          }
        });
      }

      // ── Mental Performance Plan modal + form ──

      const openMentalBtn = document.getElementById('open-mental-modal');
      const closeMentalBtn = document.getElementById('close-mental-modal');
      const mentalBackdrop = document.getElementById('mental-modal-backdrop');
      const mentalForm = document.getElementById('mental-form');

      const openMental = () => {
        if (!mentalBackdrop) return;
        mentalBackdrop.classList.add('active');
        mentalBackdrop.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };

      const closeMental = () => {
        if (!mentalBackdrop) return;
        mentalBackdrop.classList.remove('active');
        mentalBackdrop.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      if (openMentalBtn) openMentalBtn.addEventListener('click', openMental);
      if (closeMentalBtn) closeMentalBtn.addEventListener('click', closeMental);
      if (mentalBackdrop) {
        mentalBackdrop.addEventListener('click', (event) => {
          if (event.target === mentalBackdrop) closeMental();
        });
      }
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeMental();
      });

      if (mentalForm instanceof HTMLFormElement) {
        mentalForm.addEventListener('submit', async (event) => {
          event.preventDefault();

          const submitBtn = mentalForm.querySelector('.consultation-submit');
          const originalSubmitLabel = submitBtn ? submitBtn.textContent : '';
          if (submitBtn instanceof HTMLButtonElement) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Submitting...';
          }
          startIntakeLoading();

          const formData = new FormData(mentalForm);

          const performanceMoments = [];
          formData.getAll('performanceMoments').forEach((m) => {
            performanceMoments.push(String(m));
          });

          const requestData = {
            planType: 'mental',
            name: String(formData.get('name') || '').trim(),
            email: String(formData.get('email') || '').trim(),
            phone: String(formData.get('phone') || '').trim() || undefined,
            sport: String(formData.get('sport') || '').trim(),
            goals: String(formData.get('goals') || '').trim(),
            includeProgressionPlan: true,
            planDuration: String(formData.get('planDuration') || '').trim() || undefined,
            competitionLevel: String(formData.get('competitionLevel') || '').trim() || undefined,
            yearsCompeting: String(formData.get('yearsCompeting') || '').trim() || undefined,
            confidenceLevel: String(formData.get('confidenceLevel') || '').trim() || undefined,
            performanceMomentsToWorkOn: performanceMoments,
            currentRoutines: String(formData.get('currentRoutines') || '').trim() || undefined,
            peakMoment: String(formData.get('peakMoment') || '').trim() || undefined,
            struggleMoment: String(formData.get('struggleMoment') || '').trim() || undefined,
            companionPlanSummary: String(formData.get('companionPlanSummary') || '').trim() || undefined,
            anythingElse: String(formData.get('anythingElse') || '').trim() || undefined,
          };

          try {
            const response = await fetch('/api/programme-intake', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(requestData),
            });

            const result = await response.json().catch(() => ({}));
            if (!response.ok && result.reason !== 'red_flag') {
              throw new Error(result.message || 'Submission failed.');
            }

            if (result.success && result.previewToken) {
              closeMental();
              mentalForm.reset();
              window.location.href = '/programme-preview?token=' + encodeURIComponent(result.previewToken);
              return;
            }

            if (result.reason === 'red_flag' && result.message) {
              closeMental();
              mentalForm.reset();
              alert(result.message);
              return;
            }

            alert('Error: ' + (result.message || 'Something went wrong'));
          } catch (error) {
            console.error('Error:', error);
            const message = error instanceof Error
              ? error.message
              : 'Failed to submit your request. Please try again or contact me directly at emilyphelan@mindthegael.co.uk';
            alert(message);
          } finally {
            if (submitBtn instanceof HTMLButtonElement) {
              submitBtn.disabled = false;
              submitBtn.textContent = originalSubmitLabel || 'Submit Mental Performance Intake';
            }
            stopIntakeLoading();
          }
        });
      }
    </script>
  </body>
</html>

