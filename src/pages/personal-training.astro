---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import saoirseImage from '../assets/saoirse.png';
import { SITE_TITLE } from '../consts';

const GOOGLE_CALENDAR_EMBED_URL =
  'https://calendar.google.com/calendar/appointments/schedules/AcZssZ36KoXqM3BjxB0kIH_OIVYVykacTIuW9-AJsezyfpalTSLO0YwC2h4FqPox3L4zBGQASYd-Ya4B?gv=true';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Personal Training | ${SITE_TITLE}`} description="Exercise-based personal training for female athletes, with a special focus on women's health." />
  </head>
  <body class="personal-training-page">
    <Header />
    <main class="container">
      <div class="coming-soon-strip">
        <Image src={saoirseImage} alt="Saoirse the shamrock" class="strip-shamrock" />
        <span>Personal Training launching shortly. Register your interest below!</span>
      </div>
      <h1>Personal Training</h1>
      <section class="intro">
        <div class="pt-band pt-band-intro">
          <div class="pt-band-inner">
            <p>Our personal training is exercise-based, with a special focus on women's health for female athletes. Performance and mental wellbeing can overlap with this work, but physical training support is the core focus.</p>
          </div>
        </div>

        <div class="pt-band pt-band-focus">
          <div class="pt-band-inner">
            <div class="training-highlight">
              <div class="training-highlight-copy">
                <h2>Train with Structure. Perform with Confidence.</h2>
                <p>
                  Every programme is designed to be practical and sustainable, with clear progression across strength, recovery, and performance demands.
                </p>
              </div>
              <div class="training-highlight-media">
                <img src="/assets/CiaraFlan-London-1.jpg" alt="Ciara Flanagan training in London" loading="lazy" />
              </div>
            </div>

            <div class="focus-areas">
              <div class="focus-card">
                <h3>Strength & Conditioning</h3>
                <p>Build physical capacity, movement quality, and resilience through structured S&C coaching.</p>
              </div>
              <div class="focus-card">
                <h3>Women's Health Focus</h3>
                <p>Training support tailored to female athletes, including cycle-aware planning and long-term athlete wellbeing.</p>
              </div>
              <div class="focus-card">
                <h3>Performance Integration</h3>
                <p>Translate gym work into better training and match-day performance with sport-specific application.</p>
              </div>
              <div class="focus-card">
                <h3>Recovery & Load Management</h3>
                <p>Plan training load, recovery, and progression so athletes can perform consistently and reduce burnout risk.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="pt-band pt-band-pricing">
          <div class="pt-band-inner">
            <h2 class="pricing-heading">Personal Training Pricing</h2>
            <div class="pricing-table-wrap">
              <table class="pricing-table">
                <caption>Personal Training Pricing</caption>
                <thead>
                  <tr>
                    <th>Option</th>
                    <th>Price</th>
                    <th>Includes</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Online 1:1 Sessions</td>
                    <td>£15</td>
                    <td>One 30-minute online personal training session.</td>
                  </tr>
                  <tr>
                    <td>4 Online 1:1 Personal Training Sessions (Bundle)</td>
                    <td>£50</td>
                    <td>Four 30-minute online personal training sessions at a discounted bundle rate.</td>
                  </tr>
                  <tr>
                    <td>In-Person 1:1 Sessions</td>
                    <td>£25</td>
                    <td>One 30-minute in-person personal training session.</td>
                  </tr>
                  <tr>
                    <td>4 In-Person 1:1 Personal Training Sessions (Bundle)</td>
                    <td>£80</td>
                    <td>Four 30-minute in-person personal training sessions at a discounted bundle rate.</td>
                  </tr>
                  <tr>
                    <td>Pre-Season Team Programme (6 Weeks)</td>
                    <td>Pilot from £850 | Standard £1250</td>
                    <td>Six-week S&C coaching for a team panel of 20-30 athletes. Pilot pricing is limited availability.</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="pt-band pt-band-booking">
          <div class="pt-band-inner">
            <section class="calendar-section" aria-labelledby="calendar-heading">
              <h2 id="calendar-heading" class="calendar-heading">Book a PT Session</h2>
              <p class="calendar-copy">
                Use the booking schedule below to choose a time that suits you. If you do not see a slot that works, or if you'd like to arrange a regular weekly time, please contact me directly at emilyphelan@mindthegael.co.uk.
              </p>
              <button type="button" class="consultation-btn" id="open-consultation-modal">Book Initial Consultation</button>
              <p class="consultation-note">The consultation form opens in a pop-up when you click the button above.</p>
              <div class="calendar-embed-wrap">
                <iframe
                  src={GOOGLE_CALENDAR_EMBED_URL}
                  title="Personal training appointment booking"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
              </div>
            </section>
          </div>
        </div>
      </section>

      <div class="consultation-modal-backdrop" id="consultation-modal-backdrop" aria-hidden="true">
        <div class="consultation-modal" role="dialog" aria-modal="true" aria-labelledby="consultation-modal-title">
          <button type="button" class="consultation-close" id="close-consultation-modal" aria-label="Close consultation form">✕</button>
          <h2 id="consultation-modal-title">Initial Consultation Form</h2>
          <p class="consultation-intro">Complete this form and click submit to send your consultation request directly.</p>

          <form id="consultation-form" class="consultation-form">
            <div class="consultation-grid">
              <label>
                Full Name
                <input type="text" name="name" required />
              </label>

              <label>
                Email
                <input type="email" name="email" required />
              </label>

              <label>
                Phone (optional)
                <input type="tel" name="phone" />
              </label>

              <label>
                Sport / Team
                <input type="text" name="sport" required />
              </label>

              <label>
                Preferred Contact Method
                <select name="contactMethod" required>
                  <option value="">Select one</option>
                  <option value="Email">Email</option>
                  <option value="Phone">Phone</option>
                  <option value="Instagram">Instagram</option>
                </select>
              </label>

              <label>
                Preferred Time to Talk
                <input type="text" name="preferredTime" placeholder="e.g. weekday evenings" />
              </label>
            </div>

            <div class="progression-plan-fields">
              <h3>Custom Progression Plan</h3>
              <p class="plan-fields-intro">Fill out your training details for a personalized plan (optional):</p>
              
              <div class="plan-basic-fields">
                <label>
                  Age
                  <input type="number" name="planAge" min="16" max="100" />
                </label>
                <label>
                  Height (e.g. 5'8 or 173cm)
                  <input type="text" name="planHeight" placeholder="e.g. 5'8 or 173cm" />
                </label>
                <label>
                  Weight (e.g. 65kg, 143lbs)
                  <input type="text" name="planWeight" placeholder="e.g. 65kg, 143lbs" />
                </label>
                <label>
                  Exercise Experience
                  <select name="planExerciseLevel">
                    <option value="">Select level</option>
                    <option value="Beginner (less than 1 year)">Beginner (less than 1 year)</option>
                    <option value="Intermediate (1-3 years)">Intermediate (1-3 years)</option>
                    <option value="Advanced (3+ years)">Advanced (3+ years)</option>
                  </select>
                </label>
                <label>
                  Sports Background
                  <select name="planSportsOrNot">
                    <option value="">Select option</option>
                    <option value="Currently competing">Currently competing in a sport</option>
                    <option value="Previously competed">Previously competed, now fitness</option>
                    <option value="No competitive background">No competitive sports background</option>
                  </select>
                </label>
                <label>
                  Training Frequency Per Week
                  <input type="number" name="planFrequency" min="1" max="7" />
                </label>
                <label>
                  Plan Duration
                  <select name="planDuration">
                    <option value="">Select duration</option>
                    <option value="6 weeks">6-Week Plan</option>
                    <option value="12 weeks">12-Week Plan</option>
                  </select>
                </label>
              </div>

              <label class="plan-equipment-label">
                Where will you train?
                <div class="plan-checkbox-group">
                  <label class="checkbox">
                    <input type="checkbox" name="planEquipment" value="Home - bodyweight only" />
                    <span>Home (bodyweight only)</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planEquipment" value="Home - with some equipment" />
                    <span>Home with basic equipment (dumbbells, bands, etc.)</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planEquipment" value="Gym access" />
                    <span>Gym access</span>
                  </label>
                </div>
              </label>

              <label>
                Lifestyle
                <select name="planLifestyle">
                  <option value="">Select option</option>
                  <option value="Office-based, sedentary">Office-based job, mostly sedentary</option>
                  <option value="Active job">Active job (standing, moving)</option>
                  <option value="Outdoor-focused">Outdoor-focused lifestyle</option>
                  <option value="Mix">Mix of sedentary and active</option>
                </select>
              </label>

              <label>
                Medical Conditions (if any)
                <textarea name="planMedical" rows="2" placeholder="e.g. asthma, diabetes, pcos, none"></textarea>
              </label>

              <label>
                Injuries or Limitations (if any)
                <textarea name="planInjuries" rows="2" placeholder="e.g. lower back, shoulder, none"></textarea>
              </label>

              <label class="plan-goals-label">
                What are your main goals? (select all that apply)
                <div class="plan-checkbox-group">
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Strength" />
                    <span>Build strength</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Muscle" />
                    <span>Build muscle</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Endurance" />
                    <span>Improve endurance</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Performance" />
                    <span>Sport/athletic performance</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="Recovery" />
                    <span>Injury prevention & recovery</span>
                  </label>
                  <label class="checkbox">
                    <input type="checkbox" name="planGoals" value="General fitness" />
                    <span>General fitness & health</span>
                  </label>
                </div>
              </label>

              <label class="consultation-full-width">
                Please provide specific details on what you are hoping to achieve
                <textarea name="goals" rows="4" required placeholder="Be as specific as possible about your goals and what success looks like for you"></textarea>
              </label>

              <label>
                Issues, Worries, or Specific Concerns
                <textarea name="planIssues" rows="2" placeholder="e.g. knee pain, recovery, cycle-aware, etc."></textarea>
              </label>
            </div>

            <label class="consultation-consent">
              <input type="checkbox" name="consent" required />
              <span>I consent to being contacted about my consultation request.</span>
            </label>

            <button type="submit" class="consultation-submit">Submit Consultation Request</button>
          </form>
        </div>
      </div>
    </main>
    <Footer />

    <script is:inline>
      const openModalBtn = document.getElementById('open-consultation-modal');
      const closeModalBtn = document.getElementById('close-consultation-modal');
      const modalBackdrop = document.getElementById('consultation-modal-backdrop');
      const consultationForm = document.getElementById('consultation-form');

      const openModal = () => {
        if (!modalBackdrop) return;
        modalBackdrop.classList.add('active');
        modalBackdrop.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };

      const closeModal = () => {
        if (!modalBackdrop) return;
        modalBackdrop.classList.remove('active');
        modalBackdrop.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      if (openModalBtn) {
        openModalBtn.addEventListener('click', openModal);
      }

      if (closeModalBtn) {
        closeModalBtn.addEventListener('click', closeModal);
      }

      if (modalBackdrop) {
        modalBackdrop.addEventListener('click', (event) => {
          if (event.target === modalBackdrop) {
            closeModal();
          }
        });
      }

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeModal();
        }
      });

      if (consultationForm instanceof HTMLFormElement) {
        consultationForm.addEventListener('submit', async (event) => {
          event.preventDefault();

          const submitBtn = consultationForm.querySelector('.consultation-submit');
          const originalSubmitLabel = submitBtn ? submitBtn.textContent : '';
          if (submitBtn instanceof HTMLButtonElement) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Submitting...';
          }

          const formData = new FormData(consultationForm);
          const name = String(formData.get('name') || '').trim();
          const email = String(formData.get('email') || '').trim();
          const phone = String(formData.get('phone') || '').trim();
          const sport = String(formData.get('sport') || '').trim();
          const contactMethod = String(formData.get('contactMethod') || '').trim();
          const preferredTime = String(formData.get('preferredTime') || '').trim();
          const goals = String(formData.get('goals') || '').trim();

          // Build request payload
          const requestData = {
            name,
            email,
            phone: phone || undefined,
            sport,
            contactMethod,
            preferredTime: preferredTime || undefined,
            goals,
            includeProgressionPlan: true,
          };

          // Add progression plan fields
          const planAge = String(formData.get('planAge') || '').trim();
          const planFrequency = String(formData.get('planFrequency') || '').trim();
          const planGoalsArray = [];
          
          // Get all planGoals checkboxes
          formData.getAll('planGoals').forEach(goal => {
            planGoalsArray.push(String(goal));
          });

          const equipmentArray = [];
          
          // Get all planEquipment checkboxes
          formData.getAll('planEquipment').forEach(equip => {
            equipmentArray.push(String(equip));
          });

          Object.assign(requestData, {
            age: planAge ? parseInt(planAge) : undefined,
            height: String(formData.get('planHeight') || '').trim() || undefined,
            weight: String(formData.get('planWeight') || '').trim() || undefined,
            exerciseLevel: String(formData.get('planExerciseLevel') || '').trim() || undefined,
            sportsOrNot: String(formData.get('planSportsOrNot') || '').trim() || undefined,
            equipment: equipmentArray,
            frequencyPerWeek: planFrequency ? parseInt(planFrequency) : undefined,
            planDuration: String(formData.get('planDuration') || '').trim() || undefined,
            planGoals: planGoalsArray,
            issuesWorries: String(formData.get('planIssues') || '').trim() || undefined,
            lifestyle: String(formData.get('planLifestyle') || '').trim() || undefined,
            medicalConditions: String(formData.get('planMedical') || '').trim() || undefined,
            injuries: String(formData.get('planInjuries') || '').trim() || undefined,
          });

          // Submit to API
          try {
            const response = await fetch('/api/training-plan', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(requestData),
            });

            const result = await response.json().catch(() => ({}));
            if (!response.ok) {
              throw new Error(result.error || 'Submission failed.');
            }
            
            if (result.success) {
              closeModal();
              consultationForm.reset();
              alert(result.message || 'Thank you! Your consultation request has been received.');
            } else {
              alert('Error: ' + (result.error || 'Something went wrong'));
            }
          } catch (error) {
            console.error('Error:', error);
            const message = error instanceof Error
              ? error.message
              : 'Failed to submit your request. Please try again or contact me directly at emilyphelan@mindthegael.co.uk';
            alert(message);
          } finally {
            if (submitBtn instanceof HTMLButtonElement) {
              submitBtn.disabled = false;
              submitBtn.textContent = originalSubmitLabel || 'Submit Consultation Request';
            }
          }
        });
      }
    </script>
  </body>
</html>

<style>
  .personal-training-page main.container {
    padding-top: 0;
    padding-bottom: 2rem;
  }

  .pt-band {
    margin: 0 calc(50% - 50vw);
    padding: 1.5rem max(1rem, calc(50vw - 600px));
  }

  .pt-band-intro {
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
  }

  .pt-band-focus {
    background: linear-gradient(180deg, rgba(240, 205, 255, 0.92) 0%, rgba(244, 255, 232, 0.9) 100%);
  }

  .pt-band-pricing {
    background: linear-gradient(180deg, rgba(105, 0, 90, 0.88) 0%, rgba(105, 0, 90, 0.72) 100%);
  }

  .pt-band-booking {
    background: linear-gradient(180deg, rgba(244, 255, 232, 0.9) 0%, rgba(240, 205, 255, 0.9) 100%);
  }

  .pt-band-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin: 1rem 0;
    padding: 0 0.2rem;
  }

  .intro p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .pt-band-focus p,
  .pt-band-focus .training-highlight-copy p,
  .pt-band-focus .focus-card p,
  .pt-band-booking p,
  .pt-band-booking .calendar-copy,
  .pt-band-booking .consultation-note {
    color: var(--green-dark);
  }

  .pricing-heading {
    margin: 0 0 0.9rem;
    color: var(--green-light);
  }

  .pricing-table-wrap {
    overflow-x: auto;
    margin-bottom: 0;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    background-color: rgba(244, 255, 232, 0.95);
    border: 1px solid rgba(244, 255, 232, 0.7);
    color: var(--green-dark);
  }

  .pricing-table caption {
    caption-side: top;
    text-align: left;
    color: rgba(244, 255, 232, 0.95);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .pricing-table th,
  .pricing-table td {
    padding: 0.85rem;
    text-align: left;
    border: 1px solid rgba(192, 254, 113, 0.35);
    vertical-align: middle;
  }

  .pricing-table th {
    background: rgba(192, 254, 113, 0.14);
    color: var(--purple);
    font-weight: 700;
  }

  .pricing-cta {
    display: inline-block;
    margin-top: 0.6rem;
    padding: 0.55rem 0.9rem;
    border-radius: 8px;
    background: var(--green-lime);
    color: var(--green-dark);
    font-weight: 700;
    border: 2px solid var(--green-lime);
    transition: transform 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .pricing-cta:hover {
    transform: translateY(-1px);
    border-color: var(--purple-light);
    color: var(--purple);
  }

  .calendar-section {
    margin: 0;
  }

  .calendar-heading {
    margin: 0 0 0.9rem;
    color: var(--green-lime);
  }

  .calendar-copy {
    margin: 0 0 1rem;
  }

  .consultation-note {
    margin: 0 0 1rem;
    font-size: 0.92rem;
    color: var(--green-dark);
  }

  .consultation-btn {
    display: inline-block;
    margin: 0 0 1rem;
    padding: 0.7rem 1.1rem;
    border-radius: 8px;
    border: 2px solid transparent;
    background: var(--green-lime);
    color: var(--green-dark);
    font-weight: 700;
    font: inherit;
    line-height: 1.2;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .consultation-btn:hover {
    background: var(--purple-light);
    border-color: var(--purple);
  }

  .calendar-embed-wrap {
    width: 100%;
    border: 1px solid rgba(192, 254, 113, 0.45);
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.14);
  }

  .calendar-embed-wrap iframe {
    width: 100%;
    height: 880px;
    border: 0;
    display: block;
    background: #fff;
  }

  .focus-areas {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 0;
  }

  .training-highlight {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 1rem;
    margin: 0 0 1.5rem;
    border: 0;
    border-radius: 0;
    overflow: hidden;
    background: transparent;
  }

  .training-highlight-copy {
    padding: 1.2rem 1rem;
  }

  .training-highlight-copy h2 {
    margin: 0 0 0.55rem;
    color: var(--purple);
    font-size: 1.4rem;
  }

  .training-highlight-copy p {
    margin: 0;
    color: var(--green-dark);
  }

  .training-highlight-media {
    min-height: 240px;
  }

  .training-highlight-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  @media (max-width: 768px) {
    .pt-band {
      padding: 1.1rem max(0.8rem, calc(50vw - 600px));
    }

    .waitlist-form {
      grid-template-columns: 1fr;
      max-width: 100%;
    }

    .training-highlight {
      grid-template-columns: 1fr;
    }

    .training-highlight-media {
      min-height: 190px;
      order: -1;
    }

    .focus-areas {
      grid-template-columns: 1fr;
    }

    .calendar-embed-wrap iframe {
      height: 760px;
    }
  }

  @media (max-width: 520px) {
    .calendar-embed-wrap {
      border-radius: 12px;
    }

    .calendar-embed-wrap iframe {
      height: 700px;
    }
  }

  .focus-card {
    padding: 1.2rem 0.2rem;
    background-color: transparent;
    border: 0;
    border-radius: 0;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .focus-card:hover {
    transform: none;
    border-color: transparent;
  }

  .focus-card h3 {
    color: var(--purple);
    font-size: 1.2rem;
    margin: 0 0 0.5rem 0;
  }

  .focus-card p {
    color: var(--green-dark);
  }

  .coming-soon-strip {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto 1.5rem;
    border-radius: 8px;
    background: #f0cdff;
    color: #69005a;
    border: 2px solid #69005a;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.65rem 1rem;
    font-weight: 700;
    font-size: 0.95rem;
    text-align: center;
  }

  .strip-shamrock {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .consultation-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    z-index: 3000;
  }

  .consultation-modal-backdrop.active {
    display: flex;
  }

  .consultation-modal {
    width: min(760px, 100%);
    max-height: 90vh;
    overflow-y: auto;
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    background: var(--green-dark);
    padding: 1.1rem;
    position: relative;
  }

  .consultation-close {
    position: absolute;
    top: 0.65rem;
    right: 0.65rem;
    width: 2rem;
    height: 2rem;
    border: 0;
