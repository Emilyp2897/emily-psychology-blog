---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Personal Training | ${SITE_TITLE}`} description="One-to-one personal training focused on mental wellbeing, performance coaching and women's health." />
  </head>
  <body>
    <Header />
    <main class="container">
      <h1>Personal Training</h1>
      <section class="intro">
        <div class="coming-soon">
          <img src="/assets/saoirse.png" alt="Shamrock" class="coming-soon-img" />
          <span class="coming-soon-text">Coming Soon</span>
        </div>
        <p>Our personal training programmes will be focused on four key areas:</p>
        <div class="focus-areas">
          <div class="focus-card">
            <h3>🧠 Mental Wellbeing</h3>
            <p>Building resilience, managing stress and developing a healthier mindset through tailored one-to-one sessions.</p>
          </div>
          <div class="focus-card">
            <h3>🏆 Performance Coaching</h3>
            <p>Unlock your potential with evidence-based strategies to enhance focus, motivation and peak performance.</p>
          </div>
          <div class="focus-card">
            <h3>💜 Women's Health</h3>
            <p>Specialist support addressing the unique psychological and physical wellbeing needs of women at every stage of life.</p>
          </div>
          <div class="focus-card">
            <h3>💪 Exercise</h3>
            <p>Personalised exercise programmes designed to complement your mental and physical health goals.</p>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .intro p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .focus-areas {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 768px) {
    .focus-areas {
      grid-template-columns: 1fr;
    }
  }

  .focus-card {
    padding: 1.5rem;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .focus-card:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .focus-card h3 {
    color: var(--green-lime);
    font-size: 1.2rem;
    margin: 0 0 0.5rem 0;
  }

  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem 0;
  }

  .coming-soon-img {
    width: 80px;
    height: 80px;
    opacity: 0.8;
  }

  .coming-soon-text {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--green-lime);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .focus-areas {
      grid-template-columns: 1fr;
    }
  }
</style>