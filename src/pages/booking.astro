---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Booking System | ${SITE_TITLE}`} description="Book online 1:1, in-person 1:1, or pre-season team sessions." />
  </head>
  <body>
    <Header />
    <main class="container">
      <section class="booking-panel">
        <h1>Booking System</h1>
        <p>Choose your session details below and send your booking request.</p>

        <form id="booking-form" class="booking-form">
          <label>
            Session Type
            <select id="service" name="service" required>
              <option value="online-1-1">Online 1:1 Sessions</option>
              <option value="in-person-1-1">In-Person 1:1 Sessions</option>
              <option value="pre-season-team">Pre-Season Team Sessions</option>
            </select>
          </label>

          <label>
            Full Name
            <input type="text" id="name" name="name" required />
          </label>

          <label>
            Email
            <input type="email" id="email" name="email" required />
          </label>

          <label>
            Preferred Date
            <input type="date" id="date" name="date" required />
          </label>

          <label>
            Preferred Time
            <input type="time" id="time" name="time" required />
          </label>

          <label>
            Notes
            <textarea id="notes" name="notes" rows="4" placeholder="Anything you'd like us to know before your session?"></textarea>
          </label>

          <button type="submit">Send Booking Request</button>
        </form>
      </section>
    </main>
    <Footer />

    <script is:inline>
      const serviceLabels = {
        "online-1-1": "Online 1:1 Sessions",
        "in-person-1-1": "In-Person 1:1 Sessions",
        "pre-season-team": "Pre-Season Team Sessions",
      };

      const params = new URLSearchParams(window.location.search);
      const serviceParam = params.get("service");
      const serviceSelect = document.getElementById("service");
      if (serviceParam && serviceLabels[serviceParam] && serviceSelect) {
        serviceSelect.value = serviceParam;
      }

      const form = document.getElementById("booking-form");
      form.addEventListener("submit", (event) => {
        event.preventDefault();

        const service = document.getElementById("service").value;
        const name = document.getElementById("name").value;
        const email = document.getElementById("email").value;
        const date = document.getElementById("date").value;
        const time = document.getElementById("time").value;
        const notes = document.getElementById("notes").value;

        const subject = `Booking Request - ${serviceLabels[service]}`;
        const body = [
          `Session Type: ${serviceLabels[service]}`,
          `Name: ${name}`,
          `Email: ${email}`,
          `Preferred Date: ${date}`,
          `Preferred Time: ${time}`,
          `Notes: ${notes || "N/A"}`,
        ].join("\n");

        window.location.href = `mailto:emilyphelan@mindthegael.co.uk?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      });
    </script>
  </body>
</html>

<style>
  .booking-panel {
    max-width: 760px;
    margin: 2rem auto 4rem;
    padding: 1.5rem;
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    background: rgba(240, 205, 255, 0.08);
  }

  .booking-panel h1 {
    margin-bottom: 0.5rem;
  }

  .booking-form {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .booking-form label {
    display: grid;
    gap: 0.35rem;
    color: var(--green-light);
    font-weight: 600;
  }

  .booking-form input,
  .booking-form select,
  .booking-form textarea {
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 0.65rem;
    font: inherit;
    background: #101010;
    color: var(--green-light);
  }

  .booking-form button {
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font: inherit;
    font-weight: 700;
    background: var(--green-lime);
    color: var(--green-dark);
    cursor: pointer;
  }
  
  .booking-form button:hover {
    color: var(--purple);
    border-color: var(--purple-light);
  }
</style>