---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="resources-page">
    <Header />
    <main class="container resources-main">
      <h1>Support Resources</h1>
      <p class="resources-intro">You are not alone. Someone is always there to listen.</p>
      <p class="resources-emergency">If you or someone you know is at immediate risk of harm, go to or call the emergency department of your local general hospital. You can also contact emergency services on 112 or 999.</p>

      <section class="resources-table-block">
        <h2>UK</h2>
        <div class="table-wrap">
          <table class="resources-table">
            <thead>
              <tr>
                <th>Logo</th>
                <th>Organisation</th>
                <th>Support</th>
                <th>Phone</th>
                <th>Website</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><img src="/assets/Mind_Charity_Logo_2021.png" alt="Mind logo" class="resource-logo-cell resource-logo-mind" /></td>
                <td>Mind</td>
                <td>Mental health information and support</td>
                <td><a href="tel:03001233393">0300 123 3393</a></td>
                <td><a href="https://www.mind.org.uk" target="_blank" rel="noopener noreferrer">mind.org.uk</a></td>
              </tr>
              <tr>
                <td><img src="/assets/Samaritans.png.webp" alt="Samaritans logo" class="resource-logo-cell" /></td>
                <td>Samaritans</td>
                <td>24/7 emotional support</td>
                <td><a href="tel:116123">116 123</a></td>
                <td><a href="https://www.samaritans.org" target="_blank" rel="noopener noreferrer">samaritans.org</a></td>
              </tr>
              <tr>
                <td><img src="/assets/nhs.png" alt="NHS logo" class="resource-logo-cell" /></td>
                <td>NHS</td>
                <td>Mental health services and urgent care guidance</td>
                <td><a href="tel:111">111</a></td>
                <td><a href="https://www.nhs.uk/mental-health" target="_blank" rel="noopener noreferrer">nhs.uk/mental-health</a></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="resources-table-block">
        <h2>Ireland</h2>
        <div class="table-wrap">
          <table class="resources-table">
            <thead>
              <tr>
                <th>Logo</th>
                <th>Organisation</th>
                <th>Support</th>
                <th>Phone</th>
                <th>Website</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><img src="/assets/Pieta_Logo_Rev_RGB_1_1.png.webp" alt="Pieta logo" class="resource-logo-cell" /></td>
                <td>Pieta</td>
                <td>Suicide and self-harm crisis support</td>
                <td><a href="tel:1800247247">1800 247 247</a></td>
                <td><a href="https://www.pieta.ie" target="_blank" rel="noopener noreferrer">pieta.ie</a></td>
              </tr>
              <tr>
                <td><img src="/assets/Samaritans.png.webp" alt="Samaritans logo" class="resource-logo-cell" /></td>
                <td>Samaritans Ireland</td>
                <td>24/7 emotional support</td>
                <td><a href="tel:116123">116 123</a></td>
                <td><a href="https://www.samaritans.org/ireland" target="_blank" rel="noopener noreferrer">samaritans.org/ireland</a></td>
              </tr>
              <tr>
                <td><img src="/assets/HSE-partner-logos-21.png" alt="HSE logo" class="resource-logo-cell" /></td>
                <td>HSE Mental Health</td>
                <td>Public mental health services and guidance (including YourMentalHealth.ie)</td>
                <td><a href="tel:1800111888">1800 111 888</a></td>
                <td><a href="https://www2.hse.ie/mental-health" target="_blank" rel="noopener noreferrer">hse.ie/mental-health</a><br /><a href="https://www.yourmentalhealth.ie" target="_blank" rel="noopener noreferrer">yourmentalhealth.ie</a></td>
              </tr>
              <tr>
                <td>—</td>
                <td>MyMind</td>
                <td>Accessible counselling and psychotherapy services</td>
                <td>—</td>
                <td><a href="https://mymind.org" target="_blank" rel="noopener noreferrer">mymind.org</a></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  .resources-page {
    position: relative;
  }

  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  .resources-main {
    position: relative;
    z-index: 1;
    padding-top: 1.75rem;
    padding-bottom: 3rem;
  }

  .resources-table-block {
    margin-top: 1.5rem;
  }

  .resources-intro {
    margin: 0.25rem 0 1.25rem;
    color: var(--green-light);
    font-size: 1.1rem;
  }

  .resources-emergency {
    margin: 0 0 1.25rem;
    color: var(--purple-light);
    font-weight: 600;
  }

  h2 {
    color: var(--green-lime);
    font-size: 1.4rem;
    margin: 0 0 0.75rem;
  }

  .table-wrap {
    overflow-x: auto;
  }

  .resources-table {
    width: 100%;
    border-collapse: collapse;
    border: 2px solid var(--green-lime);
    background: rgba(240, 205, 255, 0.08);
  }

  .resources-table th,
  .resources-table td {
    border: 1px solid rgba(192, 254, 113, 0.35);
    padding: 0.8rem;
    text-align: left;
    vertical-align: top;
  }

  .resources-table th {
    color: var(--green-lime);
    background: rgba(192, 254, 113, 0.14);
    font-weight: 700;
  }

  .resources-table a {
    color: var(--green-lime);
    text-decoration: underline;
  }

  .resources-table a:hover {
    color: var(--purple-light);
  }

  .resource-logo-cell {
    width: 72px;
    height: 72px;
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }

  .resource-logo-mind {
    width: 84px;
    height: 84px;
  }

  @media (max-width: 720px) {
    .resources-table th,
    .resources-table td {
      font-size: 0.95rem;
    }
  }
</style>
