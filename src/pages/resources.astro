---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container" style="padding-top:0;margin-top:0;">

      <section class="resources-bubbles" style="margin-top: 0;">
        <div style="display: flex; flex-direction: column; gap: 2em;">
          <div class="resource-bubble">
            <button type="button" aria-label="Mind Charity">
              <span class="bubble-icon" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <img src="/assets/Mind_Charity_Logo_2021.png" alt="Mind Charity Logo" style="width: 120px; height: 120px; object-fit: contain; margin-bottom: 0.3em;" />
              </span>
              <span class="bubble-label">Mind Charity</span>
            </button>
          </div>
          <div class="resource-bubble">
            <button type="button" aria-label="Pieta House">
              <span class="bubble-icon" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <img src="/assets/Pieta_Logo_Rev_RGB_1_1.png.webp" alt="Pieta House Logo" style="width: 110px; height: 110px; object-fit: contain; margin-bottom: 0.3em;" />
              </span>
              <span class="bubble-label">Pieta House</span>
            </button>
          </div>
        </div>
        <div class="resource-bubble">
          <button type="button" aria-label="Samaritans">
            <span class="bubble-icon" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
              <img src="/assets/Samaritans.png.webp" alt="Samaritans Logo" style="width: 110px; height: 110px; object-fit: contain; margin-bottom: 0.3em;" />
            </span>
            <span class="bubble-label">Samaritans</span>
          </button>
        </div>
        <div class="resource-bubble">
          <button type="button" aria-label="NHS">
            <span class="bubble-icon" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
              <img src="/assets/nhs.png" alt="NHS Logo" style="width: 110px; height: 110px; object-fit: contain; margin-bottom: 0.3em;" />
            </span>
            <span class="bubble-label">NHS</span>
          </button>
        </div>
        <div class="resource-bubble">
          <button type="button" aria-label="HSE">
            <span class="bubble-icon" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
              <img src="/assets/HSE-partner-logos-21.png" alt="HSE Logo" style="width: 110px; height: 110px; object-fit: contain; margin-bottom: 0.3em;" />
            </span>
            <span class="bubble-label">HSE</span>
          </button>
        </div>

      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  h2 {
    color: var(--green-lime);
    font-size: 1.5rem;
    margin-top: 2rem;
  }

  .tagline {
    color: #f0cdff;
    font-size: 1.2rem;
    font-style: italic;
    margin-bottom: 2rem;
  }


  .resources-bubbles {
    display: flex;
    flex-wrap: nowrap;
    justify-content: space-between;
    align-items: flex-start;
    gap: 4rem;
    margin: 2.5rem 0 0 0 !important;
    padding-top: 0 !important;
    position: relative;
  }
  .resource-bubble {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1 1 220px;
    min-width: 200px;
    max-width: 260px;
    margin-bottom: 0.5rem;
    margin-top: 0 !important;
  }

  .resource-bubble button {
    background: var(--green-dark);
    border: 2px solid var(--green-lime);
    border-radius: 50%;
    width: var(--bubble-size, 180px);
    height: var(--bubble-size, 180px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    box-shadow: 0 2px 16px rgba(0,0,0,0.13);
    position: relative;
    outline: none;
    font-size: 2.5rem;
  }
  .resource-bubble button:hover,
  .resource-bubble button:focus {
    border-color: var(--purple-light);
    box-shadow: 0 8px 32px rgba(105,0,90,0.18);
    transform: scale(1.07) rotate(-2deg);
    z-index: 2;
  }
  .resource-bubble button:hover,
  .resource-bubble button:focus {
    border-color: var(--purple-light);
    box-shadow: 0 4px 16px rgba(105,0,90,0.12);
  }
  .bubble-icon {
    font-size: 3.5rem;
    color: var(--green-lime);
    pointer-events: none;
    user-select: none;
  }
  .bubble-label {
    position: absolute;
    left: 50%;
    bottom: -2.7rem;
    transform: translateX(-50%) scale(0.95);
    background: var(--purple);
    color: #fff;
    padding: 0.6em 1.6em;
    border-radius: 1.5em;
    font-size: 1.25rem;
    font-weight: 700;
    opacity: 0;
    pointer-events: none;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0,0,0,0.13);
    transition: opacity 0.2s, transform 0.2s;
    z-index: 2;
  }
  .resource-bubble button:hover .bubble-label,
  .resource-bubble button:focus .bubble-label {
    opacity: 1;
    transform: translateX(-50%) scale(1);
    pointer-events: auto;
  }

  .closing {
    color: #f0cdff;
    font-style: italic;
    font-size: 1.05rem;
  }
</style>
