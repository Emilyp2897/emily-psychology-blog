---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Sign Up | ${SITE_TITLE}`} description="Create your Mind the Gael account." />
  </head>
  <body>
    <Header />
    <main class="container">
      <div class="auth-wrap">
        <h1>Create Account</h1>
        <p class="auth-intro">Sign up to access your performance plan.</p>

        <form id="signup-form" class="auth-form">
          <label>
            Full Name
            <input type="text" name="name" required />
          </label>
          <label>
            Email
            <input type="email" name="email" required />
          </label>
          <label>
            Password
            <input type="password" name="password" required />
          </label>
          <label>
            Confirm Password
            <input type="password" name="confirm_password" required />
          </label>
          <p class="auth-error" id="signup-error"></p>
          <button type="submit" class="auth-btn">Create Account</button>
        </form>

        <p class="auth-switch">Already have an account? <a href="/login">Log in</a></p>
      </div>
    </main>
    <Footer />

    <script>
      import { supabase } from '../lib/supabase.js';

      const form = document.getElementById('signup-form');
      const errorEl = document.getElementById('signup-error');

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form as HTMLFormElement);
        const name = formData.get('name') as string;
        const email = formData.get('email') as string;
        const password = formData.get('password') as string;
        const confirmPassword = formData.get('confirm_password') as string;

        if (password !== confirmPassword) {
          errorEl!.textContent = 'Passwords do not match.';
          return;
        }

        if (password.length < 8) {
          errorEl!.textContent = 'Password must be at least 8 characters.';
          return;
        }

        const { error } = await supabase.auth.signUp({
          email,
          password,
          options: {
            data: { full_name: name }
          }
        });

        if (error) {
          errorEl!.textContent = error.message;
        } else {
          window.location.href = '/dashboard';
        }
      });
    </script>

    <style>
      .auth-wrap {
        max-width: 440px;
        margin: 4rem auto;
      }

      .auth-intro {
        color: var(--green-light);
        margin-bottom: 2rem;
      }

      .auth-form {
        display: grid;
        gap: 1rem;
      }

      .auth-form label {
        display: grid;
        gap: 0.4rem;
        color: var(--green-light);
        font-weight: 600;
      }

      .auth-form input {
        padding: 0.7rem;
        border-radius: 8px;
        border: 1px solid rgba(192, 254, 113, 0.3);
        background: rgba(255, 255, 255, 0.92);
        color: #121212;
        font: inherit;
      }

      .auth-btn {
        padding: 0.75rem 1.25rem;
        background: var(--green-lime);
        color: var(--green-dark);
        font-weight: 700;
        font: inherit;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        margin-top: 0.5rem;
      }

      .auth-error {
        color: #ff6b6b;
        font-size: 0.9rem;
        min-height: 1.2em;
        margin: 0;
      }

      .auth-switch {
        margin-top: 1.5rem;
        color: var(--green-light);
        font-size: 0.95rem;
      }

      .auth-switch a {
        color: var(--green-lime) !important;
      }
    </style>
  </body>
</html>