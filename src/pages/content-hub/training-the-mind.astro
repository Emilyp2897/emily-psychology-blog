---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const allPosts = await getCollection('blog');

// Scheduled-release helper. Posts with a pubDate in the future render as
// locked cards (blurred preview, release date shown, no link) until the
// release date passes. Computed at request time so the lock lifts
// automatically without a redeploy.
const today = new Date();
today.setHours(0, 0, 0, 0);

const isUnreleased = (date: Date) => date > today;

const releaseDateLabel = (date: Date) =>
  date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

type MonthEntry = {
  month: string;
  theme: string;
  slugs: string[];
};

const monthlySeries: MonthEntry[] = [
  {
    month: 'Month 1',
    theme: 'Pressure & Performance Anxiety',
    slugs: [
      'training-the-mind/attention-control-theory',
      'training-the-mind/how-pressure-shows-in-ladies-football',
      'training-the-mind/choking-under-pressure',
    ],
  },
  {
    month: 'Month 2',
    theme: 'Confidence & Self-Talk',
    slugs: [
      'training-the-mind/understanding-confidence',
      'training-the-mind/applying-confidence-in-lgfa',
    ],
  },
  {
    month: 'Month 3',
    theme: 'Mistakes, Perfectionism & Shame',
    slugs: [
      'training-the-mind/understanding-mistakes-and-perfectionism',
      'training-the-mind/applying-mistake-resilience-in-lgfa',
    ],
  },
  {
    month: 'Month 4',
    theme: 'Team Culture, Belonging & Communication',
    slugs: [
      'training-the-mind/understanding-team-culture-and-belonging',
      'training-the-mind/applying-team-culture-in-lgfa',
    ],
  },
  {
    month: 'Month 5',
    theme: 'Motivation, Discipline & Burnout Risk',
    slugs: [
      'training-the-mind/understanding-motivation',
      'training-the-mind/applying-motivation-and-discipline-in-lgfa',
    ],
  },
  {
    month: 'Month 6',
    theme: 'Injury Psychology & Comeback Confidence',
    slugs: [
      'training-the-mind/understanding-identity-and-fear-after-injury',
      'training-the-mind/applying-comeback-confidence-in-lgfa',
    ],
  },
  {
    month: 'Month 7',
    theme: 'Flow, Focus & Playing Free',
    slugs: [
      'training-the-mind/understanding-flow-and-focus',
      'training-the-mind/applying-flow-and-focus-in-lgfa',
    ],
  },
  {
    month: 'Month 8',
    theme: 'Body Image, RED-S & Food Culture',
    slugs: [
      'training-the-mind/understanding-body-image-in-sport',
      'training-the-mind/applying-body-confidence-and-fuelling-in-lgfa',
    ],
  },
  {
    month: 'Month 9',
    theme: 'Boundaries, Coaches & People-Pleasing',
    slugs: [
      'training-the-mind/understanding-why-women-athletes-over-accommodate',
      'training-the-mind/applying-boundaries-in-lgfa',
    ],
  },
  {
    month: 'Month 10',
    theme: 'Championship Pressure & Fear of Failure',
    slugs: [
      'training-the-mind/understanding-pressure-and-fear-of-failure',
      'training-the-mind/applying-championship-pressure-in-lgfa',
    ],
  },
  {
    month: 'Month 11',
    theme: 'Identity Beyond Sport & Balance',
    slugs: [
      'training-the-mind/understanding-athletic-identity',
      'training-the-mind/applying-balanced-identity-in-lgfa',
    ],
  },
  {
    month: 'Month 12',
    theme: 'Off-Season Mental Health & Reset',
    slugs: [
      'training-the-mind/understanding-off-season-mental-health',
      'training-the-mind/applying-off-season-recovery-in-lgfa',
    ],
  },
];

function postFor(slug: string) {
  return allPosts.find((post) => post.slug === slug);
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Training the Mind | ${SITE_TITLE}`} description="A 12-month journey through the mental side of sport, built for female athletes." />
  </head>
  <body class="ttm-page">
    <Header />
    <main class="container ttm-main">
      <section class="hero">
        <p class="hero-kicker">Content Hub Series</p>
        <h1>Training the Mind</h1>
        <p class="hero-tagline">A 12-month journey through the mental side of sport, built for female athletes. Two posts per month, with a companion toolkit over in the Gael Performance Toolkit.</p>
      </section>

      <section class="ttm-series" aria-label="Monthly blog posts">
        <h2>The 12-Month Series</h2>
        <p class="series-intro">Each month focuses on a different theme. Understanding the theory, then applying it in real Gaelic football situations.</p>

        {monthlySeries.map((entry) => (
          <div class="month-group">
            <h3 class="month-heading">{entry.month}: {entry.theme}</h3>
            <ul class="month-list">
              {entry.slugs.map((slug) => {
                const post = postFor(slug);
                if (!post) {
                  return (
                    <li class="ttm-card ttm-card-missing">
                      <span class="ttm-status">Coming soon</span>
                      <h4 class="ttm-title">{slug.split('/').pop()?.replace(/-/g, ' ')}</h4>
                    </li>
                  );
                }
                if (isUnreleased(post.data.pubDate)) {
                  return (
                    <li class="ttm-card ttm-card-locked" aria-disabled="true">
                      <span class="ttm-lock-badge">🔒 Releases {releaseDateLabel(post.data.pubDate)}</span>
                      <h4 class="ttm-title">{post.data.title}</h4>
                      {post.data.description && (
                        <p class="ttm-description ttm-description-blur">{post.data.description}</p>
                      )}
                    </li>
                  );
                }
                return (
                  <li class="ttm-card">
                    <a href={`/content-hub/${post.slug}/`}>
                      <h4 class="ttm-title">{post.data.title}</h4>
                      {post.data.description && (
                        <p class="ttm-description">{post.data.description}</p>
                      )}
                      <span class="ttm-cta">Read post →</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </section>

      <section class="content-feedback-cta" aria-label="Content feedback">
        <p>Got feedback on this content?</p>
        <a href="/content-feedback" class="feedback-cta-link">Share feedback</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .ttm-main {
    padding-top: 0;
    padding-bottom: 3rem;
  }

  .hero {
    margin: 0 calc(50% - 50vw) 0.8rem;
    padding: 2rem max(1rem, calc(50vw - 600px + 1rem));
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
  }

  .hero-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
    color: var(--purple-light);
    font-weight: 700;
  }

  .hero h1 {
    margin: 0.2rem 0 0;
    color: var(--green-lime);
  }

  .hero-tagline {
    margin: 0.35rem 0 0;
    color: var(--green-light);
    max-width: 64ch;
  }

  .ttm-series {
    margin-top: 0.4rem;
    margin-bottom: 1.6rem;
  }

  .ttm-series h2 {
    color: var(--purple-light);
    margin: 0 0 0.25rem;
  }

  .series-intro {
    margin: 0 0 0.4rem;
    color: var(--green-light);
    max-width: 60ch;
    font-size: 0.95rem;
  }

  .month-group {
    margin-top: 1rem;
  }

  .month-heading {
    color: var(--purple-light);
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .month-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  /* White cards with dark titles. */
  .ttm-card {
    border: 2px solid rgba(105, 0, 90, 0.18);
    border-radius: 12px;
    padding: 1rem 1.1rem 1.1rem;
    background: #ffffff;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .ttm-card:hover {
    transform: translateY(-3px);
    border-color: var(--purple);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
  }

  .ttm-card a {
    display: block;
    text-decoration: none !important;
    color: inherit !important;
  }

  .ttm-status {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: var(--purple);
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.45rem;
  }

  .ttm-title {
    color: var(--green-dark) !important;
    font-size: 1.05rem;
    margin: 0 0 0.4rem;
    line-height: 1.35;
    font-weight: 700;
  }

  .ttm-description {
    color: var(--green-dark);
    font-size: 0.92rem;
    margin: 0 0 0.7rem;
    line-height: 1.5;
    opacity: 0.82;
  }

  .ttm-cta {
    color: var(--purple);
    font-weight: 700;
    font-size: 0.85rem;
  }

  .ttm-card-missing {
    opacity: 0.65;
    background: #f7f5f8;
  }

  /* Scheduled-release lock: post pubDate is in the future. Card is shown
     in muted form with a release-date badge; description is blurred so
     users can see something is there but cannot read it yet. */
  .ttm-card-locked {
    position: relative;
    background: rgba(244, 255, 232, 0.55);
    border-color: rgba(105, 0, 90, 0.18);
    cursor: not-allowed;
  }

  .ttm-card-locked .ttm-title {
    color: var(--purple);
    opacity: 0.72;
  }

  .ttm-description-blur {
    filter: blur(4px);
    user-select: none;
    pointer-events: none;
    opacity: 0.7;
  }

  .ttm-lock-badge {
    display: inline-block;
    margin-bottom: 0.45rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: var(--purple);
    color: var(--green-light);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .content-feedback-cta {
    margin: 1.4rem 0 0;
    text-align: center;
  }

  .content-feedback-cta p {
    margin: 0 0 0.55rem;
    color: var(--green-light);
  }

  .feedback-cta-link {
    display: inline-block;
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 0.5rem 0.9rem;
    background: var(--green-lime);
    color: var(--green-dark) !important;
    font-weight: 700;
    text-decoration: none !important;
  }

  .feedback-cta-link:hover {
    border-color: var(--purple-light);
    background: var(--purple-light);
  }
</style>
