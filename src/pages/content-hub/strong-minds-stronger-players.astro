---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const allPosts = await getCollection('blog');

const childPosts = allPosts.filter(
  (post) => post.slug.startsWith('strong-minds-stronger-players/') && post.slug !== 'strong-minds-stronger-players/strong-minds-stronger-players'
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={`Strong Minds, Stronger Players | ${SITE_TITLE}`} description="Understand mental health, recognising what to look out for, when pressure becomes something more serious, and how to seek the right support when you need it." />
  </head>
  <body class="strong-minds-page">
    <Header />
    <main class="container strong-minds-main">
      <section class="hero">
        <p class="hero-kicker">Content Hub Series</p>
        <h1>Strong Minds, Stronger Players</h1>
        <p class="hero-tagline">Understanding mental health in sport, spotting warning signs early, and knowing where to seek support.</p>
      </section>

      <div class="intro-card">
        <p>Each post helps you build awareness of mental health in sport, so you can recognise changes early, understand what they might mean, and know when to seek the right support.</p>
      </div>

      <div class="smsp-coming-soon-banner" role="note">
        <p class="smsp-cs-eyebrow">Coming soon</p>
        <p class="smsp-cs-body"><strong>Strong Minds, Stronger Players is launching soon.</strong> Always free for every player and coach. We are finalising the content with our expert panel before opening it up.</p>
      </div>

      <section class="latest-blog-box">
        <ul id="posts-list" class="latest-posts">
          {childPosts.length > 0 ? childPosts.map((post) => (
            <li class="smsp-card smsp-card-locked" aria-disabled="true">
              <span class="smsp-lock-badge">🔒 Coming soon</span>
              <h2 class="title">{post.data.title}</h2>
              {post.data.description && (
                <p class="description smsp-description-blur">{post.data.description}</p>
              )}
            </li>
          )) : (
            <li class="coming-soon">
              <p>Posts coming soon. Check back shortly.</p>
            </li>
          )}
        </ul>
      </section>

      <section class="content-feedback-cta">
        <p>Got feedback on this content?</p>
        <a href="/content-feedback" class="feedback-cta-link">Share Feedback</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .strong-minds-main {
    padding-top: 0;
    padding-bottom: 3rem;
  }

  .hero {
    margin: 0 calc(50% - 50vw) 1.1rem;
    padding: 2rem max(1rem, calc(50vw - 600px + 1rem));
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
  }

  .hero-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
    color: var(--purple-light);
    font-weight: 700;
  }

  .hero h1 {
    margin: 0.2rem 0 0;
    color: var(--green-lime);
  }

  .hero-tagline {
    margin: 0.35rem 0 0;
    color: var(--green-light);
    max-width: 64ch;
  }

  .intro-card,
  .latest-blog-box,
  .content-feedback-cta {
    background: #ffffff;
    border: 2px solid rgba(105, 0, 90, 0.22);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    color: #000000;
  }

  .smsp-coming-soon-banner {
    margin-bottom: 1rem;
    padding: 1.1rem 1.25rem;
    background: rgba(192, 254, 113, 0.12);
    border: 2px solid var(--green-lime);
    border-radius: 10px;
    text-align: center;
  }

  .smsp-cs-eyebrow {
    margin: 0 0 0.3rem;
    color: var(--green-lime);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .smsp-cs-body {
    margin: 0;
    color: var(--green-light);
    line-height: 1.5;
  }

  .intro-card p,
  .content-feedback-cta p {
    color: #000000;
    margin: 0;
  }

  .latest-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .latest-posts li {
    margin-bottom: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(192, 254, 113, 0.2);
  }

  .latest-posts li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .latest-posts li a {
    display: block;
    text-decoration: none;
    color: #000000 !important;
  }

  .latest-posts li a:hover .title {
    color: var(--purple);
  }

  .latest-posts .title {
    margin: 0 0 0.25rem;
    font-size: 1.15rem;
    color: #000000;
  }

  .latest-posts .description {
    margin: 0;
    color: #000000;
    line-height: 1.5;
    font-size: 0.96rem;
  }

  .coming-soon {
    border-bottom: none !important;
    padding-bottom: 0 !important;
    margin-bottom: 0 !important;
  }

  /* Coming-soon lock cards (mirror the TTM lock-card pattern). Each
     SMSP post renders as a non-clickable card with a lock badge,
     blurred description teaser, and no link. When SMSP is ready to
     launch, swap the rendering back to clickable <a>. */
  .smsp-card-locked {
    position: relative;
    padding: 1.1rem 1.25rem;
    background: rgba(192, 254, 113, 0.08);
    border: 2px dashed rgba(192, 254, 113, 0.55);
    border-radius: 10px;
    margin-bottom: 0.9rem;
    cursor: not-allowed;
    color: #1a1a1a;
  }

  .smsp-card-locked:last-child {
    margin-bottom: 0;
  }

  .smsp-lock-badge {
    display: inline-block;
    margin-bottom: 0.5rem;
    padding: 0.2rem 0.6rem;
    background: var(--green-lime);
    color: var(--green-dark);
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .smsp-card-locked .title {
    margin: 0 0 0.3rem;
    color: #1a1a1a;
    font-size: 1.1rem;
    opacity: 0.85;
  }

  .smsp-description-blur {
    margin: 0;
    color: #555;
    line-height: 1.5;
    font-size: 0.94rem;
    filter: blur(2.5px);
    user-select: none;
    pointer-events: none;
  }

  .content-feedback-cta {
    text-align: center;
  }

  .feedback-cta-link {
    display: inline-block;
    margin-top: 0.6rem;
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 0.48rem 0.85rem;
    background: var(--green-lime);
    color: var(--green-dark) !important;
    font-weight: 700;
    text-decoration: none !important;
  }

  .feedback-cta-link:hover {
    border-color: var(--purple-light);
    color: var(--purple) !important;
  }

  @media (max-width: 720px) {
    .strong-minds-main {
      padding-bottom: 2rem;
    }

    .hero {
      padding: 1.4rem max(0.85rem, calc(50vw - 600px + 1rem));
      margin-bottom: 0.9rem;
    }

    .intro-card,
    .latest-blog-box,
    .content-feedback-cta {
      padding: 1rem;
    }
  }
</style>
