---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = await getCollection('blog');

const childPosts = allPosts.filter(
  (post) => post.slug.startsWith('strong-minds-stronger-players/') && post.slug !== 'strong-minds-stronger-players/strong-minds-stronger-players'
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={`Strong Minds, Stronger Players | ${SITE_TITLE}`} description="Understand mental health, recognising what to look out for, when pressure becomes something more serious, and how to seek the right support when you need it." />
  </head>
  <body>
    <Header />
    <main class="container">
      <section class="hero">
        <h1>Strong Minds, Stronger Players</h1>
      </section>

      <div class="prose">
        <p>Each post helps you build awareness of mental health in sport, so you can recognise changes early, understand what they might mean, and know when to seek the right support.</p>
      </div>

      <section class="posts">
        <ul id="posts-list">
          {childPosts.length > 0 ? childPosts.map((post) => (
            <li class="fade-in card">
              <a href={`/content-hub/${post.slug}/`}>
                <h2 class="title">{post.data.title}</h2>
                {post.data.description && (
                  <p class="description">{post.data.description}</p>
                )}
              </a>
            </li>
          )) : (
            <li class="coming-soon">
              <p>Posts coming soon. Check back shortly.</p>
            </li>
          )}
        </ul>
      </section>

      <section class="content-feedback-cta">
        <p>Got feedback on this content?</p>
        <a href="/content-feedback" class="feedback-cta-link">Share Feedback</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    color: var(--green-lime);
  }

  h2 {
    color: var(--green-lime);
  }

  .posts ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    padding: 0;
    list-style: none;
    justify-content: center;
    margin-bottom: 4rem;
    width: 100%;
    max-width: 1200px;
  }

  @media (min-width: 900px) {
    .posts ul {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .posts li {
    max-width: 350px;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .posts li:hover {
    border-color: var(--purple-light);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  }

  .posts li a {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .posts li .title {
    margin-bottom: 1rem;
    font-size: 1.4em;
  }

  .posts li .description {
    color: var(--green-light);
    line-height: 1.6;
  }

  .coming-soon {
    color: var(--green-light);
    font-size: 1.1rem;
    padding: 1rem 0;
    list-style: none;
  }

  @media (max-width: 1024px) {
    .posts ul {
      flex-direction: column;
      align-items: center;
    }
    .posts li {
      max-width: 100%;
      width: 100%;
    }
  }

  .content-feedback-cta {
    margin: 0 0 2.5rem;
    text-align: center;
  }

  .content-feedback-cta p {
    margin-bottom: 0.55rem;
    color: var(--green-light);
  }

  .feedback-cta-link {
    display: inline-block;
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 0.48rem 0.85rem;
    background: var(--green-lime);
    color: var(--green-dark);
    font-weight: 700;
    text-decoration: none;
  }

  .feedback-cta-link:hover {
    border-color: var(--purple-light);
    background: var(--purple-light);
  }
</style>
