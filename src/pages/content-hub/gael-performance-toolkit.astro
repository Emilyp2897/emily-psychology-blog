---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// Get toolkit posts (excluding the intro page).
const allPosts = await getCollection('blog');

const toolkitPosts = allPosts.filter(
  (post) =>
    post.slug.startsWith('gael-performance-toolkit/') &&
    post.slug !== 'gael-performance-toolkit/gael-performance-toolkit'
);

// Map each month of the Training the Mind series to its companion toolkit.
type ToolkitMonth = {
  month: string;
  theme: string;
  slug: string;
};

const monthlyToolkits: ToolkitMonth[] = [
  { month: 'Month 1',  theme: 'Pressure & Performance Anxiety',         slug: 'gael-performance-toolkit/pre-performance-routines-toolkit' },
  { month: 'Month 2',  theme: 'Confidence & Self-Talk',                  slug: 'gael-performance-toolkit/self-talk-and-confidence-toolkit' },
  { month: 'Month 3',  theme: 'Mistakes, Perfectionism & Shame',          slug: 'gael-performance-toolkit/mistake-reset-toolkit' },
  { month: 'Month 4',  theme: 'Team Culture, Belonging & Communication',  slug: 'gael-performance-toolkit/team-communication-toolkit' },
  { month: 'Month 5',  theme: 'Motivation, Discipline & Burnout Risk',    slug: 'gael-performance-toolkit/goal-setting-toolkit' },
  { month: 'Month 6',  theme: 'Injury Psychology & Comeback Confidence',  slug: 'gael-performance-toolkit/imagery-and-graded-exposure-toolkit' },
  { month: 'Month 7',  theme: 'Flow, Focus & Playing Free',               slug: 'gael-performance-toolkit/focus-and-refocus-toolkit' },
  { month: 'Month 8',  theme: 'Body Image, RED-S & Food Culture',         slug: 'gael-performance-toolkit/nutrition-and-language-toolkit' },
  { month: 'Month 9',  theme: 'Boundaries, Coaches & People-Pleasing',    slug: 'gael-performance-toolkit/boundaries-and-assertiveness-toolkit' },
  { month: 'Month 10', theme: 'Championship Pressure & Fear of Failure',  slug: 'gael-performance-toolkit/championship-routines-toolkit' },
  { month: 'Month 11', theme: 'Identity Beyond Sport & Balance',          slug: 'gael-performance-toolkit/values-and-balance-toolkit' },
  { month: 'Month 12', theme: 'Off-Season Mental Health & Reset',         slug: 'gael-performance-toolkit/off-season-recovery-toolkit' },
];

// Bonus toolkits = anything not in the monthly map (e.g. older standalone
// toolkits like reset-your-focus-toolkit, stay-composed-under-pressure-toolkit).
const monthlySlugSet = new Set(monthlyToolkits.map((m) => m.slug));
const bonusToolkits = toolkitPosts.filter((p) => !monthlySlugSet.has(p.slug));

function toolkitFor(slug: string) {
  return toolkitPosts.find((p) => p.slug === slug);
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={`Gael Performance Toolkit | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="toolkit-page">
    <Header />
    <main class="container toolkit-main">
      <section class="hero">
        <p class="hero-kicker">Content Hub Series</p>
        <h1>Gael Performance Toolkit</h1>
        <p class="hero-tagline">Practical tools for the mental side of sport. Use them before games, between plays, and after the moments that knock your confidence.</p>
      </section>

      <section class="toolkit-series" aria-label="Monthly toolkits">
        <h2>The 12-Month Toolkit Series</h2>
        <p class="series-intro">Each toolkit pairs with the matching Training the Mind month. Use them on their own or alongside the blog posts.</p>
        <ul class="month-toolkit-list">
          {monthlyToolkits.map((entry) => {
            const post = toolkitFor(entry.slug);
            if (!post) {
              return (
                <li class="toolkit-card toolkit-card-missing">
                  <span class="toolkit-month">{entry.month}</span>
                  <span class="toolkit-status">Coming soon</span>
                  <h3 class="toolkit-title">{entry.theme}</h3>
                </li>
              );
            }
            return (
              <li class="toolkit-card">
                <a href={`/content-hub/${post.slug}/`}>
                  <span class="toolkit-month">{entry.month}</span>
                  <h3 class="toolkit-title">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="toolkit-description">{post.data.description}</p>
                  )}
                  <span class="toolkit-cta">Open toolkit →</span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>

      {bonusToolkits.length > 0 && (
        <section class="toolkit-bonus" aria-label="Bonus toolkits">
          <h2>Bonus Toolkits</h2>
          <p class="series-intro">Standalone tools outside the 12-month series.</p>
          <ul class="month-toolkit-list">
            {bonusToolkits.map((post) => (
              <li class="toolkit-card">
                <a href={`/content-hub/${post.slug}/`}>
                  <span class="toolkit-month toolkit-month-bonus">Bonus</span>
                  <h3 class="toolkit-title">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="toolkit-description">{post.data.description}</p>
                  )}
                  <span class="toolkit-cta">Open toolkit →</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="content-feedback-cta">
        <p>Got feedback on this content?</p>
        <a href="/content-feedback" class="feedback-cta-link">Share Feedback</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .toolkit-main {
    padding-top: 0;
    padding-bottom: 3rem;
  }

  .hero {
    margin: 0 calc(50% - 50vw) 1.1rem;
    padding: 2rem max(1rem, calc(50vw - 600px + 1rem));
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
  }

  .hero-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
    color: var(--purple-light);
    font-weight: 700;
  }

  .hero h1 {
    margin: 0.2rem 0 0;
    color: var(--green-lime);
  }

  .hero-tagline {
    margin: 0.35rem 0 0;
    color: var(--green-light);
    max-width: 64ch;
  }

  .latest-blog-box {
    background: #ffffff;
    border: 2px solid rgba(105, 0, 90, 0.22);
    border-radius: 8px;
    padding: 1.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    margin-bottom: 1rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    color: #000000;
  }

  .latest-blog-box:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .latest-blog-box h2 {
    color: var(--purple);
    margin-bottom: 0.7rem;
  }

  #search-posts {
    width: 100%;
    max-width: 420px;
    display: block;
    margin-bottom: 1rem;
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    border: 1px solid rgba(105, 0, 90, 0.45);
    background: #fff;
    color: #000000;
    font-size: 0.95rem;
  }

  .latest-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .latest-posts li {
    margin-bottom: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(192, 254, 113, 0.2);
  }

  .latest-posts li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .latest-posts li a {
    text-decoration: none;
    color: #000000 !important;
    display: block;
  }

  .latest-posts li a:hover .title {
    color: var(--purple);
  }

  .latest-posts .title {
    margin: 0 0 0.25rem;
    font-size: 1.15rem;
    color: #000000;
  }

  .latest-posts .description {
    margin: 0;
    color: #000000;
    line-height: 1.5;
    font-size: 0.96rem;
  }

  .content-feedback-cta {
    margin: 0;
    text-align: center;
    border: 2px solid rgba(105, 0, 90, 0.22);
    border-radius: 8px;
    background: #ffffff;
    padding: 1rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
  }

  .content-feedback-cta p {
    margin-bottom: 0.55rem;
    color: #000000;
  }

  .feedback-cta-link {
    display: inline-block;
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 0.48rem 0.85rem;
    background: var(--green-lime);
    color: var(--green-dark) !important;
    font-weight: 700;
    text-decoration: none !important;
  }

  .feedback-cta-link:hover {
    border-color: var(--purple-light);
    color: var(--purple) !important;
  }

  @media (max-width: 720px) {
    .toolkit-main {
      padding-bottom: 2rem;
    }

    .hero {
      padding: 1.4rem max(0.85rem, calc(50vw - 600px + 1rem));
      margin-bottom: 0.9rem;
    }

    .latest-blog-box {
      padding: 1rem;
    }
  }

  /* New: monthly toolkit series listing */
  .toolkit-series {
    margin-top: 0.4rem;
    margin-bottom: 1.6rem;
  }

  .toolkit-bonus {
    margin-top: 1.2rem;
    margin-bottom: 1.6rem;
  }

  .toolkit-series h2,
  .toolkit-bonus h2 {
    color: var(--purple-light);
    margin: 0 0 0.25rem;
  }

  .series-intro {
    margin: 0 0 0.6rem;
    color: var(--green-light);
    max-width: 60ch;
    font-size: 0.95rem;
  }

  .month-toolkit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .toolkit-card {
    border: 2px solid rgba(105, 0, 90, 0.18);
    border-radius: 12px;
    padding: 1rem 1.1rem 1.1rem;
    background: #ffffff;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .toolkit-card:hover {
    transform: translateY(-3px);
    border-color: var(--purple);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
  }

  .toolkit-card a {
    display: block;
    text-decoration: none !important;
    color: inherit !important;
  }

  .toolkit-month {
    display: inline-block;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    background: var(--purple);
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .toolkit-month-bonus {
    background: var(--green-lime);
    color: var(--green-dark);
  }

  .toolkit-status {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: rgba(105, 0, 90, 0.55);
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-left: 0.4rem;
    vertical-align: middle;
  }

  .toolkit-title {
    color: var(--green-dark) !important;
    font-size: 1.05rem;
    margin: 0 0 0.4rem;
    line-height: 1.35;
    font-weight: 700;
  }

  .toolkit-description {
    color: var(--green-dark);
    font-size: 0.92rem;
    margin: 0 0 0.7rem;
    line-height: 1.5;
    opacity: 0.82;
  }

  .toolkit-cta {
    color: var(--purple);
    font-weight: 700;
    font-size: 0.85rem;
  }

  .toolkit-card-missing {
    opacity: 0.65;
    background: #f7f5f8;
  }
</style>