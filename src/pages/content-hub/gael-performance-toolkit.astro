---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// Get toolkit child posts (excluding the main toolkit intro page).
const allPosts = await getCollection('blog');

const childPosts = allPosts
  .filter((post) =>
    post.slug.startsWith('gael-performance-toolkit/') &&
    post.slug !== 'gael-performance-toolkit/gael-performance-toolkit'
  )
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={`Gael Performance Toolkit | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="toolkit-page">
    <Header />
    <main class="container toolkit-main">
      <section class="hero">
        <p class="hero-kicker">Content Hub Series</p>
        <h1>Gael Performance Toolkit</h1>
        <p class="hero-tagline">Practical tools for the mental side of sport. Use them before games, between plays, and after the moments that knock your confidence.</p>
      </section>

      <section class="latest-blog-box" aria-label="Practical tools">
        <h2>Practical Tools</h2>
        <label class="sr-only" for="search-posts">Search toolkit posts</label>
        <input
          type="text"
          id="search-posts"
          name="search-posts"
          placeholder="Search tools..."
          oninput="filterPosts()"
        />
        <ul id="posts-list" class="latest-posts">
          {childPosts.map((post) => (
            <li>
              <a href={`/content-hub/${post.slug}/`}>
                <h3 class="title">{post.data.title}</h3>
                {post.data.description && (
                  <p class="description">{post.data.description}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
        <script is:inline>
      function filterPosts() {
        const input = document.getElementById('search-posts');
        const filter = (input && 'value' in input ? input.value : '').toLowerCase();
        const ul = document.getElementById('posts-list');

        if (!ul) return;

        Array.from(ul.getElementsByTagName('li')).forEach((item) => {
          const title = item.querySelector('.title')?.textContent?.toLowerCase() || '';
          const desc = item.querySelector('.description')?.textContent?.toLowerCase() || '';
          item.style.display = title.includes(filter) || desc.includes(filter) ? '' : 'none';
        });
      }
    </script>
      </section>

      <section class="content-feedback-cta">
        <p>Got feedback on this content?</p>
        <a href="/content-feedback" class="feedback-cta-link">Share Feedback</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .toolkit-main {
    padding-top: 0;
    padding-bottom: 3rem;
  }

  .hero {
    margin: 0 calc(50% - 50vw) 1.1rem;
    padding: 2rem max(1rem, calc(50vw - 600px + 1rem));
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
  }

  .hero-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
    color: var(--purple-light);
    font-weight: 700;
  }

  .hero h1 {
    margin: 0.2rem 0 0;
    color: var(--green-lime);
  }

  .hero-tagline {
    margin: 0.35rem 0 0;
    color: var(--green-light);
    max-width: 64ch;
  }

  .latest-blog-box {
    background: #ffffff;
    border: 2px solid rgba(105, 0, 90, 0.22);
    border-radius: 8px;
    padding: 1.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    margin-bottom: 1rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    color: #000000;
  }

  .latest-blog-box:hover {
    transform: translateY(-2px);
    border-color: var(--purple-light);
  }

  .latest-blog-box h2 {
    color: var(--purple);
    margin-bottom: 0.7rem;
  }

  #search-posts {
    width: 100%;
    max-width: 420px;
    display: block;
    margin-bottom: 1rem;
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    border: 1px solid rgba(105, 0, 90, 0.45);
    background: #fff;
    color: #000000;
    font-size: 0.95rem;
  }

  .latest-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .latest-posts li {
    margin-bottom: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(192, 254, 113, 0.2);
  }

  .latest-posts li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .latest-posts li a {
    text-decoration: none;
    color: #000000 !important;
    display: block;
  }

  .latest-posts li a:hover .title {
    color: var(--purple);
  }

  .latest-posts .title {
    margin: 0 0 0.25rem;
    font-size: 1.15rem;
    color: #000000;
  }

  .latest-posts .description {
    margin: 0;
    color: #000000;
    line-height: 1.5;
    font-size: 0.96rem;
  }

  .content-feedback-cta {
    margin: 0;
    text-align: center;
    border: 2px solid rgba(105, 0, 90, 0.22);
    border-radius: 8px;
    background: #ffffff;
    padding: 1rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
  }

  .content-feedback-cta p {
    margin-bottom: 0.55rem;
    color: #000000;
  }

  .feedback-cta-link {
    display: inline-block;
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 0.48rem 0.85rem;
    background: var(--green-lime);
    color: var(--green-dark) !important;
    font-weight: 700;
    text-decoration: none !important;
  }

  .feedback-cta-link:hover {
    border-color: var(--purple-light);
    color: var(--purple) !important;
  }

  @media (max-width: 720px) {
    .toolkit-main {
      padding-bottom: 2rem;
    }

    .hero {
      padding: 1.4rem max(0.85rem, calc(50vw - 600px + 1rem));
      margin-bottom: 0.9rem;
    }

    .latest-blog-box {
      padding: 1rem;
    }
  }
</style>