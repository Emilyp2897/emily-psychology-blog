---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import saoirseImage from '../../assets/saoirse.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const seriesCards = [
  {
    title: 'Training the Mind Blog',
    description: 'Explore the mental side of performance with short, relatable posts built for female athletes.',
    href: '/content-hub/training-the-mind/',
  },
  {
    title: 'Gael Performance Toolkit',
    description: 'Practical, in-the-moment tools you can use before and during games when pressure rises.',
    href: '/content-hub/gael-performance-toolkit/',
  },
  {
    title: 'Stronger Minds, Stronger Players',
    description: 'Understand mental health in sport, recognise warning signs, and know where to get support.',
    href: '/content-hub/strong-minds-stronger-players/strong-minds-stronger-players/',
  },
];

const onlineContentBundles = [
  {
    title: 'Monthly Access',
    price: '£5 / month (first 50, then £8)',
    description: 'Includes a 14-day free trial, then monthly access: 4 Training the Mind articles (1 per week), 4 Gael Performance Toolkits, and 1 mindfulness newsletter.',
  },
  {
    title: '3-Month Bundle',
    price: '£21',
    description: '3 months access (total): 12 Training the Mind articles, 12 Gael Performance Toolkits, and 3 mindfulness newsletters.',
  },
  {
    title: '6-Month Bundle',
    price: '£39',
    description: '6 months access (total): 24 Training the Mind articles, 24 Gael Performance Toolkits, and 6 mindfulness newsletters.',
  },
  {
    title: '12-Month Bundle',
    price: '£72',
    description: '12 months access (total): 48 Training the Mind articles, 48 Gael Performance Toolkits, and 12 mindfulness newsletters.',
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={`Content Hub | ${SITE_TITLE}`} description="Mind the Gael content hub: Training the Mind, Gael Performance Toolkit, and Stronger Minds, Stronger Players resources." />
  </head>

  <body>
    <Header />

    <main class="container">

      <section class="hero fade-in">
        <h1>Mind the Gael Content Hub</h1>
        <p class="tagline">For the moments before the game, after the mistake, and everything in between</p>
      </section>

      <section class="posts">
        <ul>
          {seriesCards.map((card) => (
            <li class="fade-in">
              <a href={card.href}>
                <h2 class="title">{card.title}</h2>
                <p class="description">{card.description}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="online-content-bundles fade-in" aria-label="Online content bundle subscriptions">
        <div class="bundle-header">
          <a href="/api/create-checkout-session?plan=individual" class="subscribe-cta-link">
            <Image src={saoirseImage} class="subscribe-cta-img" alt="Saoirse the shamrock mascot" />
          </a>
        </div>
        <p class="access-note"><strong>Subscriptions include access to:</strong> Training the Mind and the Gael Performance Toolkit. <strong>Stronger Minds, Stronger Players will always be free</strong> because the content focuses on spotting when someone may be struggling with mental health and signposting pathways to professional support resources.</p>
        <p class="bundle-intro">Choose the online support option that fits your schedule and budget.</p>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              {onlineContentBundles.map((bundle) => (
                <tr>
                  <td>{bundle.title}</td>
                  <td>{bundle.price}</td>
                  <td>{bundle.description}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="bundle-actions">
          <a href="/pricing" class="subscriptions-main-cta">View Full Pricing</a>
          <a href="/api/create-checkout-session?plan=individual" class="subscriptions-main-cta">Subscribe Now</a>
        </div>
      </section>

      <section class="content-feedback-cta fade-in" aria-label="Content hub feedback">
        <p>Got feedback on any Content Hub page?</p>
        <a href="/content-feedback" class="subscriptions-main-cta">Share Feedback</a>
      </section>

    </main>

    <Footer />

    <!-- fade animation -->
    <script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".fade-in").forEach((el, index) => {
      setTimeout(() => el.classList.add("show"), index * 90);
    });
  });
</script>


  </body>
</html>

<style>
  h1, h2 {
    color: var(--green-lime);
  }

  .hero {
    text-align: center;
    margin: 0 calc(50% - 50vw) 1.4rem;
    padding: 2rem max(1rem, calc(50vw - 600px));
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
  }

  .tagline {
    color: var(--green-light);
    font-size: 1.1rem;
  }

  .posts ul {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    padding: 0;
    list-style: none;
    justify-content: center;
    margin-bottom: 4rem;
  }

  .posts li {
    flex: 1;
    max-width: 350px;
    background: linear-gradient(180deg, rgba(240, 205, 255, 0.92) 0%, rgba(244, 255, 232, 0.9) 100%);
    border: 2px solid rgba(105, 0, 90, 0.24);
    border-radius: 12px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .posts li:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: var(--purple-light);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  .posts li a {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .posts li .title {
    margin-bottom: 1rem;
    font-size: 1.4em;
    color: var(--purple);
  }

  .posts li .description {
    color: var(--green-dark);
    line-height: 1.6;
  }

  .bundle-header {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .bundle-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .online-content-bundles {
    margin: 0 auto 3rem;
    text-align: center;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(105, 0, 90, 0.24);
    background: linear-gradient(180deg, rgba(240, 205, 255, 0.9) 0%, rgba(244, 255, 232, 0.9) 100%);
  }

  .bundle-intro {
    color: var(--green-dark);
    margin-bottom: 1rem;
  }

  .access-note {
    max-width: 900px;
    margin: 0 auto 1rem;
    padding: 1rem 1.2rem;
    border-radius: 10px;
    border: 1px solid rgba(3, 10, 6, 0.42);
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
    color: #ffffff;
    line-height: 1.45;
  }

  .pricing-table-wrap {
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    background-color: rgba(255, 255, 255, 0.82);
    border: 2px solid rgba(105, 0, 90, 0.24);
  }

  .pricing-table th,
  .pricing-table td {
    padding: 0.85rem;
    text-align: left;
    border: 1px solid rgba(192, 254, 113, 0.35);
    vertical-align: middle;
  }

  .pricing-table th {
    background: rgba(240, 205, 255, 0.45);
    color: var(--purple);
    font-weight: 700;
  }

  .pricing-table td {
    color: var(--green-dark);
  }

  .subscribe-cta-link {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--green-lime);
    gap: 0.5rem;
  }

  .subscribe-cta-img {
    width: 90px;
    height: 90px;
    transition: transform 0.2s ease;
  }

  .subscribe-cta-link:hover .subscribe-cta-img {
    transform: translateY(-4px) scale(1.04);
  }

  .subscriptions-main-cta {
    display: inline-block;
    padding: 0.75rem 1.3rem;
    border-radius: 8px;
    background: var(--green-lime);
    color: var(--green-dark);
    font-weight: 700;
    border: 2px solid var(--green-lime);
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .subscriptions-main-cta:hover {
    transform: translateY(-1px);
    border-color: var(--purple-light);
    color: var(--purple);
  }

  .content-feedback-cta {
    margin: 0 auto 3rem;
    text-align: center;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(105, 0, 90, 0.24);
    background: linear-gradient(180deg, rgba(240, 205, 255, 0.9) 0%, rgba(244, 255, 232, 0.9) 100%);
  }

  .content-feedback-cta p {
    margin-bottom: 0.6rem;
    color: var(--green-dark);
  }

  .fade-in {
    opacity: 1;
    transform: none;
    transition: all 0.6s ease;
  }

  .fade-in.show {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .posts ul {
      flex-direction: column;
      align-items: center;
    }

    .posts li {
      max-width: 100%;
      width: 100%;
    }

  }
</style>