---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import saoirseImage from '../../assets/saoirse.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const seriesCards = [
  {
    title: 'Training the Mind Blog',
    description: 'Explore the mental side of performance with short, relatable posts built for female athletes.',
    href: '/content-hub/training-the-mind/',
  },
  {
    title: 'Gael Performance Toolkit',
    description: 'Practical, in-the-moment tools you can use before and during games when pressure rises.',
    href: '/content-hub/gael-performance-toolkit/',
  },
  {
    title: 'Stronger Minds, Stronger Players',
    description: 'Understand mental health in sport, recognise warning signs, and know where to get support.',
    href: '/content-hub/strong-minds-stronger-players/',
  },
];

const onlineContentBundles = [
  {
    title: 'Monthly Subscription (Founding Offer)',
    price: '£5 / month (first 50, then £8)',
    description: '14-day free trial, then monthly access. Includes 4 Training the Mind articles per month, 4 Gael Performance Toolkits, and 1 mindfulness newsletter. Stronger Minds, Stronger Players is always free.',
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={`Content Hub | ${SITE_TITLE}`} description="Mind the Gael content hub: Training the Mind, Gael Performance Toolkit, and Stronger Minds, Stronger Players resources." />
  </head>

  <body class="content-hub-page">
    <Header />

    <main class="container">

      <section class="hero fade-in">
        <h1>Mind the Gael Content Hub</h1>
        <p class="tagline">For the moments before the game, after the mistake, and everything in between</p>
      </section>

      <section class="series-cards fade-in" aria-label="Content hub sections">
        {seriesCards.map((card) => (
          <a href={card.href} class="series-card">
            <h2 class="title">{card.title}</h2>
            <p class="description">{card.description}</p>
          </a>
        ))}
      </section>

      <section class="online-content-bundles fade-in" aria-label="Blog subscription">
        <div class="bundle-header">
          <a href="/api/create-checkout-session?plan=individual" class="subscribe-cta-link">
            <Image src={saoirseImage} class="subscribe-cta-img" alt="Saoirse the shamrock mascot" />
          </a>
        </div>
        <p class="access-note"><strong>Subscriptions include access to:</strong> Training the Mind and the Gael Performance Toolkit. <strong>Stronger Minds, Stronger Players will always be free</strong> because the content focuses on spotting when someone may be struggling with mental health and signposting pathways to professional support resources.</p>
        <p class="bundle-intro">Subscribe monthly to keep getting fresh content every week.</p>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              {onlineContentBundles.map((bundle) => (
                <tr>
                  <td>{bundle.title}</td>
                  <td>{bundle.price}</td>
                  <td>{bundle.description}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="bundle-actions">
          <a href="/pricing" class="subscriptions-main-cta">View Full Pricing</a>
          <a href="/api/create-checkout-session?plan=individual" class="subscriptions-main-cta">Subscribe Now</a>
        </div>
      </section>

      <section class="content-feedback-cta fade-in" aria-label="Content hub feedback">
        <p>Got feedback on any Content Hub page?</p>
        <a href="/content-feedback" class="subscriptions-main-cta">Share Feedback</a>
      </section>

    </main>

    <Footer />

    <!-- fade animation -->
    <script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".fade-in").forEach((el, index) => {
      setTimeout(() => el.classList.add("show"), index * 90);
    });
  });
</script>


  </body>
</html>

<style>
  h1, h2 {
    color: var(--green-lime);
  }

  .hero {
    text-align: center;
    margin: 0 calc(50% - 50vw) 1.4rem;
    padding: 2rem max(1rem, calc(50vw - 600px));
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
  }

  .tagline {
    color: var(--green-light);
    font-size: 1.1rem;
  }

  .series-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .series-card {
    background: #ffffff;
    border: 2px solid rgba(105, 0, 90, 0.22);
    border-radius: 8px;
    padding: 1.8rem;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    color: #000000;
    text-decoration: none;
    display: flex;
    flex-direction: column;
  }

  .series-card:hover {
    transform: translateY(-4px);
    border-color: var(--purple-light);
    box-shadow: 0 15px 32px rgba(0, 0, 0, 0.16);
  }

  .series-card .title {
    margin: 0 0 0.8rem;
    font-size: 1.25rem;
    color: var(--purple);
    transition: color 0.2s ease;
  }

  .series-card:hover .title {
    color: var(--green-lime);
  }

  .series-card .description {
    margin: 0;
    color: #000000;
    line-height: 1.6;
    font-size: 0.97rem;
    flex-grow: 1;
  }

  .bundle-header {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .bundle-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .online-content-bundles {
    margin: 0 auto 3rem;
    text-align: center;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(105, 0, 90, 0.24);
    background: #ffffff;
  }

  .bundle-intro {
    color: #000000;
    margin-bottom: 1rem;
  }

  .access-note {
    max-width: 900px;
    margin: 0 auto 1rem;
    padding: 1rem 1.2rem;
    border-radius: 10px;
    border: 1px solid rgba(105, 0, 90, 0.42);
    background: var(--purple);
    color: #ffffff;
    line-height: 1.45;
  }

  .pricing-table-wrap {
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    background-color: rgba(244, 255, 232, 0.95);
    border: 2px solid rgba(105, 0, 90, 0.5);
  }

  .pricing-table th,
  .pricing-table td {
    padding: 0.85rem;
    text-align: left;
    border: 1px solid rgba(105, 0, 90, 0.45);
    vertical-align: middle;
  }

  .pricing-table th {
    background: rgba(192, 254, 113, 0.14);
    color: var(--purple);
    font-weight: 700;
  }

  .pricing-table td {
    color: var(--green-dark);
  }

  .subscribe-cta-link {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--green-lime);
    gap: 0.5rem;
  }

  .subscribe-cta-img {
    width: 90px;
    height: 90px;
    transition: transform 0.2s ease;
  }

  .subscribe-cta-link:hover .subscribe-cta-img {
    transform: translateY(-4px) scale(1.04);
  }

  .subscriptions-main-cta {
    display: inline-block;
    padding: 0.75rem 1.3rem;
    border-radius: 8px;
    background: var(--green-lime);
    color: var(--green-dark) !important;
    text-decoration: none !important;
    font-weight: 700;
    border: 2px solid var(--green-lime);
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .subscriptions-main-cta:hover {
    transform: translateY(-1px);
    border-color: var(--purple-light);
    color: var(--purple) !important;
  }

  .content-feedback-cta {
    margin: 0 auto 3rem;
    text-align: center;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(105, 0, 90, 0.24);
    background: #ffffff;
  }

  .content-feedback-cta p {
    margin-bottom: 0.6rem;
    color: #000000;
  }

  .fade-in {
    opacity: 1;
    transform: none;
    transition: all 0.6s ease;
  }

  .fade-in.show {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .series-card {
      padding: 1rem;
    }

    .cards-grid {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }
  }

  @media (max-width: 720px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>