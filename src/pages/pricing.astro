---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Pricing | ${SITE_TITLE}`} description="View all Mind the Gael pricing for personal training, online content bundles, and team sessions." />
  </head>
  <body>
    <Header />
    <main class="container pricing-main">
      <h1>Pricing</h1>

      <section class="pricing-section" aria-labelledby="pt-pricing-heading">
        <h2 id="pt-pricing-heading">Personal Training</h2>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>6-Week Online Programme</td>
                <td>£10</td>
                <td>A 6-week online training programme built around your sport, your equipment, and your goals. Delivered as a full plan to follow at your own pace, with no scheduled check-ins. Optional follow-up chat available if you'd like to discuss your plan.</td>
              </tr>
              <tr>
                <td>12-Week Online Programme</td>
                <td>£20</td>
                <td>A 12-week online training programme for longer arcs: pre-season builds, return-to-play phases, or extended training blocks. Same self-paced delivery, with optional follow-up chat if you want to talk it through.</td>
              </tr>
              <tr>
                <td>Pre-Season Team Programme (6 Weeks)</td>
                <td>Pilot from £850 | Standard £1250</td>
                <td>Six-week S&C coaching for a team panel of 20-30 athletes, delivered fully online. Pilot pricing is limited availability.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="pricing-section" aria-labelledby="mental-performance-pricing-heading">
        <h2 id="mental-performance-pricing-heading">Mental Performance Plans</h2>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>6-Week Mental Performance Plan</td>
                <td>TBC</td>
                <td>A 6-week online mental performance plan drawing on the Gael Performance Toolkit. Built around your sport, your routines, and the performance moments you want to work on (pre-game nerves, focus during play, recovery from mistakes).</td>
              </tr>
              <tr>
                <td>12-Week Mental Performance Plan</td>
                <td>TBC</td>
                <td>A 12-week online mental performance plan for longer arcs: pre-season mental prep, post-injury return, or sustained mental skill development.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="pricing-section" aria-labelledby="blog-subscription-heading">
        <h2 id="blog-subscription-heading">Blog Subscription</h2>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Monthly Subscription (Founding Offer)</td>
                <td>£5 / month (first 50, then £8)</td>
                <td>14-day free trial, then monthly access. Includes 4 Training the Mind articles per month, 4 Gael Performance Toolkits, and 1 mindfulness newsletter. Stronger Minds, Stronger Players is always free.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>


    </main>
    <Footer />
  </body>
</html>

<style>
  .pricing-main {
    padding-top: 0;
    padding-bottom: 3rem;
  }

  .pricing-main > h1 {
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
    color: var(--purple);
    margin: 0 calc(50% - 50vw) 1rem;
    padding: 2rem max(1rem, calc(50vw - 600px + 1rem));
  }

  .pricing-intro {
    margin-bottom: 1.25rem;
    color: var(--green-light);
  }

  .pricing-section {
    margin-bottom: 2rem;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(105, 0, 90, 0.24);
    background: #ffffff;
  }

  .pricing-section h2 {
    color: var(--purple);
  }

  .pricing-table-wrap {
    overflow-x: auto;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    background-color: rgba(244, 255, 232, 0.95);
    border: 2px solid rgba(105, 0, 90, 0.5);
  }

  .pricing-table th,
  .pricing-table td {
    padding: 0.85rem;
    text-align: left;
    border: 1px solid rgba(105, 0, 90, 0.45);
    vertical-align: middle;
    color: var(--green-dark);
  }

  .pricing-table th {
    background: rgba(192, 254, 113, 0.14);
    color: var(--purple);
    font-weight: 700;
  }

</style>
