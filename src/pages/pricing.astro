---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Pricing | ${SITE_TITLE}`} description="View all Mind the Gael pricing for personal training, online content bundles, and team sessions." />
  </head>
  <body>
    <Header />
    <main class="container pricing-main">
      <h1>Pricing</h1>

      <section class="pricing-section" aria-labelledby="pt-pricing-heading">
        <h2 id="pt-pricing-heading">Personal Training</h2>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Online 1:1 Sessions</td>
                <td>£15</td>
                <td>One 30-minute online personal training session.</td>
              </tr>
              <tr>
                <td>4 Online 1:1 Personal Training Sessions (Bundle)</td>
                <td>£50</td>
                <td>Four 30-minute online personal training sessions at a discounted bundle rate.</td>
              </tr>
              <tr>
                <td>In-Person 1:1 Sessions</td>
                <td>£25</td>
                <td>One 30-minute in-person personal training session.</td>
              </tr>
              <tr>
                <td>4 In-Person 1:1 Personal Training Sessions (Bundle)</td>
                <td>£80</td>
                <td>Four 30-minute in-person personal training sessions at a discounted bundle rate.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="pricing-section" aria-labelledby="online-pricing-heading">
        <h2 id="online-pricing-heading">Online Content Bundles</h2>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Monthly Access</td>
                <td>£5 / month (first 50, then £8)</td>
                <td>Includes a 14-day free trial, then monthly access: 4 Training the Mind articles (1 per week), 4 Gael Performance Toolkits, and 1 mindfulness newsletter.</td>
              </tr>
              <tr>
                <td>3-Month Bundle</td>
                <td>£21</td>
                <td>3 months access (total): 12 Training the Mind articles, 12 Gael Performance Toolkits, and 3 mindfulness newsletters.</td>
              </tr>
              <tr>
                <td>6-Month Bundle</td>
                <td>£39</td>
                <td>6 months access (total): 24 Training the Mind articles, 24 Gael Performance Toolkits, and 6 mindfulness newsletters.</td>
              </tr>
              <tr>
                <td>12-Month Bundle</td>
                <td>£72</td>
                <td>12 months access (total): 48 Training the Mind articles, 48 Gael Performance Toolkits, and 12 mindfulness newsletters.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="pricing-section" aria-labelledby="hybrid-pricing-heading">
        <h2 id="hybrid-pricing-heading">Hybrid Bundles</h2>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Hybrid Bundle: Online Content + 2 Online 1:1 Sessions</td>
                <td>£32 / month</td>
                <td>Monthly online content plus two 30-minute online personal training sessions.</td>
              </tr>
              <tr>
                <td>Hybrid Bundle: Online Content + 2 In-Person 1:1 Sessions</td>
                <td>£48 / month</td>
                <td>Monthly online content plus two 30-minute in-person personal training sessions.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="pricing-section" aria-labelledby="content-workshop-pricing-heading">
        <h2 id="content-workshop-pricing-heading">Content & Workshop Bundles</h2>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Online Content + 1 Workshop (Your Choice)</td>
                <td>£55</td>
                <td>One-time payment for 3 months access (12 articles, 12 toolkits, 3 newsletters) plus 1 workshop of your choice.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="pricing-section" aria-labelledby="workshops-pricing-heading">
        <h2 id="workshops-pricing-heading">Online Workshops</h2>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Course</th>
                <th>Upfront Price</th>
                <th>Installment Option</th>
                <th>Duration</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Mindfullness for Female Athletes</td>
                <td>£35</td>
                <td>£40 (2 x £20)</td>
                <td>TBD</td>
              </tr>
              <tr>
                <td>Performance Coaching for Female Athletes</td>
                <td>£39</td>
                <td>£45 (3 x £15)</td>
                <td>TBD</td>
              </tr>
              <tr>
                <td>Nutrition for Female Athletes</td>
                <td>£29</td>
                <td>£34 (2 x £17)</td>
                <td>TBD</td>
              </tr>
              <tr>
                <td>Mental Wellbeing Workshop</td>
                <td>£35</td>
                <td>£40 (2 x £20)</td>
                <td>TBD</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="pricing-section" aria-labelledby="team-pricing-heading">
        <h2 id="team-pricing-heading">Team Programmes</h2>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Price</th>
                <th>Includes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Team Online Subscription (Monthly)</td>
                <td>£75 / month</td>
                <td>Monthly online team support package designed for a panel of up to 30 athletes.</td>
              </tr>
              <tr>
                <td>Team Online Subscription (6-Month Outright)</td>
                <td>£405</td>
                <td>Six months paid upfront for a panel of up to 30 athletes.</td>
              </tr>
              <tr>
                <td>Team Online Subscription (12-Month Outright)</td>
                <td>£720</td>
                <td>Twelve months paid upfront for a panel of up to 30 athletes.</td>
              </tr>
              <tr>
                <td>Pre-Season Team Programme (6 Weeks)</td>
                <td>Pilot from £850 | Standard £1250</td>
                <td>Six-week S&C coaching for a team panel of 20-30 athletes. Pilot pricing is limited availability.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .pricing-main {
    padding-top: 0;
    padding-bottom: 3rem;
  }

  .pricing-main > h1 {
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
    margin: 0 calc(50% - 50vw) 1rem;
    padding: 2rem max(1rem, calc(50vw - 600px));
  }

  .pricing-intro {
    margin-bottom: 1.25rem;
    color: var(--green-light);
  }

  .pricing-section {
    margin-bottom: 2rem;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(105, 0, 90, 0.24);
    background: linear-gradient(180deg, rgba(240, 205, 255, 0.9) 0%, rgba(244, 255, 232, 0.9) 100%);
  }

  .pricing-table-wrap {
    overflow-x: auto;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    background-color: rgba(255, 255, 255, 0.8);
    border: 2px solid rgba(105, 0, 90, 0.5);
  }

  .pricing-table th,
  .pricing-table td {
    padding: 0.85rem;
    text-align: left;
    border: 1px solid rgba(105, 0, 90, 0.45);
    vertical-align: middle;
    color: var(--green-dark);
  }

  .pricing-table th {
    background: rgba(240, 205, 255, 0.45);
    color: var(--purple);
    font-weight: 700;
  }

</style>
