---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import saoirseImage from '../../assets/saoirse.png';

export const prerender = false;

const saoirseAssets = {
  happy: saoirseImage.src,
  oh: '/assets/Oh.svg',
  shocked: '/assets/Shocked.svg',
  annoyed: '/assets/Annoyed.svg',
  angry: '/assets/Angry.svg',
};

// PUBLIC_FEEDBACK_ENABLED controls whether the pilot feedback popup
// appears after a customer completes a week. Default ON; set to
// 'false' in the env to silence it after the pilot is done.
const feedbackEnabled =
  String(import.meta.env.PUBLIC_FEEDBACK_ENABLED ?? 'true').toLowerCase() !== 'false';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`My Plan | ${SITE_TITLE}`} description="Your Mind the Gael performance plan." />
  </head>
  <body>
    <Header />
    <main class="container">
      <div class="plan-wrap">
        <a href="/dashboard" class="back-link">← Back to Dashboard</a>
        <div id="plan-container">
          <p class="loading">Loading your plan...</p>
        </div>
      </div>
    </main>
    <Footer />

    <div id="celebration-modal" class="modal" hidden>
      <div class="modal-card">
        <img id="modal-saoirse" class="modal-saoirse" alt="Saoirse celebrating" />
        <p class="modal-eyebrow">Maith thú</p>
        <h2 id="modal-heading">Week complete</h2>
        <p id="modal-message" class="modal-message"></p>
        <div class="modal-actions">
          <button id="modal-continue" type="button" class="modal-primary">Open next week</button>
          <button id="modal-close" type="button" class="modal-secondary">Stay on this week</button>
        </div>
      </div>
    </div>

    <div id="day-celebration" class="modal day-modal" hidden>
      <div class="modal-card day-modal-card">
        <img class="day-modal-saoirse" alt="Saoirse celebrating" />
        <p class="modal-eyebrow">Maith thú</p>
        <h2 class="day-modal-message"></h2>
      </div>
    </div>

    <div id="feedback-modal" class="modal" hidden>
      <form id="feedback-form" class="modal-card feedback-card">
        <p class="modal-eyebrow">Pilot feedback</p>
        <h2 id="feedback-heading">How did this week go?</h2>
        <p class="feedback-intro">A minute of your time helps Emily make the next week better. Skip if you would rather not right now.</p>

        <div class="feedback-rating">
          <label class="feedback-rating-label">Rate this week</label>
          <div class="rating-buttons" role="radiogroup" aria-label="Rate this week from 1 to 5">
            <button type="button" class="rating-btn" data-rating="1" aria-label="1 out of 5"><span>1</span><small>Tough</small></button>
            <button type="button" class="rating-btn" data-rating="2" aria-label="2 out of 5"><span>2</span></button>
            <button type="button" class="rating-btn" data-rating="3" aria-label="3 out of 5"><span>3</span><small>OK</small></button>
            <button type="button" class="rating-btn" data-rating="4" aria-label="4 out of 5"><span>4</span></button>
            <button type="button" class="rating-btn" data-rating="5" aria-label="5 out of 5"><span>5</span><small>Loved it</small></button>
          </div>
          <input type="hidden" id="feedback-rating-value" />
        </div>

        <label class="feedback-text-label">
          What worked well this week?
          <input type="text" id="feedback-worked-well" maxlength="500" placeholder="e.g. The pre-game routine helped me settle." />
        </label>

        <label class="feedback-text-label">
          What was hard or unclear?
          <input type="text" id="feedback-was-hard" maxlength="500" placeholder="e.g. Tuesday session was a bit too heavy on legs." />
        </label>

        <label class="feedback-text-label">
          Anything you want to flag to Emily? (optional)
          <textarea id="feedback-notes" maxlength="1000" rows="2" placeholder="Optional"></textarea>
        </label>

        <div class="modal-actions">
          <button type="submit" class="modal-primary" id="feedback-submit">Send feedback</button>
          <button type="button" class="modal-secondary" id="feedback-skip">Skip for now</button>
        </div>
      </form>
    </div>

    <script is:inline define:vars={{ saoirseAssets, feedbackEnabled }}>
      // Expose the resolved Saoirse emotion variants and the feedback
      // gate to the main script. define:vars only works on is:inline
      // scripts.
      window.SAOIRSE_ASSETS = saoirseAssets;
      window.FEEDBACK_ENABLED = !!feedbackEnabled;
    </script>

    <script>
      import { supabase } from '../../lib/supabase.js';
      import { marked } from 'marked';

      const { data: { user } } = await supabase.auth.getUser();
      if (!user) {
        window.location.href = '/login';
      }

      const planId = window.location.pathname.split('/').pop();
      const container = document.getElementById('plan-container');

      const { data: plan, error } = await supabase
        .from('Plans')
        .select('*')
        .eq('id', planId)
        .eq('user_id', user?.id)
        .single();

      // Module-level state. Declared before any function uses them so
      // they're never accessed in TDZ.
      type SessionStruct = { exerciseCount: number };
      type WeekStruct = { sessions: SessionStruct[] };

      let weeksStructure: WeekStruct[] = [];
      let weeks: string[] = [];
      let progress: Record<string, string> =
        plan?.progress && typeof plan.progress === 'object' ? { ...plan.progress } : {};
      let planType: 'physical' | 'mental' = plan?.plan_type === 'mental' ? 'mental' : 'physical';
      let weeksTotal = 0;

      if (error || !plan) {
        console.error('plan fetch error:', error);
        if (container) container.innerHTML = `<p class="error">Plan not found or not yet approved.${error?.message ? ' ' + error.message : ''}</p>`;
      } else {
        try {
          await renderPlan(plan);
        } catch (err: any) {
          console.error('renderPlan failed:', err);
          if (container) container.innerHTML = `<p class="error">Could not render your plan: ${err?.message || 'Unknown error'}. Check the browser console.</p>`;
        }
      }

      async function renderPlan(plan: any) {
        if (!container) return;

        const approvedAt = plan.approved_at ? new Date(plan.approved_at) : new Date();
        weeksTotal = plan.weeks_total || 0;
        weeks = parsePlanIntoWeeks(plan.plan_content, weeksTotal);
        weeksStructure = weeks.map(w => parseWeekStructure(w, planType));

        const initialWeek = pickInitialWeek();
        const week1Html = await renderWeek(weeks[initialWeek - 1], initialWeek);

        container.innerHTML = `
          <div class="plan-header">
            <div class="plan-meta">
              <span class="plan-type-badge">${planType === 'mental' ? 'Mental Performance Plan' : 'Physical Performance Plan'}</span>
              <span class="plan-date">Started ${approvedAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </div>
          </div>

          <div class="ai-disclaimer" role="note">
            <strong>Heads up.</strong> This plan was AI-generated and personally reviewed by Emily before going live. If anything feels off, unclear, or unsafe for your body, <a href="/contact-us">message Emily</a> before pushing through it.
          </div>

          <section id="stats-panel" class="stats-panel">
            ${renderStats()}
          </section>

          <div id="week-nav" class="week-nav">
            ${renderWeekNav(initialWeek)}
          </div>

          <article id="week-content" class="plan-content" data-week="${initialWeek}">
            ${week1Html}
          </article>
        `;

        bindWeekNavHandlers();
        bindCheckboxHandlers();
      }

      function pickInitialWeek(): number {
        const unlocked = computeUnlockedWeeks();
        return unlocked[unlocked.length - 1] || 1;
      }

      function computeUnlockedWeeks(): number[] {
        const out: number[] = [1];
        for (let w = 1; w < weeksTotal; w++) {
          if (isWeekComplete(w)) out.push(w + 1);
          else break;
        }
        return out;
      }

      function isWeekComplete(weekNum: number): boolean {
        const struct = weeksStructure[weekNum - 1];
        if (!struct || struct.sessions.length === 0) return false;
        return struct.sessions.every((_s, idx) => isSessionComplete(weekNum, idx + 1));
      }

      function isSessionComplete(weekNum: number, sessionNum: number): boolean {
        const struct = weeksStructure[weekNum - 1];
        if (!struct) return false;
        const session = struct.sessions[sessionNum - 1];
        if (!session || session.exerciseCount === 0) return false;
        for (let e = 1; e <= session.exerciseCount; e++) {
          if (!progress[`${weekNum}.${sessionNum}.${e}`]) return false;
        }
        return true;
      }

      function countCompletedInWeek(weekNum: number): number {
        const struct = weeksStructure[weekNum - 1];
        if (!struct) return 0;
        let n = 0;
        struct.sessions.forEach((s, sIdx) => {
          for (let e = 1; e <= s.exerciseCount; e++) {
            if (progress[`${weekNum}.${sIdx + 1}.${e}`]) n++;
          }
        });
        return n;
      }

      function totalExercisesInWeek(weekNum: number): number {
        const struct = weeksStructure[weekNum - 1];
        if (!struct) return 0;
        return struct.sessions.reduce((acc, s) => acc + s.exerciseCount, 0);
      }

      function totalExercisesAll(): number {
        return weeksStructure.reduce((acc, w) =>
          acc + w.sessions.reduce((a, s) => a + s.exerciseCount, 0), 0);
      }

      function completedExercisesAll(): number {
        let n = 0;
        weeksStructure.forEach((w, wIdx) => {
          w.sessions.forEach((s, sIdx) => {
            for (let e = 1; e <= s.exerciseCount; e++) {
              if (progress[`${wIdx + 1}.${sIdx + 1}.${e}`]) n++;
            }
          });
        });
        return n;
      }

      function sessionsCompleteAll(): number {
        let n = 0;
        weeksStructure.forEach((w, wIdx) => {
          w.sessions.forEach((_s, sIdx) => {
            if (isSessionComplete(wIdx + 1, sIdx + 1)) n++;
          });
        });
        return n;
      }

      function totalSessions(): number {
        return weeksStructure.reduce((acc, w) => acc + w.sessions.length, 0);
      }

      function weeksComplete(): number {
        let n = 0;
        for (let w = 1; w <= weeksTotal; w++) if (isWeekComplete(w)) n++;
        return n;
      }

      function dayStreak(): number {
        const dayKeys = Array.from(new Set(
          Object.values(progress)
            .filter((v): v is string => typeof v === 'string')
            .map(v => v.slice(0, 10)),
        )).sort();
        if (dayKeys.length === 0) return 0;

        const todayMs = new Date(new Date().toISOString().slice(0, 10) + 'T00:00:00Z').getTime();
        const yesterdayMs = todayMs - 86400000;
        const todayStr = new Date(todayMs).toISOString().slice(0, 10);
        const yesterdayStr = new Date(yesterdayMs).toISOString().slice(0, 10);

        if (!dayKeys.includes(todayStr) && !dayKeys.includes(yesterdayStr)) return 0;

        const startStr = dayKeys.includes(todayStr) ? todayStr : yesterdayStr;
        let cursor = new Date(startStr + 'T00:00:00Z').getTime();
        let streak = 0;
        while (dayKeys.includes(new Date(cursor).toISOString().slice(0, 10))) {
          streak++;
          cursor -= 86400000;
        }
        return streak;
      }

      function renderWeekNav(activeWeek: number): string {
        const unlocked = new Set(computeUnlockedWeeks());
        return Array.from({ length: weeksTotal }, (_, i) => {
          const weekNum = i + 1;
          const isUnlocked = unlocked.has(weekNum);
          const isComplete = isWeekComplete(weekNum);
          const isActive = weekNum === activeWeek;
          const label = `Week ${weekNum}${!isUnlocked ? ' 🔒' : isComplete ? ' ✓' : ''}`;
          return `
            <button class="week-pill ${isUnlocked ? 'unlocked' : 'locked'} ${isActive ? 'active' : ''} ${isComplete ? 'complete' : ''}"
              data-week="${weekNum}"
              ${!isUnlocked ? 'disabled' : ''}>
              ${label}
            </button>
          `;
        }).join('');
      }

      function bindWeekNavHandlers() {
        document.querySelectorAll('#week-nav .week-pill.unlocked').forEach(btn => {
          btn.addEventListener('click', async () => {
            await openWeek(parseInt(btn.getAttribute('data-week') || '1'));
          });
        });
      }

      async function openWeek(weekNum: number) {
        document.querySelectorAll('#week-nav .week-pill').forEach(b => b.classList.remove('active'));
        const newActive = document.querySelector(`#week-nav .week-pill[data-week="${weekNum}"]`);
        if (newActive) newActive.classList.add('active');
        const weekContent = document.getElementById('week-content');
        if (weekContent) {
          weekContent.setAttribute('data-week', String(weekNum));
          weekContent.innerHTML = '<p class="loading">Loading...</p>';
          weekContent.innerHTML = await renderWeek(weeks[weekNum - 1], weekNum);
          bindCheckboxHandlers();
        }
      }

      function parsePlanIntoWeeks(content: string, weeksTotal: number): string[] {
        const out: string[] = [];
        for (let i = 1; i <= weeksTotal; i++) {
          const pattern = new RegExp(
            `#{1,2}\\s+Week\\s+${i}[\\s\\S]*?(?=#{1,2}\\s+Week\\s+${i + 1}|#{1,2}\\s+COACH NOTES|#{1,2}\\s+THINGS TO TRACK|#{1,2}\\s+ROUTINES|$)`,
            'gi',
          );
          const match = content.match(pattern);
          out.push(match ? match[0].trim() : `Week ${i} content is not available.`);
        }
        return out;
      }

      // Parse one week's markdown into its session structure: how many
      // sessions, and how many ticking rows in each. For physical
      // plans, each `### Session N` heading owns the next table. For
      // mental plans, the whole week has one "session" whose rows are
      // the daily-practice table.
      function parseWeekStructure(weekContent: string, planType: 'physical' | 'mental'): WeekStruct {
        if (planType === 'mental') {
          // One session per week, exercise count = number of daily rows.
          const rows = countFirstTableRows(weekContent);
          return { sessions: [{ exerciseCount: rows || 1 }] };
        }
        const chunks = splitOnSessionHeadings(weekContent);
        const sessions = chunks.map(chunk => ({ exerciseCount: countFirstTableRows(chunk) || 1 }));
        if (sessions.length === 0) sessions.push({ exerciseCount: 1 });
        return { sessions };
      }

      // Split a week's content into per-session chunks (one chunk per
      // `### Session N` heading). Drops anything before the first
      // Session heading (the week intro lines).
      function splitOnSessionHeadings(weekContent: string): string[] {
        const parts = weekContent.split(/^#{3}\s+Session\s+\d+[^\n]*$/gim);
        // First element is content before the first Session heading; drop it.
        return parts.slice(1);
      }

      // Count data rows in the first markdown table found in a chunk.
      // Markdown tables look like:
      //   | header | header |
      //   | --- | --- |
      //   | data | data |
      function countFirstTableRows(markdown: string): number {
        const lines = markdown.split('\n');
        let foundSeparator = false;
        let count = 0;
        for (const raw of lines) {
          const line = raw.trim();
          if (!foundSeparator) {
            if (/^\|[\s\-:|]+\|$/.test(line)) foundSeparator = true;
            continue;
          }
          if (line.startsWith('|') && line.endsWith('|')) count++;
          else if (line === '') break;
          else break;
        }
        return count;
      }

      async function renderWeek(content: string, weekNum: number): Promise<string> {
        if (!content) return '<p>Content for this week is not available yet.</p>';
        const total = totalExercisesInWeek(weekNum);
        const done = countCompletedInWeek(weekNum);
        const isComplete = isWeekComplete(weekNum);
        const itemLabel = planType === 'mental' ? 'days of practice' : 'exercises';

        const processed = content.replace(/(\s)(\*\*[A-Z][^*]+:\*\*)/g, '\n\n$2');
        const rendered = await marked.parse(processed);
        const cleaned = stripEmptyBlocks(rendered);
        const coached = transformCoachTips(cleaned);
        const withChecks = injectExerciseCheckboxes(coached, weekNum);

        return `
          <div class="week-block">
            <div class="week-status-row">
              ${isComplete
                ? `<span class="week-status-badge complete">Week ${weekNum} complete</span>`
                : `<span class="week-status-badge in-progress">In progress</span>`}
              <span class="week-progress-text">${done} of ${total} ${itemLabel} ticked</span>
            </div>
            ${withChecks}
          </div>
        `;
      }

      // Strip empty <blockquote> and <p> elements from the rendered
      // markdown. Marked sometimes produces empties when the model
      // outputs blank `>` separator lines between exercise descriptions;
      // global.css gives every blockquote a purple left border + padding
      // so even empties showed up as short vertical bars between rows.
      function stripEmptyBlocks(html: string): string {
        const tmp = document.createElement('div');
        tmp.innerHTML = html;
        tmp.querySelectorAll('blockquote, p').forEach(el => {
          if (!el.textContent || !el.textContent.trim()) el.remove();
        });
        return tmp.innerHTML;
      }

      // Replace specific labelled paragraphs with a speech-bubble card
      // showing one of Saoirse's emotion variants on the left. Each
      // entry maps a (case-insensitive, no trailing colon) label to the
      // display copy and which avatar to use.
      //
      // Two markdown patterns are handled:
      //
      //   Pattern A — physical plans, label + content on same line:
      //     **Cues:** Keep your chest up.
      //   Renders as: <p><strong>Cues:</strong> Keep your chest up.</p>
      //
      //   Pattern B — mental plans, label is its own paragraph, then
      //   the content paragraphs follow until the next labelled line
      //   or a non-paragraph block (table, heading, list, hr):
      //     **Concept of the week**
      //     Three to five lines of explanation...
      //
      // Exercise description blockquotes (e.g. **Back squat:**) are NOT
      // in this map and stay as their existing purple-banner style.
      function transformCoachTips(html: string): string {
        const assets = (window as any).SAOIRSE_ASSETS || {};
        const labelMap: Record<string, { display: string; avatar: string }> = {
          // Physical plan labels
          'cues': { display: 'Cues from Saoirse', avatar: assets.happy },
          'cycle consideration': { display: 'Cycle consideration', avatar: assets.oh },
          'how to know you are ready to progress': { display: 'Ready to progress?', avatar: assets.happy },
          'how to know you are ready to progress?': { display: 'Ready to progress?', avatar: assets.happy },
          // Mental plan labels
          'concept of the week': { display: 'Concept of the week', avatar: assets.happy },
          'reflection prompt': { display: 'Reflection prompt', avatar: assets.happy },
        };

        const tmp = document.createElement('div');
        tmp.innerHTML = html;

        // Snapshot the <p> list up-front because we'll mutate the DOM
        // as we go.
        const paragraphs = Array.from(tmp.querySelectorAll('p'));

        for (const p of paragraphs) {
          if (!p.parentElement) continue; // already removed via Strategy B
          const strong = p.querySelector('strong');
          if (!strong) continue;
          const rawLabel = (strong.textContent || '').trim().replace(/:$/, '').toLowerCase();
          const config = labelMap[rawLabel];
          if (!config) continue;

          // Decide Pattern A vs Pattern B: if the only text in the
          // paragraph is the label itself, the content is in following
          // siblings (B); otherwise content sits after the strong (A).
          const fullText = (p.textContent || '').trim().toLowerCase();
          const labelOnly = fullText === rawLabel || fullText === rawLabel + ':';

          let bodyHtml = '';
          const toRemove: Element[] = [];

          if (!labelOnly) {
            // Pattern A: strip the leading <strong>...</strong> and any
            // colon, keep the rest of the inline content as the body.
            bodyHtml = p.innerHTML
              .replace(/^\s*<strong[^>]*>[^<]*<\/strong>\s*:?\s*/i, '')
              .trim();
          } else {
            // Pattern B: walk forward and collect content paragraphs
            // until we hit another labelled paragraph or a different
            // block-level element (table/heading/list/hr).
            let sib = p.nextElementSibling;
            while (sib) {
              const tag = sib.tagName;
              if (['TABLE', 'H1', 'H2', 'H3', 'H4', 'H5', 'H6', 'HR', 'UL', 'OL'].includes(tag)) {
                break;
              }
              if (tag === 'P') {
                const sibStrong = sib.querySelector('strong');
                if (sibStrong) {
                  const sibLabel = (sibStrong.textContent || '').trim().replace(/:$/, '').toLowerCase();
                  // Stop on any labelled paragraph — strong-led lines
                  // that aren't in labelMap (e.g. **Focus:**) still mean
                  // a new section starts, so we don't swallow them.
                  if (sibStrong.parentElement === sib && sibLabel) {
                    const sibText = (sib.textContent || '').trim().toLowerCase();
                    if (sibText === sibLabel || sibText === sibLabel + ':' || labelMap[sibLabel]) {
                      break;
                    }
                  }
                }
              }
              bodyHtml += sib.outerHTML;
              toRemove.push(sib);
              sib = sib.nextElementSibling;
            }
          }

          if (!bodyHtml) continue;

          const wrap = document.createElement('div');
          wrap.className = 'coach-tip';
          wrap.innerHTML =
            `<img src="${config.avatar || ''}" alt="Saoirse" class="coach-tip-avatar">` +
            `<div class="coach-tip-bubble">` +
              `<span class="coach-tip-label">${config.display}</span>` +
              `<div class="coach-tip-text">${bodyHtml}</div>` +
            `</div>`;
          p.replaceWith(wrap);
          toRemove.forEach(el => el.remove());
        }

        return tmp.innerHTML;
      }

      // Inject a "Done" checkbox column into each session's table.
      // Physical: each <h3>Session N: ...</h3> is followed by its
      //   <table>; we rewrite the next table after each Session heading.
      // Mental: there is no Session heading; we rewrite the first
      //   <table> in the week (the daily practice table).
      function injectExerciseCheckboxes(html: string, weekNum: number): string {
        if (planType === 'mental') {
          return transformFirstTable(html, weekNum, 1);
        }

        // Walk the HTML, splitting on each <h3>Session N...</h3>. For
        // each segment after a Session heading, transform its first
        // <table>.
        const headingRegex = /(<h3[^>]*>\s*Session\s+(\d+)[^<]*<\/h3>)/gi;
        const parts = html.split(headingRegex);
        // parts is [pre, h3_match, session_num, post, h3_match, session_num, post, ...]
        if (parts.length <= 1) return html;

        let out = parts[0]; // before first Session heading
        for (let i = 1; i < parts.length; i += 3) {
          const heading = parts[i];
          const sessionNum = parseInt(parts[i + 1], 10);
          let segment = parts[i + 2] || '';
          segment = transformFirstTable(segment, weekNum, sessionNum);
          out += heading + segment;
        }
        return out;
      }

      function transformFirstTable(html: string, weekNum: number, sessionNum: number): string {
        // Find first <table>...</table> block.
        const tableMatch = html.match(/<table[\s\S]*?<\/table>/i);
        if (!tableMatch) return html;
        const tableHtml = tableMatch[0];

        // Inject a leading "Done" header cell.
        let newTable = tableHtml.replace(
          /<thead>([\s\S]*?)<\/thead>/i,
          (_m, head) => `<thead>${head.replace(/<tr>/i, '<tr><th class="tick-col">Done</th>')}</thead>`,
        );
        // If no <thead>, treat first <tr> as the header.
        if (!/<thead>/i.test(tableHtml)) {
          newTable = newTable.replace(/<tr>/i, '<tr><th class="tick-col">Done</th>');
        }

        // Inject a checkbox cell at the start of each <tbody> row.
        let exerciseIndex = 0;
        newTable = newTable.replace(/<tbody>([\s\S]*?)<\/tbody>/i, (_m, body) => {
          const newBody = body.replace(/<tr>/gi, () => {
            exerciseIndex++;
            const key = `${weekNum}.${sessionNum}.${exerciseIndex}`;
            const checked = !!progress[key];
            return `<tr class="exercise-row${checked ? ' done' : ''}" data-week="${weekNum}" data-session="${sessionNum}" data-exercise="${exerciseIndex}">`
              + `<td class="tick-col">`
              + `<input type="checkbox" class="exercise-tick" data-week="${weekNum}" data-session="${sessionNum}" data-exercise="${exerciseIndex}" ${checked ? 'checked' : ''} aria-label="Mark item complete">`
              + `</td>`;
          });
          return `<tbody>${newBody}</tbody>`;
        });

        return html.replace(tableMatch[0], newTable);
      }

      function bindCheckboxHandlers() {
        document.querySelectorAll('#week-content input.exercise-tick').forEach(input => {
          input.addEventListener('change', async (ev) => {
            const el = ev.currentTarget as HTMLInputElement;
            const week = parseInt(el.getAttribute('data-week') || '0');
            const session = parseInt(el.getAttribute('data-session') || '0');
            const exercise = parseInt(el.getAttribute('data-exercise') || '0');
            if (!week || !session || !exercise) return;

            const previouslyComplete = isWeekComplete(week);
            const previouslySessionComplete = isSessionComplete(week, session);
            const wantCompleted = el.checked;
            el.disabled = true;

            try {
              const { data: sessionData } = await supabase.auth.getSession();
              const accessToken = sessionData?.session?.access_token;
              if (!accessToken) throw new Error('Not signed in.');

              const res = await fetch('/api/plan/toggle-session', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'Authorization': `Bearer ${accessToken}`,
                },
                body: JSON.stringify({ planId, week, session, exercise, completed: wantCompleted }),
              });
              const data = await res.json().catch(() => ({}));
              if (!res.ok || !data.success) {
                throw new Error(data?.error || `HTTP ${res.status}`);
              }

              progress = data.progress || progress;
              el.disabled = false;

              // Toggle the parent row's `.done` class for the strike-through styling.
              const row = el.closest('tr');
              if (row) row.classList.toggle('done', wantCompleted);

              refreshStatsAndNav(week);

              const nowComplete = isWeekComplete(week);
              const nowSessionComplete = isSessionComplete(week, session);
              if (!previouslyComplete && nowComplete) {
                // Week just finished — big modal beats the toast.
                showCelebration(week);
              } else if (wantCompleted) {
                if (planType === 'mental') {
                  // Mental plans: each ticked row is one day of practice.
                  showDayCelebration('Maith thú, day of practice done.');
                } else if (!previouslySessionComplete && nowSessionComplete) {
                  // Physical: only celebrate when the full session finishes,
                  // not every individual exercise tick.
                  showDayCelebration(`Maith thú, Session ${session} done.`);
                }
              }
            } catch (err: any) {
              console.error('toggle-session failed:', err);
              el.checked = !wantCompleted;
              el.disabled = false;
              alert('Could not save that tick: ' + (err?.message || 'unknown error') + '. Please try again.');
            }
          });
        });
      }

      function refreshStatsAndNav(activeWeek: number) {
        const stats = document.getElementById('stats-panel');
        const nav = document.getElementById('week-nav');
        if (stats) stats.innerHTML = renderStats();
        if (nav) {
          nav.innerHTML = renderWeekNav(activeWeek);
          bindWeekNavHandlers();
        }
        const weekContent = document.getElementById('week-content');
        const text = weekContent?.querySelector('.week-progress-text');
        const itemLabel = planType === 'mental' ? 'days of practice' : 'exercises';
        if (text) {
          text.textContent = `${countCompletedInWeek(activeWeek)} of ${totalExercisesInWeek(activeWeek)} ${itemLabel} ticked`;
        }
        const badge = weekContent?.querySelector('.week-status-badge');
        if (badge) {
          const done = isWeekComplete(activeWeek);
          badge.textContent = done ? `Week ${activeWeek} complete` : 'In progress';
          badge.classList.toggle('complete', done);
          badge.classList.toggle('in-progress', !done);
        }
      }

      function renderStats(): string {
        const doneEx = completedExercisesAll();
        const totalEx = totalExercisesAll();
        const pct = totalEx > 0 ? Math.round((doneEx / totalEx) * 100) : 0;
        const sessDone = sessionsCompleteAll();
        const sessTotal = totalSessions();
        const wkDone = weeksComplete();
        const streak = dayStreak();
        const itemLabel = planType === 'mental' ? 'practices' : 'exercises';

        // SVG ring math: r=52 → circumference = 2πr ≈ 326.73
        const radius = 52;
        const circumference = 2 * Math.PI * radius;
        const offset = circumference * (1 - pct / 100);

        return `
          <div class="stat-ring-wrap">
            <svg class="stat-ring" viewBox="0 0 120 120" aria-hidden="true">
              <circle class="ring-track" cx="60" cy="60" r="${radius}" />
              <circle class="ring-fill" cx="60" cy="60" r="${radius}"
                stroke-dasharray="${circumference.toFixed(2)}"
                stroke-dashoffset="${offset.toFixed(2)}" />
            </svg>
            <div class="ring-label">
              <span class="ring-value">${pct}%</span>
              <span class="ring-sublabel">${doneEx} / ${totalEx} ${itemLabel}</span>
            </div>
          </div>
          <div class="stat-mini-grid">
            <div class="stat-mini">
              <span class="stat-mini-value">${sessDone}<span class="stat-mini-of">/${sessTotal}</span></span>
              <span class="stat-mini-label">Sessions complete</span>
            </div>
            <div class="stat-mini">
              <span class="stat-mini-value">${wkDone}<span class="stat-mini-of">/${weeksTotal}</span></span>
              <span class="stat-mini-label">Weeks complete</span>
            </div>
            <div class="stat-mini">
              <span class="stat-mini-value">${streak}</span>
              <span class="stat-mini-label">Day streak</span>
            </div>
          </div>
        `;
      }

      // Centered modal celebration for completing a single "day" —
      // a full session on a physical plan, or one daily-practice row
      // on a mental plan. Same modal layout as the week-complete one
      // but with no buttons; auto-dismisses after ~2.5s and closes
      // immediately if the customer clicks the overlay. Suppressed by
      // callers if the week-complete modal is going to fire instead.
      let dayCelebrationTimeout: number | undefined;
      function showDayCelebration(message: string) {
        const el = document.getElementById('day-celebration') as HTMLElement | null;
        if (!el) return;
        const img = el.querySelector('.day-modal-saoirse') as HTMLImageElement | null;
        const msg = el.querySelector('.day-modal-message') as HTMLElement | null;
        const assets = (window as any).SAOIRSE_ASSETS || {};
        if (img) img.src = assets.happy || '';
        if (msg) msg.textContent = message;

        el.hidden = false;

        if (dayCelebrationTimeout) window.clearTimeout(dayCelebrationTimeout);
        dayCelebrationTimeout = window.setTimeout(() => {
          el.hidden = true;
        }, 2500);

        // Click anywhere on the overlay to dismiss early. Re-binding
        // each call is fine because it's a one-shot per show.
        const dismissOnClick = () => {
          if (dayCelebrationTimeout) window.clearTimeout(dayCelebrationTimeout);
          el.hidden = true;
          el.removeEventListener('click', dismissOnClick);
        };
        el.addEventListener('click', dismissOnClick);
      }

      function showCelebration(weekNum: number) {
        const modal = document.getElementById('celebration-modal');
        const heading = document.getElementById('modal-heading');
        const message = document.getElementById('modal-message');
        const saoirseImg = document.getElementById('modal-saoirse') as HTMLImageElement | null;
        const cont = document.getElementById('modal-continue') as HTMLButtonElement | null;
        const close = document.getElementById('modal-close');
        if (!modal || !heading || !message || !cont || !close) return;

        const assets = (window as any).SAOIRSE_ASSETS || {};
        if (saoirseImg) saoirseImg.src = assets.happy || '';

        const hasNext = weekNum < weeksTotal;
        heading.textContent = `Week ${weekNum} complete`;
        message.textContent = hasNext
          ? `Strong work. Week ${weekNum + 1} is now unlocked.`
          : `That's the full plan done. Have a chat with Emily about what's next.`;
        cont.hidden = !hasNext;
        modal.hidden = false;

        const proceedToNext = async () => {
          if (hasNext) await openWeek(weekNum + 1);
        };
        const stayHere = async () => { /* noop */ };

        const onClose = () => {
          modal.hidden = true;
          cont.removeEventListener('click', onContinue);
          close.removeEventListener('click', onClose);
          if ((window as any).FEEDBACK_ENABLED) showFeedbackModal(weekNum, stayHere);
        };
        const onContinue = () => {
          modal.hidden = true;
          cont.removeEventListener('click', onContinue);
          close.removeEventListener('click', onClose);
          if ((window as any).FEEDBACK_ENABLED) showFeedbackModal(weekNum, proceedToNext);
          else proceedToNext();
        };
        cont.addEventListener('click', onContinue);
        close.addEventListener('click', onClose);
      }

      // Pilot feedback popup that fires after the week-complete
      // celebration. Asks for a 1-5 rating + two short text replies +
      // an optional note for Emily. POSTs to /api/plan/week-feedback
      // then runs `afterAction` (advance to next week or stay). Skip
      // also runs `afterAction` so we never block navigation.
      function showFeedbackModal(weekNum: number, afterAction: () => Promise<void> | void) {
        const modal = document.getElementById('feedback-modal') as HTMLElement | null;
        const form = document.getElementById('feedback-form') as HTMLFormElement | null;
        const heading = document.getElementById('feedback-heading');
        const ratingInput = document.getElementById('feedback-rating-value') as HTMLInputElement | null;
        const workedWell = document.getElementById('feedback-worked-well') as HTMLInputElement | null;
        const wasHard = document.getElementById('feedback-was-hard') as HTMLInputElement | null;
        const notes = document.getElementById('feedback-notes') as HTMLTextAreaElement | null;
        const submit = document.getElementById('feedback-submit') as HTMLButtonElement | null;
        const skip = document.getElementById('feedback-skip');
        if (!modal || !form || !ratingInput || !workedWell || !wasHard || !notes || !submit || !skip) return;

        // Reset state.
        if (heading) heading.textContent = `How did Week ${weekNum} go?`;
        ratingInput.value = '';
        workedWell.value = '';
        wasHard.value = '';
        notes.value = '';
        submit.disabled = false;
        submit.textContent = 'Send feedback';
        modal.querySelectorAll('.rating-btn').forEach(b => b.classList.remove('selected'));

        modal.hidden = false;

        const ratingButtons = Array.from(modal.querySelectorAll('.rating-btn')) as HTMLButtonElement[];
        const ratingHandlers: Array<() => void> = [];
        ratingButtons.forEach(btn => {
          const handler = () => {
            ratingButtons.forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            ratingInput.value = btn.getAttribute('data-rating') || '';
          };
          btn.addEventListener('click', handler);
          ratingHandlers.push(handler);
        });

        const cleanup = () => {
          modal.hidden = true;
          ratingButtons.forEach((btn, i) => btn.removeEventListener('click', ratingHandlers[i]));
          skip.removeEventListener('click', onSkip);
          form.removeEventListener('submit', onSubmit);
        };

        const finishWith = async (action: () => Promise<void> | void) => {
          cleanup();
          await action();
        };

        const onSkip = () => { void finishWith(afterAction); };

        const onSubmit = async (ev: Event) => {
          ev.preventDefault();
          const rating = ratingInput.value ? parseInt(ratingInput.value, 10) : null;
          const wwText = workedWell.value.trim();
          const wbText = wasHard.value.trim();
          const noteText = notes.value.trim();

          if (rating === null && !wwText && !wbText && !noteText) {
            alert('Add a rating or one line of feedback, or hit Skip if you would rather not.');
            return;
          }

          submit.disabled = true;
          submit.textContent = 'Sending...';

          try {
            const { data: sessionData } = await supabase.auth.getSession();
            const accessToken = sessionData?.session?.access_token;
            if (!accessToken) throw new Error('Not signed in.');

            const res = await fetch('/api/plan/week-feedback', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${accessToken}`,
              },
              body: JSON.stringify({
                planId,
                weekNumber: weekNum,
                rating,
                workedWell: wwText || null,
                wasHard: wbText || null,
                notesForEmily: noteText || null,
              }),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok || !data.success) {
              throw new Error(data?.error || `HTTP ${res.status}`);
            }
            await finishWith(afterAction);
          } catch (err: any) {
            console.error('feedback submit failed:', err);
            submit.disabled = false;
            submit.textContent = 'Send feedback';
            alert('Could not send feedback: ' + (err?.message || 'unknown error') + '. Hit Skip if you want to move on.');
          }
        };

        skip.addEventListener('click', onSkip);
        form.addEventListener('submit', onSubmit);
      }
    </script>

