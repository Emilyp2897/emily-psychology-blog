---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import saoirseImage from '../assets/saoirse.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="workshops-page">
    <Header />
    <main class="container">

      <div class="coming-soon-strip fade-in">
        <Image src={saoirseImage} alt="Saoirse the shamrock" class="strip-shamrock" loading="eager" />
        <span>Coming Soon. Courses launching shortly.</span>
      </div>

      <section class="hero fade-in">
        <div class="hero-inner">
          <h1>Online Workshops</h1>
          <p class="hero-intro">These are online interactive courses designed for athletes to do in their own time.</p>
          <p class="access-note">Accessible pricing options are available for every course.</p>
        </div>
      </section>

      <section class="intro-card fade-in" aria-label="Workshop overview">
        <p>
          These workshops are designed to give athletes practical support in a format they can work through in their own time,
          with a clear focus on useful tools, reflection, and implementation.
        </p>
      </section>

      <div class="two-col-grid fade-in">
        <section class="workshops-content">
          <div class="workshop-cards">
            <article class="workshop-card">
              <h4>Mindfullness for Female Athletes</h4>
              <p>Build focus and emotional control through guided practices, short exercises, and weekly reflection prompts.</p>
              <p class="workshop-meta"><strong>Price:</strong> £30</p>
              <a class="sign-up-btn" href="/contact-us?course=mindfullness-for-female-athletes">Sign Up</a>
            </article>
            <article class="workshop-card">
              <h4>Performance Coaching for Female Athletes</h4>
              <p>Learn practical performance tools for confidence, consistency, and pressure moments with step-by-step implementation.</p>
              <p class="workshop-meta"><strong>Price:</strong> £30</p>
              <a class="sign-up-btn" href="/contact-us?course=performance-coaching-for-female-athletes">Sign Up</a>
            </article>
            <article class="workshop-card">
              <h4>Nutrition for Female Athletes</h4>
              <p>Improve fueling, recovery, and energy with evidence-based nutrition lessons and practical weekly meal planning tasks.</p>
              <p class="workshop-meta"><strong>Price:</strong> £30</p>
              <a class="sign-up-btn" href="/contact-us?course=nutrition-for-female-athletes">Sign Up</a>
            </article>
            <article class="workshop-card">
              <h4>Mental Wellbeing Workshop</h4>
              <p>Develop routines that protect wellbeing and prevent burnout using structured self-checks and resilience-building exercises.</p>
              <p class="workshop-meta"><strong>Price:</strong> £30</p>
              <a class="sign-up-btn" href="/contact-us?course=mental-wellbeing-workshop">Sign Up</a>
            </article>
          </div>
        </section>
      </div>

    </main>
    <Footer />

    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.fade-in').forEach((el, index) => {
          setTimeout(() => el.classList.add('show'), index * 90);
        });
      });
    </script>
  </body>
</html>

<style>
  .workshops-page {
    position: relative;
    isolation: isolate;
  }

  .workshops-page .container {
    padding-top: 0;
  }

  .hero {
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
    margin: 0 calc(50% - 50vw) 1rem;
    padding: 2rem max(1rem, calc(50vw - 600px + 1rem)) 1.9rem;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .hero h1 {
    margin: 0 0 0.3rem;
    color: var(--green-lime);
    font-size: 2rem;
    line-height: 1.2;
  }

  .hero p {
    margin: 0;
    line-height: 1.42;
  }

  .hero-intro {
    color: var(--green-light);
  }

  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 0.25rem;
    margin-bottom: 3rem;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .coming-soon-strip {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1200px;
    margin: 0.2rem auto 0.55rem;
    border-radius: 8px;
    background: #ffffff;
    border: 2px solid rgba(105, 0, 90, 0.22);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    color: var(--purple);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.55rem 1rem;
    font-weight: 700;
    font-size: 0.95rem;
    text-align: center;
  }

  .strip-shamrock {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .intro-card {
    max-width: 1200px;
    margin: 0 auto 1rem;
    background: #ffffff;
    border: 2px solid rgba(105, 0, 90, 0.22);
    border-radius: 8px;
    padding: 1.35rem 1.5rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
  }

  .intro-card p {
    margin: 0;
    color: #000000;
    line-height: 1.6;
  }

  .workshops-content {
    padding: 0;
  }

  .workshop-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .workshop-card {
    border: 2px solid rgba(105, 0, 90, 0.22);
    border-radius: 8px;
    padding: 1.3rem;
    background: #ffffff;
    color: #000000;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .workshop-card:hover {
    transform: translateY(-4px);
    border-color: var(--purple-light);
    box-shadow: 0 15px 32px rgba(0, 0, 0, 0.16);
  }

  .workshop-card h4 {
    color: var(--purple);
    font-size: 1.2rem;
    margin: 0 0 0.65rem;
  }

  .workshop-card p {
    margin: 0;
    color: #000000;
    line-height: 1.5;
  }

  .access-note {
    margin: 0.85rem 0 0;
    color: var(--purple-light);
    font-weight: 600;
    line-height: 1.38;
  }

  .planned-label {
    margin: 0 0 0.2rem;
    color: var(--green-light);
    font-size: 1.15rem;
  }

  .workshop-meta {
    margin-top: 0.7rem;
    color: #000000;
    font-size: 0.95rem;
  }

  .sign-up-btn {
    display: inline-block;
    margin-top: 0.9rem;
    padding: 0.75rem 1.2rem;
    border-radius: 8px;
    border: 2px solid var(--green-lime);
    background-color: var(--green-lime);
    text-decoration: none;
    color: var(--green-dark) !important;
    font-weight: 700;
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .sign-up-btn:hover {
    transform: translateY(-1px);
    border-color: var(--purple-light);
    color: var(--purple) !important;
  }

  .fade-in {
    opacity: 1;
    transform: none;
    transition: all 0.6s ease;
  }

  .fade-in.show {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 900px) {
    .two-col-grid {
      grid-template-columns: 1fr;
    }

    .workshop-cards {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 1.5rem max(0.85rem, calc(50vw - 600px + 1rem));
    }

    .intro-card,
    .workshop-card {
      padding: 1rem;
    }
  }
</style>
