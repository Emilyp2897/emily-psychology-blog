---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import saoirseImage from '../assets/saoirse.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="workshops-page">
    <Header />
    <main class="container">

      <div class="coming-soon-strip">
        <Image src={saoirseImage} alt="Saoirse the shamrock" class="strip-shamrock" loading="eager" />
        <span>Coming Soon — courses launching shortly. Register your interest below!</span>
      </div>

      <section class="hero">
        <h1>Online Workshops</h1>
        <p>These are online interactive courses designed for athletes to do in their own time.</p>
      </section>

      <div class="two-col-grid">
        <section class="workshops-content">
          <p class="access-note">Accessible pricing options are available for every course.</p>
          <p><strong>Planned workshops:</strong></p>
          <div class="workshop-cards">
            <article class="workshop-card">
              <h4>Mindfullness for Female Athletes</h4>
              <p>Build focus and emotional control through guided practices, short exercises, and weekly reflection prompts.</p>
              <p class="workshop-meta"><strong>Price:</strong> £35</p>
              <p class="workshop-meta"><strong>Duration:</strong> TBD</p>
              <a class="sign-up-btn" href="/contact-us?course=mindfullness-for-female-athletes">Sign Up</a>
            </article>
            <article class="workshop-card">
              <h4>Performance Coaching for Female Athletes</h4>
              <p>Learn practical performance tools for confidence, consistency, and pressure moments with step-by-step implementation.</p>
              <p class="workshop-meta"><strong>Price:</strong> £39</p>
              <p class="workshop-meta"><strong>Duration:</strong> TBD</p>
              <a class="sign-up-btn" href="/contact-us?course=performance-coaching-for-female-athletes">Sign Up</a>
            </article>
            <article class="workshop-card">
              <h4>Nutrition for Female Athletes</h4>
              <p>Improve fueling, recovery, and energy with evidence-based nutrition lessons and practical weekly meal planning tasks.</p>
              <p class="workshop-meta"><strong>Price:</strong> £29</p>
              <p class="workshop-meta"><strong>Duration:</strong> TBD</p>
              <a class="sign-up-btn" href="/contact-us?course=nutrition-for-female-athletes">Sign Up</a>
            </article>
            <article class="workshop-card">
              <h4>Mental Wellbeing Workshop</h4>
              <p>Develop routines that protect wellbeing and prevent burnout using structured self-checks and resilience-building exercises.</p>
              <p class="workshop-meta"><strong>Price:</strong> £35</p>
              <p class="workshop-meta"><strong>Duration:</strong> TBD</p>
              <a class="sign-up-btn" href="/contact-us?course=mental-wellbeing-workshop">Sign Up</a>
            </article>
          </div>
        </section>
      </div>

    </main>
    <Footer />
  </body>
</html>

<style>
  .workshops-page {
    position: relative;
    isolation: isolate;
  }

  .workshops-page .container {
    position: relative;
    isolation: isolate;
  }

  .workshops-page .container::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    background: url('/assets/DSC_1538.jpg') center top/cover no-repeat;
    opacity: 0.32;
    z-index: 0;
    pointer-events: none;
  }

  .workshops-page .container > * {
    position: relative;
    z-index: 1;
  }

  .section-heading {
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: var(--green-lime);
    font-size: 1.7rem;
  }

  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .coming-soon-strip {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto 1rem;
    border-radius: 8px;
    background: var(--purple-light);
    color: var(--purple);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.55rem 1rem;
    font-weight: 700;
    font-size: 0.95rem;
    text-align: center;
  }

  .strip-shamrock {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .workshops-content {
    padding: 0;
  }

  .workshop-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin-bottom: 1rem;
  }

  .workshop-card {
    border: 1px solid rgba(165, 243, 53, 0.45);
    border-radius: 10px;
    padding: 1rem;
    background: rgba(165, 243, 53, 0.08);
    color: var(--white);
  }

  .workshop-card h4 {
    color: var(--green-lime);
    font-size: 1.2rem;
    margin: 0 0 0.5rem;
  }

  .workshop-card p {
    margin: 0;
    color: var(--green-light);
    line-height: 1.5;
  }

  .access-note {
    margin: 0 0 0.75rem;
    color: var(--green-lime);
    font-weight: 600;
  }

  .workshop-meta {
    margin-top: 0.7rem;
    color: var(--white);
    font-size: 0.95rem;
  }

  .access-detail {
    margin-top: 0.35rem;
    font-size: 0.9rem;
    color: var(--green-light);
  }

  .sign-up-btn {
    display: inline-block;
    margin-top: 0.9rem;
    padding: 0.75rem 1.2rem;
    border-radius: 6px;
    border: 2px solid transparent;
    background-color: var(--green-lime);
    text-decoration: none;
    color: var(--green-dark);
    font-weight: 700;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .sign-up-btn:hover {
    background-color: var(--purple-light);
    border-color: var(--purple);
    color: var(--green-dark);
  }

  @media (max-width: 900px) {
    .two-col-grid {
      grid-template-columns: 1fr;
    }

    .workshop-cards {
      grid-template-columns: 1fr;
    }

    .individual-subscription,
    .team-subscription {
      padding: 1.5rem;
    }
  }
</style>
