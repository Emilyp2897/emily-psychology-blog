---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="workshops-page">
    <Header />
    <main class="container">

      <section class="hero">
        <h1>Workshops</h1>
      </section>

      <div class="two-col-grid">
        <section class="subscription-box public-workshops coming-soon-box">
          <h3>Online Workshops</h3>
          <p>We offer public workshops every quarter</p>
          <div class="coming-soon">
            <img src="/assets/saoirse.png" alt="Shamrock" class="coming-soon-img" />
            <span class="coming-soon-text">Coming Soon</span>
            <a href="/online-workshops" class="view-all-link">Find out more →</a>
          </div>
        </section>
        <section class="subscription-box team-workshops coming-soon-box">
          <h3>In person Workshops</h3>
          <p>We offer 1 and 2 day workshops for teams looking for mental wellbeing and performance coaching</p>
          <div class="coming-soon">
            <img src="/assets/saoirse.png" alt="Shamrock" class="coming-soon-img" />
            <span class="coming-soon-text">Coming Soon</span>
            <a href="/in-person-workshops" class="view-all-link">Find out more →</a>
          </div>
        </section>
      </div>

    </main>
    <Footer />
  </body>
</html>

<style>
  .section-heading {
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: var(--green-lime);
    font-size: 1.7rem;
  }

  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .public-workshops,
  .team-workshops {
    border-radius: 12px;
    border: 2px solid var(--green-lime);
    padding: 2rem;
    background: linear-gradient(135deg, rgba(165, 243, 53, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
    transition: all 0.3s ease;
  }

  .public-workshops:hover,
  .team-workshops:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(165, 243, 53, 0.2);
  }

  .coming-soon {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .coming-soon-img {
    width: 60px;
    height: 60px;
    margin: 1rem 0;
  }

  .coming-soon-text {
    font-weight: 600;
    color: var(--green-lime);
    font-size: 1.1rem;
  }

  .view-all-link {
    color: var(--green-lime);
    text-decoration: none;
    font-weight: 600;
    margin-top: 1rem;
    transition: all 0.3s ease;
  }

  .view-all-link:hover {
    gap: 0.5rem;
  }

  @media (max-width: 900px) {
    .two-col-grid {
      grid-template-columns: 1fr;
    }

    .public-workshops,
    .team-workshops,
    .individual-subscription,
    .team-subscription {
      padding: 1.5rem;
    }
  }
</style>
