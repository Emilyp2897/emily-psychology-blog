---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`My Dashboard | ${SITE_TITLE}`} description="Your Mind the Gael performance plans." />
  </head>
  <body>
    <Header />
    <main class="container">
      <div class="dashboard-wrap">
        <div class="dashboard-header">
          <h1>My Dashboard</h1>
          <button id="logout-btn" class="logout-btn">Log Out</button>
        </div>

        <p class="dashboard-intro" id="dashboard-greeting">Welcome back.</p>

        <section class="plans-section">
          <h2>Your Plans</h2>
          <p class="dashboard-ai-note">
            <strong>About your plans:</strong> Each plan is AI-generated and personally reviewed by Emily before it is published to you. If anything in a plan feels off, unclear, or unsafe, <a href="/contact-us">message Emily</a> before pushing through it.
          </p>
          <div id="plans-list" class="plans-list">
            <p class="plans-empty">Loading your plans...</p>
          </div>
        </section>
      </div>
    </main>
    <Footer />

    <script>
      import { supabase } from '../lib/supabase.js';

      // Check user is logged in
      const { data: { user } } = await supabase.auth.getUser();

      if (!user) {
        window.location.href = '/login';
      }

      // Greet the user
      const greeting = document.getElementById('dashboard-greeting');
      const name = user?.user_metadata?.full_name || user?.email;
      if (greeting) greeting.textContent = `Welcome back, ${name}.`;


      // Logout
      const logoutBtn = document.getElementById('logout-btn');
      logoutBtn?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/login';
      });

      // Load plans via the server-side endpoint so we can include team
      // plans (which have user_id = null and would otherwise be hidden
      // by RLS on the client-facing supabase client).
      const plansList = document.getElementById('plans-list');
      let allPlans: any[] = [];
      try {
        const { data: sessionData } = await supabase.auth.getSession();
        const accessToken = sessionData?.session?.access_token;
        if (accessToken) {
          const res = await fetch('/api/customer-plans', {
            headers: { 'Authorization': `Bearer ${accessToken}` },
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && Array.isArray(data?.plans)) {
            allPlans = data.plans;
          } else {
            console.error('customer-plans returned non-ok:', data);
          }
        }
      } catch (err) {
        console.error('customer-plans fetch failed', err);
      }

      function statusLabel(plan: any): string {
        if (plan.is_team_plan && plan.status === 'pending_review') return 'pending review';
        return plan.status;
      }

      function planLink(plan: any): string | null {
        if (plan.is_team_plan) {
          // Only link if approved + has a share token. Pending team
          // plans have no public URL yet.
          if (plan.status === 'active' && plan.share_token) return `/team-plan/${plan.share_token}`;
          return null;
        }
        return `/plan/${plan.id}`;
      }

      function planTypeLabel(plan: any): string {
        const base = plan.plan_type === 'mental' ? '🧠 Mental Performance Plan' : '💪 Physical Performance Plan';
        return plan.is_team_plan ? `${base} <span class="team-badge">Team</span>` : base;
      }

      if (allPlans.length === 0) {
        if (plansList) plansList.innerHTML = '<p class="plans-empty">You have no active plans yet. <a href="https://mindthegael.co.uk/personal-training" style="color: #c0fe71 !important; text-decoration: underline;">Get started here.</a></p>';
      } else {
        if (plansList) {
          plansList.innerHTML = allPlans.map((plan: any) => {
            const link = planLink(plan);
            const ctaHtml = link
              ? `<a href="${link}" class="plan-view-btn">${plan.is_team_plan ? 'Open team plan' : 'View Plan'}</a>`
              : `<span class="plan-pending-note">Awaiting Emily's review. You'll get an email with the share link once it's live.</span>`;
            return `
              <div class="plan-card">
                <div class="plan-card-header">
                  <span class="plan-type">${planTypeLabel(plan)}</span>
                  <span class="plan-status ${plan.status}">${statusLabel(plan)}</span>
                </div>
                <p class="plan-date">Created ${new Date(plan.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
                ${ctaHtml}
              </div>
            `;
          }).join('');
        }
      }
    </script>

    <style>
      .dashboard-wrap {
        max-width: 800px;
        margin: 3rem auto;
      }

      .dashboard-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.5rem;
      }

      .dashboard-intro {
        color: var(--green-light);
        margin-bottom: 2rem;
      }

      .logout-btn {
        padding: 0.5rem 1rem;
        background: transparent;
        border: 2px solid var(--green-lime);
        color: var(--green-lime);
        border-radius: 8px;
        font: inherit;
        font-size: 0.9rem;
        cursor: pointer;
        transition: background 0.15s ease;
      }

      .logout-btn:hover {
        background: var(--green-lime);
        color: var(--green-dark);
      }

      .plans-section h2 {
        margin-bottom: 0.5rem;
      }

      .dashboard-ai-note {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(244, 255, 232, 0.18);
        border-left: 3px solid var(--green-lime);
        border-radius: 10px;
        padding: 0.7rem 0.95rem;
        margin: 0 0 1.25rem;
        font-size: 0.88rem;
        line-height: 1.5;
        color: var(--green-light);
      }

      .dashboard-ai-note strong {
        color: var(--green-lime);
        font-weight: 700;
        margin-right: 0.3rem;
      }

      .dashboard-ai-note a {
        color: var(--green-lime) !important;
        text-decoration: underline !important;
        font-weight: 600;
      }

      .coach-link {
        display: block;
        margin: 0 0 1.5rem;
        padding: 0.75rem 1rem;
        background: rgba(192, 254, 113, 0.15);
        border: 1px solid rgba(192, 254, 113, 0.4);
        border-radius: 10px;
        color: var(--green-lime) !important;
        text-decoration: none !important;
        font-weight: 600;
        font-size: 0.92rem;
        transition: transform 0.15s ease, background 0.15s ease;
      }

      .coach-link strong {
        color: var(--green-lime);
        font-weight: 800;
      }

      .coach-link:hover {
        transform: translateY(-1px);
        background: rgba(192, 254, 113, 0.25);
      }

      .coach-link[hidden] { display: none; }

      .plans-list {
        display: grid;
        gap: 1rem;
      }

     .plans-list .plans-empty a, 
     .plans-list p a {
        color: var(--green-lime) !important;
        text-decoration: underline;
    }

      .plan-card {
        background: #ffffff;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        display: grid;
        gap: 0.5rem;
      }

      .plan-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .plan-type {
        font-weight: 700;
        color: var(--green-dark);
        font-size: 1rem;
      }

      .plan-status {
        font-size: 0.78rem;
        font-weight: 700;
        padding: 0.2rem 0.65rem;
        border-radius: 999px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: rgba(192, 254, 113, 0.2);
        color: var(--green-dark);
      }

      .plan-date {
        color: #666;
        font-size: 0.85rem;
        margin: 0;
      }

      .plan-view-btn {
        display: inline-block;
        margin-top: 0.25rem;
        padding: 0.55rem 1rem;
        background: var(--green-lime);
        color: var(--green-dark) !important;
        font-weight: 700;
        font-size: 0.9rem;
        border-radius: 8px;
        text-decoration: none !important;
        width: fit-content;
      }

      .plan-view-btn:hover {
        background: var(--purple-light);
        color: var(--purple) !important;
      }

      .team-badge {
        display: inline-block;
        margin-left: 0.4rem;
        padding: 0.1rem 0.5rem;
        background: var(--green-lime);
        color: var(--green-dark);
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        border-radius: 999px;
        vertical-align: middle;
      }

      .plan-pending-note {
        display: inline-block;
        margin-top: 0.25rem;
        padding: 0.5rem 0.75rem;
        background: rgba(105, 0, 90, 0.08);
        border-left: 3px solid var(--purple);
        border-radius: 6px;
        color: #555;
        font-size: 0.85rem;
        max-width: 100%;
      }
      
    </style>
  </body>
</html>