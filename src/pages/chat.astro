---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import saoirseImage from '../assets/saoirse.png';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Chat with Saoirse" description="Ask Saoirse questions based on Mind the Gael website content." />
  </head>
  <body>
    <Header />
    <main class="container chat-page">
      <section class="chat-hero">
        <Image src={saoirseImage} alt="Saoirse chatbot" class="chat-hero-image" loading="eager" />
        <div>
          <h1>Chat with Saoirse</h1>
          <p>
            Ask any question about topics covered on Mind the Gael. Saoirse answers using the website's published content and links you to relevant articles.
          </p>
        </div>
      </section>

      <section class="chat-box" aria-live="polite">
        <div class="quick-prompts" role="group" aria-label="Suggested prompts">
          <button type="button" class="quick-prompt" data-prompt="How do I reset my focus after a mistake?">Reset after a mistake</button>
          <button type="button" class="quick-prompt" data-prompt="How can I stop overthinking before a game?">Stop overthinking pre-game</button>
          <button type="button" class="quick-prompt" data-prompt="What should I do when pressure gets too high in key moments?">Handle high-pressure moments</button>
          <a class="quick-prompt quick-prompt-link" href="/resources">Find support resources</a>
        </div>

        <div id="chat-log" class="chat-log">
          <div class="chat-message bot">
            <p><strong>Saoirse:</strong> Hi, I am Saoirse. I can help you steady your mind, reset your focus, and handle pressure one step at a time. Ask me about performance, confidence, anxiety, team dynamics, or support resources.</p>
          </div>
        </div>

        <form id="chat-form" class="chat-form">
          <label for="chat-input" class="visually-hidden">Ask Saoirse a question</label>
          <input id="chat-input" name="chat-input" type="text" placeholder="Type your question here..." required />
          <button type="submit">Ask Saoirse</button>
        </form>
      </section>

      <p class="chat-note">
        Note: This chatbot is educational and cannot provide medical advice. If you are in crisis, go to
        <a href="/resources">Support Resources</a>.
      </p>
    </main>
    <Footer />

    <script>
      // @ts-nocheck
      /** @typedef {{ role: 'user' | 'assistant', content: string }} ChatTurn */
      const chatForm = /** @type {HTMLFormElement | null} */ (document.getElementById('chat-form'));
      const chatInput = /** @type {HTMLInputElement | null} */ (document.getElementById('chat-input'));
      const chatLog = /** @type {HTMLDivElement | null} */ (document.getElementById('chat-log'));
      const quickPromptButtons = /** @type {NodeListOf<HTMLButtonElement>} */ (document.querySelectorAll('button.quick-prompt'));

      /** @type {ChatTurn[]} */
      const history = [];
      /** @type {Map<string, { question: string; reply: string; sourceCount: number; usedModel: boolean }>} */
      const feedbackContextById = new Map();

      function escapeHtml(value) {
        return value
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      /** @param {'user' | 'bot'} role */
      /** @param {string} html */
      function appendMessage(role, html) {
        if (!chatLog) return;
        const wrapper = document.createElement('div');
        wrapper.className = `chat-message ${role}`;
        wrapper.innerHTML = html;
        chatLog.appendChild(wrapper);
        chatLog.scrollTop = chatLog.scrollHeight;
      }

      async function askSaoirse(question) {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message: question,
            history,
          }),
        });

        if (!response.ok) {
          throw new Error('Chat API unavailable');
        }

        return response.json();
      }

      async function sendFeedback(payload) {
        await fetch('/api/chat-feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
      }

      async function submitQuestion(question) {
        if (!chatInput) return;
        const normalizedQuestion = question.trim();
        if (!normalizedQuestion) return;

        history.push({ role: 'user', content: normalizedQuestion });
        appendMessage('user', `<p><strong>You:</strong> ${escapeHtml(normalizedQuestion)}</p>`);

        chatInput.value = '';
        chatInput.disabled = true;
        quickPromptButtons.forEach((button) => {
          button.disabled = true;
        });

        const loadingId = `loading-${Date.now()}`;
        appendMessage('bot', `<p id="${loadingId}"><strong>Saoirse:</strong> Thinking...</p>`);

        try {
          const result = await askSaoirse(normalizedQuestion);
          const loadingNode = document.getElementById(loadingId);
          if (loadingNode) {
            loadingNode.parentElement?.remove();
          }

          const safeReply = escapeHtml(result.reply || 'I am having trouble answering right now.');
          const links = Array.isArray(result.sources)
            ? result.sources
                .slice(0, 3)
                .map((source) => `<li><a href="${source.url}">${escapeHtml(source.title)}</a></li>`)
                .join('')
            : '';

          appendMessage(
            'bot',
            `<p><strong>Saoirse:</strong> ${safeReply}</p>${links ? `<ul class="reply-links">${links}</ul>` : ''}<div class="chat-feedback" data-feedback-id="${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}"><span class="feedback-label">Was this helpful?</span><button type="button" class="feedback-btn" data-feedback-value="helpful" aria-label="This response was helpful">Yes</button><button type="button" class="feedback-btn" data-feedback-value="not-helpful" aria-label="This response was not helpful">No</button><span class="feedback-status" aria-live="polite"></span></div>`
          );
          const feedbackContainers = chatLog ? chatLog.querySelectorAll('.chat-feedback[data-feedback-id]') : [];
          const latestFeedback = feedbackContainers[feedbackContainers.length - 1];
          const feedbackId = latestFeedback?.getAttribute('data-feedback-id');
          if (feedbackId) {
            feedbackContextById.set(feedbackId, {
              question: normalizedQuestion,
              reply: result.reply || '',
              sourceCount: Array.isArray(result.sources) ? result.sources.length : 0,
              usedModel: Boolean(result.usedModel),
            });
          }
          history.push({ role: 'assistant', content: result.reply || '' });
        } catch {
          const loadingNode = document.getElementById(loadingId);
          if (loadingNode) {
            loadingNode.parentElement?.remove();
          }
          appendMessage(
            'bot',
            '<p><strong>Saoirse:</strong> I cannot connect right now. Please try again in a moment.</p>'
          );
        }

        chatInput.disabled = false;
        quickPromptButtons.forEach((button) => {
          button.disabled = false;
        });
        chatInput.focus();
      }

      if (chatForm && chatInput && chatLog) {
        chatForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          await submitQuestion(chatInput.value);
        });

        quickPromptButtons.forEach((button) => {
          button.addEventListener('click', async () => {
            const prompt = button.dataset.prompt || '';
            await submitQuestion(prompt);
          });
        });

        chatLog.addEventListener('click', async (event) => {
          const target = event.target;
          if (!(target instanceof HTMLButtonElement) || !target.classList.contains('feedback-btn')) {
            return;
          }

          const container = target.closest('.chat-feedback');
          if (!(container instanceof HTMLDivElement)) {
            return;
          }

          const feedbackId = container.getAttribute('data-feedback-id') || '';
          const context = feedbackContextById.get(feedbackId);
          if (!feedbackId || !context) {
            return;
          }

          const value = target.dataset.feedbackValue || '';
          const status = container.querySelector('.feedback-status');
          const note = value === 'not-helpful'
            ? (window.prompt('Thanks for telling us. What was missing or unclear? (optional)') || '').trim()
            : '';

          const buttons = container.querySelectorAll('.feedback-btn');
          buttons.forEach((btn) => {
            if (btn instanceof HTMLButtonElement) {
              btn.disabled = true;
            }
          });

          if (status instanceof HTMLElement) {
            status.textContent = 'Saving...';
          }

          try {
            await sendFeedback({
              feedbackId,
              rating: value,
              note,
              question: context.question,
              reply: context.reply,
              sourceCount: context.sourceCount,
              usedModel: context.usedModel,
            });
            if (status instanceof HTMLElement) {
              status.textContent = 'Thanks for your feedback.';
            }
            feedbackContextById.delete(feedbackId);
          } catch {
            if (status instanceof HTMLElement) {
              status.textContent = 'Could not save feedback. Please try again.';
            }
            buttons.forEach((btn) => {
              if (btn instanceof HTMLButtonElement) {
                btn.disabled = false;
              }
            });
          }
        });
      }
    </script>
  </body>
</html>

<style>
  .chat-page {
    padding-top: 1.75rem;
    padding-bottom: 3rem;
  }

  .chat-hero {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .chat-hero-image {
    width: 120px;
    height: 120px;
    object-fit: contain;
    border-radius: 10px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.24);
    flex-shrink: 0;
  }

  .chat-hero h1 {
    margin-bottom: 0.35rem;
  }

  .chat-box {
    border: 2px solid var(--green-lime);
    border-radius: 14px;
    background: rgba(240, 205, 255, 0.08);
    padding: 1rem;
  }

  .quick-prompts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 0.85rem;
  }

  .quick-prompt {
    border: 1px solid rgba(192, 254, 113, 0.55);
    border-radius: 999px;
    background: rgba(192, 254, 113, 0.14);
    color: var(--green-light);
    padding: 0.35rem 0.7rem;
    font-size: 0.85rem;
    line-height: 1.2;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .quick-prompt:hover,
  .quick-prompt:focus-visible {
    background: var(--green-lime);
    color: var(--green-dark);
  }

  .quick-prompt-link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .quick-prompt:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .chat-log {
    max-height: 460px;
    overflow-y: auto;
    padding-right: 0.25rem;
  }

  .chat-message {
    margin-bottom: 0.8rem;
    line-height: 1.45;
  }

  .chat-message.user {
    color: var(--green-light);
  }

  .chat-message.bot {
    color: var(--purple-light);
  }

  .reply-links {
    margin: 0.45rem 0 0 1rem;
  }

  .reply-links a {
    color: var(--green-lime);
    text-decoration: underline;
  }

  .chat-feedback {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.45rem;
  }

  .feedback-label {
    font-size: 0.82rem;
    color: var(--green-light);
  }

  .feedback-btn {
    border: 1px solid rgba(192, 254, 113, 0.55);
    background: rgba(192, 254, 113, 0.12);
    color: var(--green-light);
    border-radius: 999px;
    padding: 0.18rem 0.58rem;
    font-size: 0.78rem;
    cursor: pointer;
  }

  .feedback-btn:hover,
  .feedback-btn:focus-visible {
    background: var(--green-lime);
    color: var(--green-dark);
  }

  .feedback-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  .feedback-status {
    font-size: 0.78rem;
    color: var(--purple-light);
  }

  .chat-form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.6rem;
    margin-top: 0.7rem;
  }

  .chat-form input {
    border: 2px solid var(--green-lime);
    border-radius: 10px;
    background: #fff;
    color: #111;
    padding: 0.68rem 0.8rem;
    font-size: 1rem;
  }

  .chat-form button {
    border: 2px solid var(--green-lime);
    border-radius: 10px;
    background: var(--green-lime);
    color: #111;
    font-weight: 700;
    cursor: pointer;
    padding: 0.68rem 1rem;
  }

  .chat-form button:hover {
    background: var(--purple-light);
  }

  .chat-note {
    margin-top: 0.9rem;
    font-size: 0.92rem;
    color: var(--purple-light);
  }

  .chat-note a {
    color: var(--green-lime);
    text-decoration: underline;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 720px) {
    .chat-page {
      padding-top: 1.1rem;
    }

    .chat-hero {
      align-items: flex-start;
      gap: 0.8rem;
    }

    .chat-hero-image {
      width: 84px;
      height: 84px;
    }

    .chat-hero h1 {
      font-size: 1.5rem;
      line-height: 1.2;
    }

    .chat-box {
      padding: 0.75rem;
    }

    .quick-prompts {
      gap: 0.35rem;
      margin-bottom: 0.7rem;
    }

    .quick-prompt {
      font-size: 0.8rem;
      padding: 0.32rem 0.6rem;
    }

    .chat-log {
      max-height: 52vh;
    }

    .chat-form {
      grid-template-columns: 1fr;
    }

    .chat-form button {
      width: 100%;
    }
  }
</style>
