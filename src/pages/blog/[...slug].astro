---
export async function getStaticPaths() {
  const posts = import.meta.glob('../../content/blog/**/*.md');

  return Object.keys(posts).map((file) => {
    const slug = file
      .replace('../../content/blog/', '')
      .replace('.md', '');

    return {
      params: { slug },
    };
  });
}

// ✅ define AGAIN for page usage (Astro requires this)
const posts = import.meta.glob('../../content/blog/**/*.md');

const slug = Astro.params.slug;

const post = posts[`../../content/blog/${slug}.md`];

if (!post) {
  throw new Error(`Post not found: ${slug}`);
}

const { default: Content } = await post();
---

<article>
  <Content />
</article>