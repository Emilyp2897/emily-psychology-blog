---
import fs from 'fs';
import path from 'path';

const slugArray = Astro.params.slug;
const filePath = path.join(import.meta.env.PROJECT_ROOT, 'content/blog', ...slugArray) + '.md';

let content = 'Post not found';
try {
  content = fs.readFileSync(filePath, 'utf-8');
} catch (e) {}
---

<article>
  <astro:markdown>
    {content}
  </astro:markdown>
</article>