---
import fs from 'fs';
import path from 'path';

// 1️⃣ Helper function must be defined BEFORE getStaticPaths
function getFiles(dir) {
  return fs.readdirSync(dir).flatMap(file => {
    const fullPath = path.join(dir, file);
    if (fs.statSync(fullPath).isDirectory()) return getFiles(fullPath);
    if (file.endsWith('.md')) return fullPath;
    return [];
  });
}

const contentDir = path.resolve('./content/blog');

// 2️⃣ Export getStaticPaths for all markdown files
export async function getStaticPaths() {
  const files = getFiles(contentDir);

  return files.map(file => {
    const relative = path.relative(contentDir, file); // e.g., training-the-mind/driver-theory.md
    const slug = relative.replace(/\.md$/, '').split(path.sep);
    return { params: { slug } };
  });
}

// 3️⃣ Load markdown for current page
const slugArray = Astro.params.slug;
const filePath = path.join(contentDir, ...slugArray) + '.md';

let content = 'Post not found';
try {
  content = fs.readFileSync(filePath, 'utf-8');
} catch (e) {}
---

<article>
  <astro:markdown>
    {content}
  </astro:markdown>
</article>