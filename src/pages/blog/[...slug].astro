---
import fs from 'fs';
import path from 'path';
import { Markdown } from '@astrojs/markdown-remark';

const slugArray = Astro.params.slug; // e.g., ["training-the-mind", "driver-theory"]
const filePath = path.join(import.meta.env.PROJECT_ROOT, 'content/blog', ...slugArray) + '.md';

let content = 'Post not found';
try {
  content = fs.readFileSync(filePath, 'utf-8');
} catch (e) {}
---

<article>
  <Markdown content={content} />
</article>