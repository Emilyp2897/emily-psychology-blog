---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// get all blog posts
const allPosts = await getCollection('blog');

// explicit order of series
const seriesSlugs = [
  'training-the-mind',
  'gael-performance-toolkit/gael-performance-toolkit',
  'strong-minds-stronger-players/strong-minds-stronger-players'
];

// map slugs to posts in that exact order
const posts = seriesSlugs
  .map(slug => allPosts.find(post => post.slug === slug))
  .filter(Boolean);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">

      <section class="hero">
        <h1>The Blog</h1>
        <p class="tagline">Evidence-based reads for women in sport.</p>
      </section>

      <section class="posts">
        <ul>
          {posts.map(post => (
            <li>
              <a href={`/blog/${post.slug}/`}>
                <h2 class="title">{post.data.title}</h2>
                <p class="date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                {post.data.description && <p class="description">{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    color: var(--green-lime);
  }

  h2 {
    color: var(--green-lime);
  }

  .posts ul {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    padding: 0;
    list-style: none;
    justify-content: center;
    margin-bottom: 4rem;
  }

  .posts li {
    flex: 1;
    max-width: 350px;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .posts li:hover {
    transform: translateY(-5px);
    border-color: var(--purple-light);
  }

  .posts li a {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .posts li .title {
    color: var(--green-lime);
    margin-bottom: 1rem;
    font-size: 1.4em;
  }

  .posts li .date {
    color: var(--green-light);
    font-size: 0.9em;
    margin-bottom: 1rem;
  }

  .posts li .description {
    color: var(--green-light);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .posts ul {
      flex-direction: column;
      align-items: center;
    }

    .posts li {
      max-width: 100%;
      width: 100%;
    }
  }
</style>