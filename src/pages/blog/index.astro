---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// get all blog posts
const allPosts = await getCollection('blog');

// explicit order of series
const seriesSlugs = [
  'training-the-mind/training-the-mind',
  'gael-performance-toolkit/gael-performance-toolkit',
  'strong-minds-stronger-players/strong-minds-stronger-players'
];

// map slugs to posts in that exact order
const posts = seriesSlugs
  .map(slug => allPosts.find(post => post.slug === slug))
  .filter(Boolean);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">

      <section class="hero">
        <h1>The Blog</h1>
        <p class="tagline">Evidence-based reads for women in sport.</p>
      </section>

      <section class="posts">
        <ul>
          {posts.map(post => (
            <li>
              <a href={`/blog/${post.slug}/`}>
                <h2 class="title">{post.data.title}</h2>
                <p class="date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                {post.data.description && <p class="description">{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <Footer />
  </body>
</html>