---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const seriesCards = [
  {
    title: 'Training the Mind',
    description: 'Explore the mental side of performance with short, relatable posts built for female athletes.',
    href: '/blog/training-the-mind/',
  },
  {
    title: 'Gael Performance Toolkit',
    description: 'Practical, in-the-moment tools you can use before and during games when pressure rises.',
    href: '/blog/gael-performance-toolkit/',
  },
  {
    title: 'Stronger Minds, Stronger Players',
    description: 'Understand mental health in sport, recognise warning signs, and know where to get support.',
    href: '/blog/strong-minds-stronger-players/strong-minds-stronger-players/',
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>

  <body>
    <Header />

    <main class="container">

      <section class="hero fade-in">
        <h1>Inside The Inner Locker Room</h1>
        <p class="tagline">For the moments before the game, after the mistake, and everything in between</p>
      </section>

      <section class="posts">
        <ul>
          {seriesCards.map((card) => (
            <li class="fade-in">
              <a href={card.href}>
                <h2 class="title">{card.title}</h2>
                <p class="description">{card.description}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="subscribe-cta fade-in">
        <a href="#subscriptions" class="subscribe-cta-link">
          <img src="/assets/saoirse.png" class="subscribe-cta-img" />
        </a>
      </section>

      <section id="subscriptions" class="subscriptions fade-in">
        <h2>Subscriptions</h2>
        <p class="subscriptions-copy">Choose your plan and complete checkout on our subscription page.</p>
        <a href="/subscribe" class="subscriptions-main-cta">Subscribe Now</a>
      </section>

    </main>

    <Footer />

    <!-- fade animation -->
    <script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".fade-in").forEach((el, index) => {
      setTimeout(() => el.classList.add("show"), index * 90);
    });
  });
</script>


  </body>
</html>

<style>
  h1, h2 {
    color: var(--green-lime);
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .tagline {
    color: var(--green-light);
    font-size: 1.1rem;
  }

  .posts ul {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    padding: 0;
    list-style: none;
    justify-content: center;
    margin-bottom: 4rem;
  }

  .posts li {
    flex: 1;
    max-width: 350px;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .posts li:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: var(--purple-light);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  .posts li a {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .posts li .title {
    margin-bottom: 1rem;
    font-size: 1.4em;
  }

  .posts li .description {
    color: var(--green-light);
    line-height: 1.6;
  }

  .subscribe-cta {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .subscribe-cta-link {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--green-lime);
    gap: 0.5rem;
  }

  .subscribe-cta-img {
    width: 90px;
    height: 90px;
    transition: transform 0.2s ease;
  }

  .subscribe-cta-link:hover .subscribe-cta-img {
    transform: translateY(-4px) scale(1.04);
  }

  .subscriptions {
    margin-bottom: 4rem;
    text-align: center;
  }

  .subscriptions h2 {
    margin-bottom: 0.75rem;
  }

  .subscriptions-copy {
    color: var(--green-light);
    margin-bottom: 1rem;
  }

  .subscriptions-main-cta {
    display: inline-block;
    padding: 0.75rem 1.3rem;
    border-radius: 8px;
    background: var(--green-lime);
    color: var(--green-dark);
    font-weight: 700;
    border: 2px solid var(--green-lime);
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .subscriptions-main-cta:hover {
    transform: translateY(-1px);
    border-color: var(--purple-light);
    color: var(--purple);
  }

  .fade-in {
    opacity: 1;
    transform: none;
    transition: all 0.6s ease;
  }

  .fade-in.show {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .posts ul {
      flex-direction: column;
      align-items: center;
    }

    .posts li {
      max-width: 100%;
      width: 100%;
    }

  }
</style>