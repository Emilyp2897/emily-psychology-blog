---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// get all blog posts
const allPosts = await getCollection('blog');

// explicit order of series
const seriesSlugs = [
  'training-the-mind/training-the-mind',   // 1️⃣ show first
  'gael-performance-toolkit',               // 2️⃣ second
  'strong-minds-stronger-players'          // 3️⃣ third
];

// map slugs to posts in that exact order
const posts = seriesSlugs
  .map(slug => allPosts.find(post => post.slug === slug))
  .filter(Boolean); // remove any missing posts just in case
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <section class="hero">
        <h1>The Blog</h1>
        <p class="tagline">Evidence-based reads for women in sport.</p>
      </section>

      <section class="posts">
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}/`}>
                <h2 class="title">{post.data.title}</h2>
                <p class="date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                {post.data.description && <p class="description">{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  body {
    background-color: #030a06;
    color: #f4ffe8;
    font-family: Georgia, serif;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    line-height: 1.7;
  }

  h1 {
    color: #c0fe71;
    font-size: 3rem;
    margin-bottom: 0.25rem;
  }

  .tagline {
    color: #f0cdff;
    font-size: 1.2rem;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .posts ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .posts li a {
    display: block;
    text-decoration: none;
    border-left: 3px solid #c0fe71;
    padding-left: 1.2rem;
    transition: border-color 0.2s ease;
  }

  .posts li a:hover {
    border-color: #f0cdff;
  }

  .title {
    color: #c0fe71;
    font-size: 1.4rem;
    margin: 0 0 0.25rem 0;
  }

  .posts li a:hover .title {
    color: #f0cdff;
  }

  .date {
    color: #a0b89a;
    font-size: 0.9rem;
    margin: 0 0 0.5rem 0;
  }

  .description {
    color: #f4ffe8;
    margin: 0;
    font-size: 1rem;
  }
</style>