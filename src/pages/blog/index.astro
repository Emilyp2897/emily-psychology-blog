---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// get all blog posts
const allPosts = await getCollection('blog');

// explicit order of series
const seriesSlugs = [
  'training-the-mind',
  'gael-performance-toolkit/gael-performance-toolkit',
  'strong-minds-stronger-players/strong-minds-stronger-players'
];

// map slugs to posts in that exact order
const posts = seriesSlugs
  .map(slug => allPosts.find(post => post.slug === slug))
  .filter(Boolean);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main class="container">

      <section class="hero fade-in">
        <h1>Inside The Inner Locker Room</h1>
        <p class="tagline">For the moments before the game, after the mistake, and everything in between</p>
      </section>

      <section class="posts">
        <ul>
          {posts.map(post => (
            <li class="fade-in">
              <a href={`/blog/${post.slug}/`}>
                <h2 class="title">{post.data.title}</h2>
                <p class="date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                {post.data.description && (
                  <p class="description">{post.data.description}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <Footer />

    <!-- Scroll Animation Script -->
    <script is:inline>
      const elements = document.querySelectorAll('.fade-in');

      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('show');
          }
        });
      });

      elements.forEach(el => observer.observe(el));
    </script>

  </body>
</html>

<style>
  /* Page spacing */
  body {
    padding: 40px;
  }

  h1, h2 {
    color: var(--green-lime);
  }

  /* HERO */
  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .tagline {
    color: var(--green-light);
    font-size: 1.1rem;
  }

  /* POSTS LAYOUT */
  .posts ul {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    padding: 0;
    list-style: none;
    justify-content: center;
    margin-bottom: 4rem;
  }

  /* CARD STYLE */
  .posts li {
    flex: 1;
    max-width: 350px;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    padding: 2rem;

    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  /* HOVER EFFECT */
  .posts li:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: var(--purple-light);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  /* MAKE FULL CARD CLICKABLE */
  .posts li a {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* TEXT STYLING */
  .posts li .title {
    margin-bottom: 1rem;
    font-size: 1.4em;
  }

  .posts li .date {
    color: var(--green-light);
    font-size: 0.9em;
    margin-bottom: 1rem;
  }

  .posts li .description {
    color: var(--green-light);
    line-height: 1.6;
  }

  /* FADE-IN ANIMATION */
  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
  }

  .fade-in.show {
    opacity: 1;
    transform: translateY(0);
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .posts ul {
      flex-direction: column;
      align-items: center;
    }

    .posts li {
      max-width: 100%;
      width: 100%;
    }
  }
</style>