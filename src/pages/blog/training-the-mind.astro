---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// Get all training-the-mind child posts (excluding the main series page)
const allPosts = await getCollection('blog');

const childPosts = allPosts.filter((post) =>
  post.slug.startsWith('training-the-mind/') &&
  post.slug !== 'training-the-mind/training-the-mind' &&
  post.slug !== 'training-the-mind/training-the-mind-fixed'
);

// Sort them by date (newest first)
childPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">
      <section class="hero">
        <h1>Training the Mind</h1>
      </section>

      <div class="prose">
        <p>This is a 12-month journey through key sports psychology concepts, designed specifically for female athletes.

        <p>Each month explores a different theme, starting with understanding pressure in performance and how it affects your thoughts, focus, and decision-making before the game, after mistakes, and in high-pressure moments.</p>

        <p>Each post is quick to read and easy to understand, giving you practical insight into your mind so you can build confidence, consistency, and control when it matters most.</p>

        <p>Explore the topics below to follow the journey and start making sense of your thoughts, reactions, and performance.</p>
      </div>

      <section class="posts">
        <h2>Month 1 - Understanding Pressure in Performance</h2>
        <input
          type="text"
          id="search-posts"
          placeholder="Search posts..."
          style="width: 100%; max-width: 400px; margin: 1.5rem 0 2rem 0; display: block; padding: 0.7em 1em; border-radius: 8px; border: 1px solid var(--green-lime); font-size: 1.1em; background: #181818; color: var(--green-light); text-align: left;"
          oninput="filterPosts()"
        />
        <ul id="posts-list">
          {childPosts.map((post) => (
            <li class="fade-in card">
              <a href={`/blog/${post.slug}/`}>
                <h2 class="title">{post.data.title}</h2>
                {post.data.description && (
                  <p class="description">{post.data.description}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
    <script is:inline>
      // 3D Card Hover Effect (delegated for dynamic content)
      function setup3DHover() {
        document.querySelectorAll('.card').forEach(card => {
          card.onmousemove = (e) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const rotateX = ((y - centerY) / centerY) * 15; // increased max tilt
            const rotateY = ((x - centerX) / centerX) * 25; // increased max tilt
            card.style.transform = `perspective(1000px) rotateX(${-rotateX}deg) rotateY(${rotateY}deg)`;
          };
          card.onmouseleave = () => {
            card.style.transform = 'perspective(1000px)';
          };
        });
      }
      setup3DHover();
      // Re-run after search filter
      function filterPosts() {
        const input = document.getElementById('search-posts');
        const filter = input.value.toLowerCase();
        const ul = document.getElementById('posts-list');
        const lis = ul.getElementsByTagName('li');
        for (let i = 0; i < lis.length; i++) {
          const title = lis[i].querySelector('.title').textContent.toLowerCase();
          const desc = lis[i].querySelector('.description')?.textContent.toLowerCase() || '';
          if (title.includes(filter) || desc.includes(filter)) {
            lis[i].style.display = '';
          } else {
            lis[i].style.display = 'none';
          }
        }
        setup3DHover();
      }
    </script>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  /* Removed .series-posts styles to use .posts styles from global.css */

  h1 {
    color: var(--green-lime);
  }

  h2 {
    color: var(--green-lime);
  }

  /* POSTS LAYOUT */
  .posts ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    padding: 0;
    list-style: none;
    justify-content: center;
    margin-bottom: 4rem;
    width: 100%;
    max-width: 1200px;
  }

  @media (min-width: 900px) {
    .posts ul {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* CARD STYLE */
  .posts li {
    flex: 1;
    max-width: 350px;
    background-color: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    padding: 2rem;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  /* HOVER EFFECT */
  .posts li:hover {
    /* transform: translateY(-10px) scale(1.02); */
    border-color: var(--purple-light);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  }

  /* MAKE FULL CARD CLICKABLE */
  .posts li a {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* TEXT STYLING */
  .posts li .title {
    margin-bottom: 1rem;
    font-size: 1.4em;
  }

  .posts li .description {
    color: var(--green-light);
    line-height: 1.6;
  }

  /* FADE-IN ANIMATION */
  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
  }

  .fade-in.show {
    opacity: 1;
    transform: translateY(0);
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .posts ul {
      flex-direction: column;
      align-items: center;
    }
    .posts li {
      max-width: 100%;
      width: 100%;
    }
  }

  /* 3D HOVER EFFECT */
  .posts li.card {
    perspective: 1000px;
    transition:
      transform 0.3s cubic-bezier(.25,.8,.25,1),
      box-shadow 0.3s cubic-bezier(.25,.8,.25,1);
    will-change: transform;
    /* Remove conflicting transform from .posts li:hover */
  }

  .posts li.card:hover {
    /* No transform here, JS handles it */
    box-shadow: 0 25px 50px rgba(0,0,0,0.2);
    border-color: var(--purple-light);
  }
</style>

<!-- Scroll Animation Script -->
    <script is:inline>
      const elements = document.querySelectorAll('.fade-in');
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('show');
          }
        });
      });
      elements.forEach(el => observer.observe(el));
    </script>