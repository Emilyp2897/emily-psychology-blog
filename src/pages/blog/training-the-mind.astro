---
import fs from 'fs';
import path from 'path';

const filePath = path.resolve('.src/content/blog/training-the-mind/training-the-mind.md');
const content = fs.readFileSync(filePath, 'utf-8');

const folderPath = path.resolve('.src/content/blog/training-the-mind');
const childFiles = fs.readdirSync(folderPath).filter(f => f !== 'training-the-mind.md');
---

<article>
  <astro:markdown>
    {content}
  </astro:markdown>
</article>

<h2>Other posts in this series:</h2>
<ul>
  {childFiles.map(file => {
    const slug = file.replace('.md', '');
    return (
      <li>
        <a href={`/blog/training-the-mind/${slug}`}>{slug.replace(/-/g, ' ')}</a>
      </li>
    );
  })}
</ul>