---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container contact-main">
      <section class="contact-intro">
        <h1>Contact Us</h1>
        <p class="intro-copy">If you are reaching out about personal training, workshops, collaboration, or general questions, we would love to hear from you.</p>
      </section>

      <section class="contact-grid" aria-label="Contact options">
        <article class="contact-card">
          <h2>Email</h2>
          <p class="contact-value">emilyphelan@mindthegael.co.uk</p>
          <p class="contact-copy">Best for bookings, collaborations, and detailed queries.</p>
          <a class="contact-btn" href="mailto:emilyphelan@mindthegael.co.uk">Send Email</a>
        </article>

        <article class="contact-card">
          <h2>Instagram</h2>
          <p class="contact-value">@mind_the_gael</p>
          <p class="contact-copy">Follow updates and send a direct message.</p>
          <a class="contact-btn" href="https://instagram.com/mind_the_gael" target="_blank" rel="noopener noreferrer">Open Instagram</a>
        </article>

        <article class="contact-card contact-card-wide">
          <h2>Phone</h2>
          <p class="contact-value">+44 7425 814858</p>
          <p class="contact-copy">For quicker contact, you can call directly.</p>
          <a class="contact-btn" href="tel:+447425814858">Call Now</a>
        </article>
      </section>

      <section class="consultation-section" aria-labelledby="consultation-heading">
        <h2 id="consultation-heading">Initial Consultation Form</h2>
        <p class="consultation-copy">Share a few details below and your response will open as an email draft, ready to send.</p>

        <form id="consultation-form" class="consultation-form">
          <div class="form-grid">
            <label>
              Full Name
              <input type="text" name="name" required />
            </label>

            <label>
              Email
              <input type="email" name="email" required />
            </label>

            <label>
              Phone (optional)
              <input type="tel" name="phone" />
            </label>

            <label>
              Sport / Team
              <input type="text" name="sport" required />
            </label>

            <label>
              Preferred Contact Method
              <select name="contactMethod" required>
                <option value="">Select one</option>
                <option value="Email">Email</option>
                <option value="Phone">Phone</option>
                <option value="Instagram">Instagram</option>
              </select>
            </label>

            <label>
              Preferred Time to Talk
              <input type="text" name="preferredTime" placeholder="e.g. weekday evenings" />
            </label>

            <label class="full-width">
              What would you like support with?
              <textarea name="goals" rows="5" required></textarea>
            </label>
          </div>

          <label class="consent-row">
            <input type="checkbox" name="consent" required />
            <span>I consent to being contacted about my consultation request.</span>
          </label>

          <button type="submit" class="contact-btn consultation-submit">Create Consultation Email</button>
        </form>
      </section>

      <section class="support-note">
        <p>If you need urgent mental health support, please visit our <a href="/resources">Support Resources page</a> for professional services. If you are in immediate danger, call emergency services on 112 or 999.</p>
      </section>
    </main>
    <Footer />

    <script is:inline>
      const consultationForm = document.getElementById('consultation-form');

      if (consultationForm instanceof HTMLFormElement) {
        consultationForm.addEventListener('submit', (event) => {
          event.preventDefault();

          const formData = new FormData(consultationForm);
          const name = String(formData.get('name') || '').trim();
          const email = String(formData.get('email') || '').trim();
          const phone = String(formData.get('phone') || '').trim();
          const sport = String(formData.get('sport') || '').trim();
          const contactMethod = String(formData.get('contactMethod') || '').trim();
          const preferredTime = String(formData.get('preferredTime') || '').trim();
          const goals = String(formData.get('goals') || '').trim();

          const subject = encodeURIComponent('Initial Consultation Request - Mind the Gael');
          const body = encodeURIComponent(
            `Initial Consultation Request\n\n` +
            `Name: ${name}\n` +
            `Email: ${email}\n` +
            `Phone: ${phone || 'Not provided'}\n` +
            `Sport / Team: ${sport}\n` +
            `Preferred Contact Method: ${contactMethod}\n` +
            `Preferred Time to Talk: ${preferredTime || 'Not provided'}\n\n` +
            `Support Needed:\n${goals}`
          );

          window.location.href = `mailto:emilyphelan@mindthegael.co.uk?subject=${subject}&body=${body}`;
        });
      }
    </script>
  </body>
</html>

<style>
  .contact-main {
    padding-top: 0;
    padding-bottom: 2.5rem;
  }

  .contact-intro {
    margin: 0 calc(50% - 50vw) 1rem;
    padding: 2rem max(1rem, calc(50vw - 600px));
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
  }

  h1 {
    color: var(--green-lime);
    font-size: 2rem;
    margin: 0.25rem 0 0.45rem;
  }

  .intro-copy {
    margin: 0;
    max-width: 62ch;
    color: var(--green-light);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .contact-card {
    border: 2px solid rgba(105, 0, 90, 0.24);
    border-radius: 12px;
    background: linear-gradient(180deg, rgba(240, 205, 255, 0.9) 0%, rgba(244, 255, 232, 0.9) 100%);
    padding: 1.1rem;
  }

  .contact-card-wide {
    grid-column: span 2;
  }

  h2 {
    margin: 0 0 0.4rem;
    color: var(--purple);
    font-size: 1.25rem;
  }

  .contact-value {
    margin: 0;
    color: var(--green-dark);
    font-weight: 700;
    word-break: break-word;
  }

  .contact-copy {
    margin: 0.6rem 0 0.8rem;
    color: var(--green-dark);
  }

  .contact-btn {
    display: inline-block;
    padding: 0.7rem 1.1rem;
    border-radius: 6px;
    border: 2px solid transparent;
    background: var(--green-lime);
    color: var(--green-dark);
    font-weight: 700;
    font: inherit;
    line-height: 1.2;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .contact-btn:hover {
    background: var(--purple-light);
    border-color: var(--purple);
    color: var(--green-dark);
  }

  .support-note {
    margin-top: 2rem;
    padding: 1rem 1.2rem;
    border-radius: 10px;
    border: 1px solid rgba(105, 0, 90, 0.3);
    background: linear-gradient(180deg, rgba(240, 205, 255, 0.9) 0%, rgba(244, 255, 232, 0.9) 100%);
    color: var(--green-dark);
  }

  .support-note p {
    margin: 0;
  }

  .support-note a {
    color: var(--green-lime);
    text-decoration: underline;
    font-weight: 700;
  }

  .consultation-section {
    margin-top: 1.3rem;
    border: 2px solid rgba(105, 0, 90, 0.24);
    border-radius: 12px;
    background: linear-gradient(180deg, rgba(105, 0, 90, 0.82) 0%, rgba(105, 0, 90, 0.64) 100%);
    padding: 1.25rem;
  }

  .consultation-section h2 {
    margin: 0;
    color: var(--green-lime);
    font-size: 1.25rem;
  }

  .consultation-copy {
    margin: 0.55rem 0 1.1rem;
    color: var(--green-light);
  }

  .consultation-form {
    display: grid;
    gap: 1rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .consultation-form label {
    display: grid;
    gap: 0.45rem;
    color: var(--green-light);
    font-weight: 600;
    font-size: 0.9rem;
    border: 1px solid rgba(192, 254, 113, 0.26);
    border-radius: 10px;
    padding: 0.65rem 0.7rem 0.72rem;
    background: rgba(3, 10, 6, 0.34);
  }

  .consultation-form input,
  .consultation-form select,
  .consultation-form textarea {
    width: 100%;
    border-radius: 8px;
    border: 1px solid rgba(105, 0, 90, 0.35);
    background: rgba(255, 255, 255, 0.92);
    color: #121212;
    padding: 0.64rem 0.72rem;
    font: inherit;
  }

  .consultation-form input::placeholder,
  .consultation-form textarea::placeholder {
    color: #505050;
  }

  .consultation-form input:focus,
  .consultation-form select:focus,
  .consultation-form textarea:focus {
    outline: 2px solid var(--green-lime);
    outline-offset: 1px;
    border-color: var(--green-lime);
  }

  .consultation-form textarea {
    resize: vertical;
    min-height: 120px;
  }

  .full-width {
    grid-column: span 2;
  }

  .consent-row {
    display: flex !important;
    align-items: center;
    gap: 0.55rem;
    font-weight: 500 !important;
    border: 1px solid rgba(192, 254, 113, 0.26);
    border-radius: 10px;
    padding: 0.65rem 0.7rem;
    background: rgba(3, 10, 6, 0.34);
  }

  .consent-row input {
    width: auto;
    margin: 0;
  }

  .consultation-submit {
    justify-self: start;
    cursor: pointer;
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-card-wide {
      grid-column: span 1;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .full-width {
      grid-column: span 1;
    }
  }
</style>
