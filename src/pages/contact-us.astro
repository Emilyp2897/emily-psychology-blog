---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>Instagram</h1>
        <p class="tagline">TBD</p>

        <h1>Email</h1>
        <p class="tagline">TBD</p>

        <h1>Phone</h1>
        <p class="tagline">TBD</p>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  body {
    background-color: #030a06;
    color: #f4ffe8;
    font-family: Georgia, serif;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    line-height: 1.7;
  }

  h1 {
    color: #c0fe71;
    font-size: 3rem;
    margin-bottom: 0.25rem;
  }

  h2 {
    color: #c0fe71;
    font-size: 1.5rem;
    margin-top: 2rem;
  }

  .tagline {
    color: #f0cdff;
    font-size: 1.2rem;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .resources p {
    color: #f4ffe8;
    margin-bottom: 1.2rem;
  }

  .closing {
    color: #f0cdff;
    font-style: italic;
    font-size: 1.05rem;
  }
</style>
