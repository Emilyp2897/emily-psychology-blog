---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Choose Subscription | ${SITE_TITLE}`} description="Choose an individual or team subscription." />
  </head>
  <body>
    <Header />
    <main class="container">
      <section class="hero">
        <h1>Choose Your Subscription</h1>
        <p>Select the plan that fits you best.</p>
      </section>

      <section class="plans">
        <article class="plan-card">
          <h2>Individual</h2>
          <p class="price">£6.99</p>
          <p>Access all individual subscriber content.</p>
          <a class="plan-cta" href="/api/create-checkout-session?plan=individual">Subscribe Now</a>
        </article>

        <article class="plan-card">
          <h2>Team</h2>
          <p class="price">£200</p>
          <p>Get access for your full team.</p>
          <a class="plan-cta" href="/api/create-checkout-session?plan=team">Subscribe Now</a>
        </article>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    text-align: center;
    margin: 2rem 0 2.5rem;
  }

  .plans {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .plan-card {
    background: rgba(240, 205, 255, 0.1);
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .price {
    color: var(--green-lime);
    font-size: 2rem;
    font-weight: 700;
    margin: 0.3rem 0 0.75rem;
  }

  .plan-cta {
    display: inline-block;
    margin-top: 0.7rem;
    background: var(--green-lime);
    color: var(--green-dark);
    padding: 0.55rem 0.95rem;
    border-radius: 8px;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .plans {
      grid-template-columns: 1fr;
    }
  }
</style>