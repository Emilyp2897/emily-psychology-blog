---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type BlogPostData = CollectionEntry<'blog'>['data'];

interface Props extends BlogPostData {
  postSlug?: string;
}

const { title, description, pubDate, updatedDate, postSlug } = Astro.props as Props;

const sectionRoutes: Record<string, { title: string; href: string }> = {
  'training-the-mind': {
    title: 'Training the Mind',
    href: '/content-hub/training-the-mind/',
  },
  'gael-performance-toolkit': {
    title: 'Gael Performance Toolkit',
    href: '/content-hub/gael-performance-toolkit/',
  },
  'strong-minds-stronger-players': {
    title: 'Strong Minds, Stronger Players',
    href: '/content-hub/strong-minds-stronger-players/',
  },
};

const sectionSlug = postSlug?.split('/')[0];
const sectionMeta = sectionSlug ? sectionRoutes[sectionSlug] : undefined;
const isGaelToolkitPost = sectionSlug === 'gael-performance-toolkit';
const isSmspPost = sectionSlug === 'strong-minds-stronger-players';

// SMSP is always free — no subscription required — but the series
// is not ready for public launch yet. Flip this to false once SMSP
// content is finalised and ready to publish.
const SMSP_COMING_SOON = true;

const shouldBypassSubscriptionGate = import.meta.env.DEV;
const showComingSoonGate = isSmspPost && SMSP_COMING_SOON && !shouldBypassSubscriptionGate;
// Subscription gate now applies to NON-SMSP posts only. SMSP either
// shows the coming-soon gate (if locked) or no gate at all once it's
// open to readers.
const showSubscriptionGate = !isSmspPost && !shouldBypassSubscriptionGate;
const contentIsLocked = showSubscriptionGate || showComingSoonGate;

const toolkitRelatedArticles = new Set([
  'training-the-mind/attention-control-theory',
  'training-the-mind/choking-under-pressure',
]);

const showToolkitToolsBox = postSlug ? toolkitRelatedArticles.has(postSlug) : false;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class:list={["blog-post-page", isGaelToolkitPost && "gael-toolkit-post"]}>
    <Header />

    <main class="container article-main">
      <section class="article-hero">
        <p class="article-kicker">Content Hub Article</p>
        <h1>{title}</h1>
        <div class="article-meta">
          <p>
            Published <FormattedDate date={pubDate} />
          </p>
          {updatedDate && (
            <p>
              Updated <FormattedDate date={updatedDate} />
            </p>
          )}
          {sectionMeta && (
            <p>
              <a href={sectionMeta.href} class="section-link">Back to {sectionMeta.title}</a>
            </p>
          )}
        </div>
      </section>

      <article class="article-shell">
        {showSubscriptionGate && (
          <div id="subscription-gate" class="subscription-gate">
            <h2>Subscribe to Keep Reading</h2>
            <p>This article is for subscribers. Join now to unlock full access.</p>
            <a href="/api/create-checkout-session?plan=individual" class="gate-cta">Subscribe Now</a>
          </div>
        )}

        {showComingSoonGate && (
          <div class="coming-soon-gate">
            <p class="coming-soon-eyebrow">Coming soon</p>
            <h2>Strong Minds, Stronger Players is launching soon</h2>
            <p>This series is always free for every player and coach. We are finalising the content with our expert panel before opening it up. Check back closer to launch.</p>
            <a href="/content-hub/strong-minds-stronger-players/" class="gate-cta gate-cta-back">Back to the series</a>
          </div>
        )}

        <div id="paid-content" class:list={["paid-content prose", contentIsLocked && "is-locked"]}>
          <slot />

          {showToolkitToolsBox && (
            <section class="toolkit-tools-box" aria-label="Related practical tools">
              <p class="toolkit-tools-title">Looking for practical tools to use this in real matches?</p>
              <p class="toolkit-tools-copy">Go to the Gael Performance Toolkit for practical tools related to this article.</p>
              <a href="/content-hub/gael-performance-toolkit/" class="toolkit-tools-link">Open Gael Performance Toolkit</a>
            </section>
          )}

          <section class="content-feedback-link-box">
            <p>Have feedback on this content?</p>
            <a href="/content-feedback" class="content-feedback-link">Share feedback</a>
          </section>
        </div>
      </article>
    </main>

    <Footer />

    <script is:inline define:vars={{ shouldBypassSubscriptionGate, isGaelToolkitPost }}>
      window.addEventListener('DOMContentLoaded', () => {
        const paidContent = document.getElementById('paid-content');
        const toolkitToolsBox = paidContent?.querySelector('.toolkit-tools-box');

        if (paidContent && isGaelToolkitPost) {
          const headings = Array.from(paidContent.querySelectorAll('h2'));
          const toolHeadings = headings.filter((heading) => {
            const text = heading.textContent?.trim().toLowerCase() || '';
            return text.startsWith('tool ');
          });

          toolHeadings.forEach((heading) => {
            const card = document.createElement('section');
            card.className = 'toolkit-tool-card';
            heading.parentNode?.insertBefore(card, heading);
            card.appendChild(heading);

            let node = card.nextSibling;
            while (node) {
              if (node.nodeType === Node.ELEMENT_NODE) {
                const el = node;
                if (el.tagName === 'H2') break;
              }
              const next = node.nextSibling;
              card.appendChild(node);
              node = next;
            }
          });
        }

        if (paidContent && toolkitToolsBox) {
          const referencesHeading = Array.from(paidContent.querySelectorAll('h2, h3')).find((heading) =>
            heading.textContent?.trim().toLowerCase() === 'references'
          );

          if (referencesHeading) {
            paidContent.insertBefore(toolkitToolsBox, referencesHeading);
          }
        }

        // Style the paragraph immediately before the References heading as a
        // purple banner IF it contains a link to the Gael Performance Toolkit.
        // The wording of this paragraph varies across posts ("Practical tools
        // in...", "Practical tools at...", etc.); matching by position +
        // toolkit link is more robust than matching by text.
        if (paidContent) {
          const referencesHeading = Array.from(paidContent.querySelectorAll('h2, h3')).find((heading) =>
            (heading.textContent || '').trim().toLowerCase() === 'references'
          );
          if (referencesHeading) {
            let prev = referencesHeading.previousElementSibling;
            while (prev && prev.tagName !== 'P') {
              prev = prev.previousElementSibling;
            }
            if (prev && prev.tagName === 'P') {
              const link = prev.querySelector('a[href*="/gael-performance-toolkit/"]');
              if (link) {
                prev.classList.add('practical-tools-banner');
              }
            }
          }
        }

        if (shouldBypassSubscriptionGate) {
          return;
        }

        const gate = document.getElementById('subscription-gate');

        const isSubscribed = localStorage.getItem('mtg_subscribed') === 'true';

        if (isSubscribed && gate && paidContent) {
          gate.style.display = 'none';
          paidContent.classList.remove('is-locked');
        }
      });
    </script>
  </body>
</html>

<style>
  .article-main {
    width: 900px;
    max-width: calc(100% - 2em);
    padding-top: 0;
    padding-bottom: 3rem;
  }

  .article-hero {
    margin: 0 calc(50% - 50vw) 1rem;
    padding: 2rem max(1rem, calc(50vw - 450px + 1rem));
    background: linear-gradient(180deg, rgba(3, 10, 6, 0.95) 0%, rgba(3, 10, 6, 0.82) 100%);
  }

  .article-kicker {
    margin: 0;
    color: var(--purple-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.74rem;
    font-weight: 700;
  }

  .article-hero h1 {
    margin: 0.25rem 0 0.5rem;
    color: var(--green-lime);
  }

  .article-meta {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .article-meta p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--green-light);
  }

  .section-link {
    color: #ffffff !important;
    font-weight: 700;
    text-decoration: underline !important;
  }

  .section-link:hover {
    color: var(--green-lime) !important;
  }

  .article-shell {
    border: 1px solid rgba(105, 0, 90, 0.24);
    border-radius: 12px;
    background: #ffffff;
    padding: 1.1rem;
  }

  .subscription-gate {
    margin: 0 0 1.2rem;
    padding: 1rem;
    border: 2px solid rgba(105, 0, 90, 0.5);
    border-radius: 10px;
    background: rgba(240, 205, 255, 0.2);
  }

  /* Coming-soon variant for SMSP posts. Uses the lime accent so it
     reads as "in the works" rather than "you need to pay". */
  .coming-soon-gate {
    margin: 0 0 1.2rem;
    padding: 1.25rem 1.1rem;
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    background: rgba(192, 254, 113, 0.12);
    text-align: center;
  }

  .coming-soon-gate .coming-soon-eyebrow {
    margin: 0 0 0.4rem;
    color: var(--green-lime);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .coming-soon-gate h2 {
    margin: 0 0 0.6rem;
    color: var(--purple);
    font-size: 1.25rem;
  }

  .coming-soon-gate p {
    margin: 0 auto 0.5rem;
    max-width: 56ch;
    color: var(--green-dark);
  }

  .coming-soon-gate .gate-cta-back {
    margin-top: 0.85rem;
    background: transparent;
    border-color: var(--purple);
    color: var(--purple) !important;
  }

  .coming-soon-gate .gate-cta-back:hover {
    background: var(--purple);
    color: #ffffff !important;
    border-color: var(--purple);
  }

  .subscription-gate h2 {
    margin: 0 0 0.5rem;
    color: var(--purple);
    font-size: 1.2rem;
  }

  .subscription-gate p {
    margin: 0;
    color: var(--green-dark);
  }

  .subscription-gate .gate-cta {
    display: inline-block;
    margin-top: 0.7rem;
    padding: 0.5rem 0.95rem;
    border-radius: 8px;
    background: var(--green-lime);
    color: var(--green-dark) !important;
    text-decoration: none !important;
    font-weight: 700;
    border: 2px solid var(--green-lime);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .subscription-gate .gate-cta:hover {
    transform: translateY(-1px);
    border-color: var(--purple-light);
  }

  .paid-content {
    color: var(--green-dark);
  }

  .paid-content.is-locked {
    max-height: 240px;
    overflow: hidden;
    filter: blur(1.5px);
    pointer-events: none;
    user-select: none;
    opacity: 0.72;
  }

  .prose :global(p),
  .prose :global(li),
  .prose :global(ol),
  .prose :global(ul),
  .prose :global(blockquote) {
    color: var(--green-dark);
  }

  .prose :global(p) {
    margin: 0 0 0.8rem;
    line-height: 1.55;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.25rem;
    margin-left: 0.25rem;
    margin-top: 0.25rem;
    margin-bottom: 0.8rem;
  }

  .prose :global(li) {
    padding-left: 0.2rem;
    margin-bottom: 0.2rem;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    color: var(--purple);
    line-height: 1.3;
  }

  .prose :global(h2) {
    margin-top: 1rem;
    margin-bottom: 0.35rem;
  }

  .gael-toolkit-post .prose :global(.toolkit-tool-card) {
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    padding: 1rem 1.1rem 1.1rem;
    background: var(--green-light);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    margin: 0.9rem 0 1rem;
  }

  .gael-toolkit-post .prose :global(.toolkit-tool-card h2) {
    margin-top: 0;
    margin-bottom: 0.5rem;
    color: var(--green-dark);
    font-size: 1.25rem;
  }

  .prose :global(.practical-tools-banner) {
    background: var(--purple);
    color: var(--green-light);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin: 1.4rem 0;
    font-weight: 600;
    box-shadow: 0 8px 20px rgba(105, 0, 90, 0.25);
  }

  .prose :global(.practical-tools-banner a) {
    color: var(--green-lime) !important;
    text-decoration: underline;
    font-weight: 700;
  }

  .prose :global(.practical-tools-banner a:hover) {
    color: #ffffff !important;
  }

  .gael-toolkit-post .prose :global(.toolkit-tool-card p:last-child),
  .gael-toolkit-post .prose :global(.toolkit-tool-card ul:last-child),
  .gael-toolkit-post .prose :global(.toolkit-tool-card ol:last-child) {
    margin-bottom: 0;
  }

  .prose :global(h3) {
    margin-top: 0.85rem;
    margin-bottom: 0.3rem;
  }

  .prose :global(h4) {
    margin-top: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .prose :global(blockquote) {
    margin: 0.75rem 0;
  }

  .prose :global(a) {
    color: #4f0044 !important;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: #2e0028 !important;
  }

  .content-feedback-link-box {
    margin-top: 1.2rem;
    padding: 0.9rem;
    border: 1px solid rgba(105, 0, 90, 0.5);
    border-radius: 10px;
    background: rgba(244, 255, 232, 0.95);
  }

  .content-feedback-link-box p {
    margin: 0 0 0.45rem;
    color: var(--green-dark);
  }

  .content-feedback-link {
    display: inline-block;
    text-decoration: none !important;
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 0.4rem 0.8rem;
    background: var(--green-lime);
    color: var(--green-dark) !important;
    font-weight: 700;
  }

  .content-feedback-link:hover {
    border-color: var(--purple-light);
  }

  .toolkit-tools-box {
    margin-top: 1.2rem;
    padding: 0.9rem;
    border: 1px solid rgba(105, 0, 90, 0.5);
    border-radius: 10px;
    background: rgba(240, 205, 255, 0.55);
  }

  .toolkit-tools-title {
    margin: 0 0 0.45rem;
    color: var(--purple);
    font-weight: 700;
  }

  .toolkit-tools-copy {
    margin: 0 0 0.6rem;
    color: var(--green-dark);
  }

  .toolkit-tools-link {
    display: inline-block;
    text-decoration: none !important;
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    padding: 0.4rem 0.8rem;
    background: var(--green-lime);
    color: var(--green-dark) !important;
    font-weight: 700;
  }

  .toolkit-tools-link:hover {
    border-color: var(--purple-light);
  }

  @media (max-width: 720px) {
    .article-main {
      width: 100%;
      max-width: 100%;
      padding-bottom: 2rem;
    }

    .article-hero {
      padding: 1.4rem max(0.85rem, calc(50vw - 450px + 1rem));
      margin-bottom: 0.9rem;
    }

    .article-shell {
      padding: 0.9rem;
    }
  }
</style>