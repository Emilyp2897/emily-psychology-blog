---
import { getCreditForAsset } from '../data/photo-credits';

interface Props {
  /** Astro image src (the `.src` from an `import x from '../assets/...'` ImageMetadata). */
  src?: string;
  /** Or pass a photographer name directly to override the lookup. */
  photographer?: string;
  /** Optional class to extend styling per-page. */
  class?: string;
}

const { src, photographer, class: extraClass } = Astro.props as Props;
const credit = photographer
  ? { photographer }
  : getCreditForAsset(src);
const name = credit?.photographer?.trim();
const url = credit && 'url' in credit ? credit.url : undefined;
const ig = credit && 'instagram' in credit ? credit.instagram : undefined;
---

{name && (
  <p class:list={['photo-credit', extraClass]}>
    Photo: {url ? (
      <a href={url} target="_blank" rel="noopener">{name}</a>
    ) : (
      <span>{name}</span>
    )}
    {ig && (
      <>
        {' '}<a href={`https://instagram.com/${ig}`} target="_blank" rel="noopener" class="photo-credit-handle">@{ig}</a>
      </>
    )}
  </p>
)}

<style is:global>
  .photo-credit {
    margin: 0.35rem 0 0;
    font-size: 0.78rem;
    line-height: 1.3;
    color: rgba(244, 255, 232, 0.7);
    font-style: italic;
    text-align: center;
  }

  .photo-credit a {
    color: var(--green-lime) !important;
    text-decoration: none !important;
    border-bottom: 1px dotted rgba(192, 254, 113, 0.45);
  }

  .photo-credit a:hover {
    border-bottom-color: var(--green-lime);
  }

  /* Variant for pages with a white background — use the dark text colour. */
  .photo-credit.on-white {
    color: rgba(26, 26, 26, 0.65);
  }

  .photo-credit.on-white a {
    color: var(--purple) !important;
    border-bottom-color: rgba(105, 0, 90, 0.4);
  }
</style>
