---
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <p class="copyright">
      &copy; {today.getFullYear()} Mind the Gael. All rights reserved.
    </p>

    <p class="disclaimer">
      Mind the Gael is an educational platform for female athletes — not a therapy service or medical provider. Nothing shared here is medical advice, a diagnosis, or a substitute for professional support. If you're going through a difficult time, please reach out to your GP or a qualified mental health professional. A list of crisis resources is available on our <a href="/resources">resources page</a>. If you feel unsafe or at risk, contact emergency services immediately.
    </p>

    <!-- Social links removed -->
  </div>
  <div class="shamrock-chatbot-wrapper">
    <div class="shamrock-chatbot" aria-hidden="true">
      <img src="/assets/saoirse.png" alt="Shamrock Chatbot" />
    </div>
    <div class="shamrock-bubbles">
      <a class="shamrock-speech-bubble bubble-subscribe" href="/subscribe">Subscribe to the Blog</a>
      <a class="shamrock-speech-bubble bubble-chat" href="/chat">Chat with Saoirse</a>
    </div>
  </div>
<style>
  .shamrock-chatbot-wrapper {
    position: fixed;
    right: 2vw;
    bottom: 2vw;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    pointer-events: none;
  }
  .shamrock-chatbot {
    pointer-events: none;
  }

  .shamrock-bubbles {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    pointer-events: auto;
  }

  .shamrock-speech-bubble {
    background: #fff;
    color: var(--purple);
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 1em;
    padding: 0.3em 0.9em;
    box-shadow: 0 2px 8px rgba(0,0,0,0.10);
    position: static;
    min-width: 112px;
    text-align: center;
    text-decoration: none;
    z-index: 1001;
    transform: none;
    white-space: nowrap;
    line-height: 1.15;
  }

  .bubble-subscribe:hover {
    color: var(--green-dark);
    transform: translateY(-1px);
  }

  .bubble-subscribe {
    min-width: 168px;
  }

  .bubble-chat {
    min-width: 124px;
  }

  @media (max-width: 900px) {
    .shamrock-chatbot-wrapper {
      right: 0.75rem;
      bottom: 0.75rem;
      gap: 0.35rem;
      align-items: center;
    }

    .shamrock-bubbles {
      gap: 0.25rem;
    }

    .shamrock-speech-bubble {
      font-size: 0.72rem;
      min-width: 88px;
      padding: 0.2em 0.55em;
      transform: none;
    }

    .bubble-subscribe {
      min-width: 132px;
    }

    .bubble-chat {
      min-width: 98px;
    }
  }
</style>
</footer>
<style>
  .footer-inner {
    position: relative;
  }
  .footer-splashes {
    position: absolute;
    left: -60px;
    bottom: 0;
    width: 120px;
    height: auto;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }
</style>
<style>
  .shamrock-chatbot {
    position: relative;
    right: auto;
    bottom: auto;
    z-index: 1000;
    width: 180px;
    height: 180px;
    background: none;
    border: none;
    cursor: default;
    transition: transform 0.2s;
    box-shadow: 0 4px 24px rgba(0,0,0,0.22);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .shamrock-chatbot img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  @media (max-width: 900px) {
    .shamrock-chatbot {
      width: 110px;
      height: 110px;
    }
  }

  @media (max-width: 600px) {
    .shamrock-chatbot {
      width: 90px;
      height: 90px;
    }
  }

.disclaimer a {
    color: var(--green-dark);
  }

  .disclaimer a:hover {
    text-decoration: underline;
  }
</style>