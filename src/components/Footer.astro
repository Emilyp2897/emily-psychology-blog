---
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <p class="copyright">
      &copy; {today.getFullYear()} Mind the Gael. All rights reserved.
    </p>

    <p class="disclaimer">
      Mind the Gael is an educational platform for female athletes — not a therapy service or medical provider. Nothing shared here is medical advice, a diagnosis, or a substitute for professional support. If you're going through a difficult time, please reach out to your GP or a qualified mental health professional. A list of crisis resources is available on our <a href="/resources">resources page</a>. If you feel unsafe or at risk, contact emergency services immediately.
    </p>

    <!-- Social links removed -->
  </div>
  <div class="shamrock-chatbot-wrapper">
    <button class="shamrock-chatbot" aria-label="Chatbot">
      <img src="/assets/saoirse.png" alt="Shamrock Chatbot" />
    </button>
    <div class="shamrock-speech-bubble">Need help?</div>
  </div>
<style>
  .shamrock-chatbot-wrapper {
    position: fixed;
    right: 2vw;
    bottom: 2vw;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    pointer-events: none;
    gap: 6em;
  }
  .shamrock-chatbot {
    pointer-events: auto;
  }
  .shamrock-speech-bubble {
    background: #fff;
    color: var(--purple);
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 1em;
    padding: 0.3em 0.9em;
    margin-top: 0;
    margin-bottom: 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.10);
    position: relative;
    max-width: 120px;
    text-align: center;
    pointer-events: auto;
    align-self: flex-end;
    z-index: 1001;
    transform: none;
  }
  .shamrock-speech-bubble::after {
    content: '';
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-bottom: 10px solid #fff;
    filter: drop-shadow(0 2px 2px rgba(0,0,0,0.08));
  }
  @media (max-width: 600px) {
    .shamrock-chatbot-wrapper {
      right: 1vw;
      bottom: 1vw;
      flex-direction: column;
      align-items: flex-end;
      gap: 4em;
    }
    .shamrock-speech-bubble {
      font-size: 0.75rem;
      max-width: 90px;
      padding: 0.2em 0.6em;
      margin-top: 0;
      transform: none;
      align-self: flex-end;
    }
    .shamrock-speech-bubble::after {
      top: -7px;
      left: 50%;
      transform: translateX(-50%);
      border-left: 6px solid transparent;
      border-right: 6px solid transparent;
      border-bottom: 7px solid #fff;
    }
  }
</style>
</footer>
<style>
  .footer-inner {
    position: relative;
  }
  .footer-splashes {
    position: absolute;
    left: -60px;
    bottom: 0;
    width: 120px;
    height: auto;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }
</style>
<style>
  .shamrock-chatbot {
    position: fixed;
    right: 2vw;
    bottom: 2vw;
    z-index: 1000;
    width: 180px;
    height: 180px;
    background: none;
    border: none;
    cursor: pointer;
    transition: transform 0.2s;
    box-shadow: 0 4px 24px rgba(0,0,0,0.22);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .shamrock-chatbot:hover {
    transform: scale(1.08) rotate(-6deg);
    box-shadow: 0 8px 32px rgba(105,0,90,0.18);
  }
  .shamrock-chatbot img {
    width: 160px;
    height: 160px;
    object-fit: contain;
    display: block;
  }
  @media (max-width: 600px) {
    .shamrock-chatbot {
      width: 100px;
      height: 100px;
    }
    .shamrock-chatbot img {
      width: 80px;
      height: 80px;
    }
  }
</style>