---
import { Image } from 'astro:assets';
import saoirseImage from '../assets/saoirse.png';

const today = new Date();
---

<footer>
  <div class="footer-inner">
    <p class="copyright">
      &copy; {today.getFullYear()} Mind the Gael. All rights reserved.
    </p>

    <p class="disclaimer">
      Mind the Gael is an educational platform for female athletes — not a therapy service or medical provider. Nothing shared here is medical advice, a diagnosis, or a substitute for professional support. If you're going through a difficult time, please reach out to your GP or a qualified mental health professional. A list of crisis resources is available on our <a href="/resources">resources page</a>. If you feel unsafe or at risk, contact emergency services immediately.
    </p>

    <!-- Social links removed -->
  </div>
  
  <div class="support-wrapper">
    <button id="support-tab" class="support-tab" aria-label="Show support resources" aria-controls="support-drawer" aria-expanded="false">Help</button>
    <div id="support-drawer" class="support-drawer" role="dialog" aria-modal="true" aria-labelledby="support-drawer-title" aria-hidden="true" tabindex="-1">
      <button id="close-drawer" class="close-drawer" aria-label="Close support resources">✕</button>
      <h2 id="support-drawer-title">Support Resources</h2>
      <p>If you are struggling with your mental health, free resources can be made available. You can reach out via <a href="mailto:emilyphelan@mindthegael.co.uk">emilyphelan@mindthegael.co.uk</a> if you need access.</p>
      <p>Nobody should have to pay for support. Please note this is not a substitute for professional help.</p>
      <p>See the <a href="/resources">Resources page</a> for professional help services.</p>
    </div>
  </div>
  
  <div class="shamrock-chatbot-wrapper">
    <div class="saoirse-offer-pop" id="saoirse-offer-pop" role="status" aria-live="polite">
      <button type="button" class="saoirse-offer-close" id="close-saoirse-offer" aria-label="Dismiss founding offer">×</button>
      <p><strong>Founding Offer:</strong> £5/month for first 50 members + 14-day free trial for the Training the Mind series and Gael Performance Toolkit.</p>
      <a class="offer-pop-cta" href="/api/create-checkout-session?plan=individual">Start Free Trial</a>
    </div>
    <div class="shamrock-chatbot">
      <a class="shamrock-chatbot-link" href="/chat" aria-label="Chat with Saoirse">
        <Image src={saoirseImage} alt="Shamrock Chatbot" loading="lazy" />
      </a>
    </div>
    <div class="shamrock-bubbles">
      <a class="shamrock-speech-bubble bubble-chat" href="/chat">Chat with Saoirse</a>
    </div>
  </div>
<style>
  .support-wrapper {
    position: fixed;
    left: 0;
    bottom: 2vw;
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    pointer-events: none;
  }

  .support-tab {
    display: none;
    position: relative;
    left: 0;
    width: 2.5rem;
    height: 100px;
    padding: 0.75rem 0.5rem;
    border-radius: 0 8px 8px 0;
    background: var(--purple);
    color: var(--green-light);
    border: none;
    font-size: 0.75rem;
    font-weight: bold;
    cursor: pointer;
    z-index: 1002;
    box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.2);
    transition: all 0.2s ease;
    white-space: normal;
    word-wrap: break-word;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .support-tab:hover {
    background: var(--purple-dark, #5a3d82);
    transform: translateX(4px);
  }

  .support-tab:active {
    transform: translateX(2px);
  }

  .support-drawer {
    display: none;
    position: fixed;
    left: 0;
    top: 0;
    width: 280px;
    height: 100vh;
    background: white;
    z-index: 1001;
    padding: 2rem 1.5rem;
    box-shadow: 2px 0 12px rgba(0, 0, 0, 0.15);
    overflow-y: auto;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    pointer-events: auto;
  }

  .support-drawer.active {
    display: block;
    transform: translateX(0);
  }

  .support-drawer h2 {
    color: var(--purple);
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }

  .support-drawer p {
    color: #333;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .support-drawer a {
    color: var(--purple);
    text-decoration: underline;
    font-weight: 600;
  }

  .support-drawer a:hover {
    color: var(--green-dark);
  }

  .close-drawer {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #666;
    padding: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .close-drawer:hover {
    color: #333;
  }

  @media (max-width: 720px) {
    .support-tab {
      display: flex;
    }
  }
</style>
<style>
  .saoirse-offer-pop {
    pointer-events: auto;
    position: relative;
    max-width: 270px;
    background: linear-gradient(135deg, #ffffff 0%, #f6f0ff 100%);
    color: var(--purple);
    border: 2px solid var(--purple-light);
    border-radius: 12px;
    padding: 0.8rem 0.9rem 0.75rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    animation: offer-pop-enter 300ms ease-out, offer-pop-pulse 2.8s ease-in-out 500ms infinite;
  }

  .saoirse-offer-pop::after {
    content: '';
    position: absolute;
    right: 28px;
    bottom: -9px;
    width: 16px;
    height: 16px;
    background: #f6f0ff;
    border-right: 2px solid var(--purple-light);
    border-bottom: 2px solid var(--purple-light);
    transform: rotate(45deg);
  }

  .saoirse-offer-pop p {
    margin: 0 0 0.55rem;
    font-size: 0.85rem;
    line-height: 1.35;
  }

  .offer-pop-cta {
    display: inline-block;
    border-radius: 999px;
    padding: 0.42rem 0.78rem;
    background: var(--green-lime);
    color: var(--green-dark);
    border: 2px solid transparent;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.82rem;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }

  .offer-pop-cta:hover {
    transform: translateY(-1px);
    border-color: var(--purple-light);
  }

  .saoirse-offer-close {
    position: absolute;
    top: 0.2rem;
    right: 0.35rem;
    border: none;
    background: transparent;
    color: var(--purple);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.12rem;
  }

  @keyframes offer-pop-enter {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes offer-pop-pulse {
    0%,
    100% {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
      transform: translateY(0);
    }
    50% {
      box-shadow: 0 12px 28px rgba(105, 0, 90, 0.22);
      transform: translateY(-2px);
    }
  }

  .shamrock-chatbot-wrapper {
    position: fixed;
    right: 2vw;
    bottom: 2vw;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    pointer-events: none;
  }
  .shamrock-chatbot {
    pointer-events: auto;
  }

  .shamrock-chatbot-link {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 10px;
    transition: transform 0.2s ease;
  }

  .shamrock-chatbot-link:hover {
    transform: translateY(-2px);
  }

  .shamrock-chatbot-link:focus-visible {
    outline: 3px solid var(--green-lime);
    outline-offset: 3px;
  }

  .shamrock-bubbles {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    pointer-events: auto;
  }

  .shamrock-speech-bubble {
    background: #fff;
    color: var(--purple);
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 1em;
    padding: 0.3em 0.9em;
    box-shadow: 0 2px 8px rgba(0,0,0,0.10);
    position: static;
    min-width: 112px;
    text-align: center;
    text-decoration: none;
    z-index: 1001;
    transform: none;
    white-space: nowrap;
    line-height: 1.15;
  }

  .bubble-chat {
    min-width: 124px;
  }

  @media (max-width: 900px) {
    .saoirse-offer-pop {
      max-width: 220px;
      padding: 0.65rem 0.7rem 0.62rem;
    }

    .saoirse-offer-pop p {
      font-size: 0.76rem;
    }

    .offer-pop-cta {
      font-size: 0.74rem;
      padding: 0.35rem 0.6rem;
    }

    .shamrock-chatbot-wrapper {
      right: 0.75rem;
      bottom: 0.75rem;
      gap: 0.35rem;
      align-items: center;
    }

    .shamrock-bubbles {
      gap: 0.25rem;
    }

    .shamrock-speech-bubble {
      font-size: 0.72rem;
      min-width: 88px;
      padding: 0.2em 0.55em;
      transform: none;
    }

    .bubble-chat {
      min-width: 98px;
    }
  }
</style>
</footer>
<style>
  .footer-inner {
    position: relative;
  }
  .footer-splashes {
    position: absolute;
    left: -60px;
    bottom: 0;
    width: 120px;
    height: auto;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }
</style>
<style>
  .shamrock-chatbot {
    position: relative;
    right: auto;
    bottom: auto;
    z-index: 1000;
    width: 180px;
    height: 180px;
    background: none;
    border: none;
    cursor: default;
    transition: transform 0.2s;
    box-shadow: 0 4px 24px rgba(0,0,0,0.22);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .shamrock-chatbot :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  @media (max-width: 900px) {
    .shamrock-chatbot {
      width: 110px;
      height: 110px;
    }
  }

  @media (max-width: 600px) {
    .shamrock-chatbot {
      width: 90px;
      height: 90px;
    }
  }

.disclaimer a {
    color: var(--green-dark);
  }

  .disclaimer a:hover {
    text-decoration: underline;
  }
</style>

<script>
  const supportTab = document.getElementById('support-tab');
  const supportDrawer = document.getElementById('support-drawer');
  const closeDrawer = document.getElementById('close-drawer');
  let lastFocusedElement: HTMLElement | null = null;

  function openDrawer() {
    lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    supportDrawer?.classList.add('active');
    supportDrawer?.setAttribute('aria-hidden', 'false');
    supportTab?.setAttribute('aria-expanded', 'true');
    closeDrawer?.focus();
  }

  function toggleDrawer(e: Event) {
    e.preventDefault();
    e.stopPropagation();
    if (supportDrawer?.classList.contains('active')) {
      closeDrawerFunc();
    } else {
      openDrawer();
    }
  }

  function closeDrawerFunc() {
    supportDrawer?.classList.remove('active');
    supportDrawer?.setAttribute('aria-hidden', 'true');
    supportTab?.setAttribute('aria-expanded', 'false');
    lastFocusedElement?.focus();
  }

  if (supportTab) {
    supportTab.addEventListener('click', toggleDrawer);
  }

  if (closeDrawer) {
    closeDrawer.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      closeDrawerFunc();
    });
  }

  // Close drawer when clicking outside
  document.addEventListener('click', (e) => {
    if (supportDrawer?.classList.contains('active') && e.target !== supportTab && !supportDrawer.contains(e.target as Node)) {
      closeDrawerFunc();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && supportDrawer?.classList.contains('active')) {
      closeDrawerFunc();
    }
  });

  const offerPop = document.getElementById('saoirse-offer-pop');
  const closeOfferPop = document.getElementById('close-saoirse-offer');
  const offerDismissKey = 'mtg_founding_offer_dismissed';

  if (offerPop && localStorage.getItem(offerDismissKey) === 'true') {
    offerPop.style.display = 'none';
  }

  if (offerPop && closeOfferPop) {
    closeOfferPop.addEventListener('click', () => {
      offerPop.style.display = 'none';
      localStorage.setItem(offerDismissKey, 'true');
    });
  }
</script>