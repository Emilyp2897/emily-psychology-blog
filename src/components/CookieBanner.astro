---
// Cookie consent banner. Renders once on every page; hides itself after the
// user accepts or declines. Stores the choice in localStorage so the banner
// does not return on later visits. No analytics or non-essential cookies
// are currently used on the site; the banner exists for GDPR / PECR good
// faith and to be ready when analytics is added.
---

<div class="cookie-banner" id="cookie-banner" aria-hidden="true" role="region" aria-label="Cookie consent">
  <div class="cookie-inner">
    <div class="cookie-copy">
      <p class="cookie-title">Cookies on Mind the Gael</p>
      <p class="cookie-body cookie-body-long">
        Mind the Gael uses only essential cookies needed to run the site (signin sessions, secure form submission, Stripe checkout). No tracking or analytics cookies are set without your consent. Read the <a href="/privacy" class="cookie-link">privacy policy</a>.
      </p>
      <p class="cookie-body cookie-body-short">
        Essential cookies only. <a href="/privacy" class="cookie-link">Privacy policy</a>.
      </p>
    </div>
    <div class="cookie-actions">
      <button type="button" class="cookie-btn cookie-btn-accept" id="cookie-accept">Got it</button>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const KEY = 'mtg_cookie_consent';
    const banner = document.getElementById('cookie-banner');
    if (!banner) return;

    const accepted = localStorage.getItem(KEY);
    if (accepted) {
      banner.remove();
      return;
    }

    banner.classList.add('visible');
    banner.setAttribute('aria-hidden', 'false');

    const acceptBtn = document.getElementById('cookie-accept');
    acceptBtn?.addEventListener('click', () => {
      localStorage.setItem(KEY, JSON.stringify({ accepted: true, at: new Date().toISOString() }));
      // Notify any consent-gated scripts (e.g. the analytics loader in
      // Footer.astro) so they can start loading immediately without a
      // page reload.
      window.dispatchEvent(new CustomEvent('mtg-consent-accepted'));
      banner.classList.remove('visible');
      banner.setAttribute('aria-hidden', 'true');
      window.setTimeout(() => banner.remove(), 250);
    });
  })();
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9000;
    transform: translateY(110%);
    transition: transform 0.28s ease;
    pointer-events: none;
  }

  .cookie-banner.visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  .cookie-inner {
    max-width: 1100px;
    margin: 0 auto 1rem;
    padding: 1rem 1.2rem;
    background: var(--green-dark);
    color: var(--green-light);
    border: 2px solid var(--green-lime);
    border-radius: 12px;
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.45);
    display: flex;
    gap: 1.2rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .cookie-copy {
    flex: 1 1 360px;
    min-width: 0;
  }

  .cookie-title {
    margin: 0 0 0.25rem;
    color: var(--green-lime);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .cookie-body {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--green-light);
  }

  .cookie-link {
    color: var(--green-lime) !important;
    text-decoration: underline !important;
    font-weight: 700;
  }

  /* Show the full copy on desktop, the compact one-liner on mobile.
     Both live in the DOM so screen readers still get the full context
     once one is hidden via display:none on screen. */
  .cookie-body-long { display: block; }
  .cookie-body-short { display: none; }

  .cookie-actions {
    flex: 0 0 auto;
    display: flex;
    gap: 0.5rem;
  }

  .cookie-btn {
    padding: 0.6rem 1.1rem;
    border-radius: 8px;
    font-weight: 700;
    font: inherit;
    line-height: 1.2;
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease;
    border: 2px solid var(--green-lime);
  }

  .cookie-btn-accept {
    background: var(--green-lime);
    color: var(--green-dark);
  }

  .cookie-btn-accept:hover {
    transform: translateY(-1px);
    background: var(--purple-light);
    border-color: var(--purple-light);
  }

  @media (max-width: 720px) {
    .cookie-inner {
      margin: 0 0.4rem 0.4rem;
      padding: 0.6rem 0.8rem;
      gap: 0.6rem;
      align-items: center;
      flex-direction: row;
      flex-wrap: nowrap;
    }

    .cookie-copy {
      flex: 1 1 auto;
      min-width: 0;
    }

    .cookie-title {
      font-size: 0.82rem;
      margin: 0 0 0.15rem;
    }

    .cookie-body {
      font-size: 0.78rem;
      line-height: 1.35;
    }

    .cookie-body-long { display: none; }
    .cookie-body-short { display: block; }

    .cookie-actions {
      flex: 0 0 auto;
      width: auto;
    }

    .cookie-btn {
      padding: 0.45rem 0.85rem;
      font-size: 0.82rem;
      width: auto;
    }
  }

  @media (max-width: 380px) {
    .cookie-title {
      display: none;
    }

    .cookie-body {
      font-size: 0.75rem;
    }
  }
</style>
