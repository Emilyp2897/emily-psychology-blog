---
import { Image } from 'astro:assets';
import HeaderLink from './HeaderLink.astro';
import mtgLogo from '../assets/MTG_colour.png';
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
---
<header id="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo-link" aria-label="Mind the Gael home">
      <Image src={mtgLogo} alt="Mind the Gael logo" loading="eager" fetchpriority="high" />
    </a>
    <button
      type="button"
      class="nav-toggle"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <nav class="nav-links" id="primary-nav">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <HeaderLink href="/content-hub">Content Hub</HeaderLink>
      <HeaderLink href="/personal-training">Performance Plans</HeaderLink>
      <HeaderLink href="/pricing">Pricing</HeaderLink>
      <HeaderLink href="/resources">Support Resources</HeaderLink>
      <HeaderLink href="/contact-us">Contact Us</HeaderLink>
      <a href="/login" id="nav-auth-link" class="nav-auth-link">Log In</a>
    </nav>
  </div>
  {!isHome && (
    <button
      type="button"
      class="back-bubble"
      aria-label="Go back to previous page"
      onclick="if (window.history.length > 1) { window.history.back(); } else { window.location.href = '/'; }"
    >
      <span aria-hidden="true">←</span>
    </button>
  )}
</header>

<script>
  import { supabase } from '../lib/supabase.js';

  const authLink = document.getElementById('nav-auth-link');
  const { data: { user } } = await supabase.auth.getUser();

  if (user && authLink) {
    authLink.textContent = 'Dashboard';
    authLink.setAttribute('href', '/dashboard');
  }

  // Mobile hamburger toggle: flips the nav open/closed and updates
  // aria-expanded for screen readers. Closes when a link inside the
  // drawer is tapped so the page navigation feels seamless.
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const primaryNav = document.getElementById('primary-nav');

  function closeNav() {
    if (!header || !toggle) return;
    header.classList.remove('nav-open');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open menu');
  }
  function openNav() {
    if (!header || !toggle) return;
    header.classList.add('nav-open');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close menu');
  }

  toggle?.addEventListener('click', () => {
    if (header?.classList.contains('nav-open')) closeNav();
    else openNav();
  });

  primaryNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => closeNav());
  });
</script>

<style>
  .nav-auth-link {
    color: var(--green-lime) !important;
    text-decoration: none;
    font-size: 0.93rem;
    font-weight: 700;
    padding: 0.5em 0;
    border-bottom: 4px solid transparent;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .nav-auth-link:hover {
    color: var(--purple-light) !important;
  }

  .header-inner {
    position: relative;
  }

  .header-logo-link {
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }

  /* Hamburger button — hidden on desktop, shown on mobile. */
  .nav-toggle {
    display: none;
    width: 42px;
    height: 42px;
    padding: 0;
    background: transparent;
    border: 2px solid var(--green-lime);
    border-radius: 8px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
  }

  .nav-toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--green-lime);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  /* Animate to an X when open. */
  header.nav-open .nav-toggle-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  header.nav-open .nav-toggle-bar:nth-child(2) { opacity: 0; }
  header.nav-open .nav-toggle-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .back-bubble {
    position: fixed;
    top: 96px;
    left: 18px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--green-lime);
    color: var(--green-dark);
    border: 2px solid var(--green-lime);
    font: inherit;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    z-index: 2500;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.28);
    transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }

  .back-bubble:hover {
    transform: translateY(-2px);
    background: var(--purple-light);
    border-color: var(--purple-light);
  }

  .back-bubble span {
    display: inline-block;
    line-height: 1;
    transform: translateY(-1px);
  }

  @media (max-width: 720px) {
    .back-bubble {
      top: 64px;
      left: 12px;
      width: 36px;
      height: 36px;
      font-size: 1.05rem;
    }

    .nav-toggle {
      display: inline-flex;
    }
  }
</style>