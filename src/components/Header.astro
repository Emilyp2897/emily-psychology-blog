---
import { Image } from 'astro:assets';
import HeaderLink from './HeaderLink.astro';
import mtgLogo from '../assets/MTG_colour.png';
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
---
<header>
  <div class="header-inner">
    <Image src={mtgLogo} alt="Mind the Gael logo" loading="eager" fetchpriority="high" />
    <nav class="nav-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <HeaderLink href="/content-hub">Content Hub</HeaderLink>
      <HeaderLink href="/personal-training">Performance Plans</HeaderLink>
      <HeaderLink href="/pricing">Pricing</HeaderLink>
      <HeaderLink href="/resources">Support Resources</HeaderLink>
      <HeaderLink href="/contact-us">Contact Us</HeaderLink>
      <a href="/login" id="nav-auth-link" class="nav-auth-link">Log In</a>
    </nav>
  </div>
  {!isHome && (
    <button
      type="button"
      class="back-bubble"
      aria-label="Go back to previous page"
      onclick="if (window.history.length > 1) { window.history.back(); } else { window.location.href = '/'; }"
    >
      <span aria-hidden="true">←</span>
    </button>
  )}
</header>

<script>
  import { supabase } from '../lib/supabase.js';

  const authLink = document.getElementById('nav-auth-link');
  const { data: { user } } = await supabase.auth.getUser();

  if (user && authLink) {
    authLink.textContent = 'Dashboard';
    authLink.setAttribute('href', '/dashboard');
  }
</script>

<style>
  .nav-auth-link {
    color: var(--green-lime) !important;
    text-decoration: none;
    font-size: 0.93rem;
    font-weight: 700;
    padding: 0.5em 0;
    border-bottom: 4px solid transparent;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .nav-auth-link:hover {
    color: var(--purple-light) !important;
  }

  .header-inner {
    position: relative;
  }

  .back-bubble {
    position: fixed;
    top: 96px;
    left: 18px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--green-lime);
    color: var(--green-dark);
    border: 2px solid var(--green-lime);
    font: inherit;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    z-index: 2500;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.28);
    transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }

  .back-bubble:hover {
    transform: translateY(-2px);
    background: var(--purple-light);
    border-color: var(--purple-light);
  }

  .back-bubble span {
    display: inline-block;
    line-height: 1;
    transform: translateY(-1px);
  }

  @media (max-width: 720px) {
    .back-bubble {
      top: 76px;
      left: 12px;
      width: 40px;
      height: 40px;
      font-size: 1.15rem;
    }
  }
</style>