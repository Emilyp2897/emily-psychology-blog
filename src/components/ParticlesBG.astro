<!-- tsparticles CDN loader for Astro (no React) -->
<div id="tsparticles"></div>
<script>
  window.addEventListener('DOMContentLoaded', () => {
    const tsParticles = (window as any).tsParticles;

    if (tsParticles) {
      tsParticles.load('tsparticles', {
        background: { color: '#181818' },
        fullScreen: { enable: true, zIndex: 0 },
        particles: {
          number: { value: 200 },
          color: { value: '#fff' },
          shape: { type: 'circle' },
          opacity: { value: 1 },
          size: { value: 4, random: { enable: true, minimumValue: 2 } },
          move: { enable: true, speed: 2 },
        },
        interactivity: {
          events: { onHover: { enable: false }, onClick: { enable: false } },
        },
      });
    }
  });
</script>
<style>
#tsparticles {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
}
</style>
